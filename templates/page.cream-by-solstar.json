    "section_custom_code_cream_pricing": {
      "type": "section-custom-code",
      "name": "Pricing options",
      "settings": {
        "code": "<style>.cream-pricing{--cream-bg:#0d0326;--cream-text:#ffffff;--cream-text-muted:rgba(255,255,255,.8);--cream-shadow:rgba(255,255,255,.35);--cream-surface:#f5f2ec;--cream-surface-light:#ffffff;--cream-bg-brighter:#26124f;--cream-bg-transparent:rgba(13,3,38,0);--cream-primary:#ab8c52;--cream-primary-text:#fcfbf9;--cream-primary-border:#fcfbf9;--cream-accent:#665035;--cream-border:#d1cdc4;background:var(--cream-bg);color:var(--cream-text);padding:90px 24px}.cream-pricing__inner{max-width:1100px;margin:0 auto}.cream-pricing__head{text-align:center;max-width:760px;margin:0 auto 34px}.cream-pricing__head p{margin:0 0 12px;color:var(--cream-primary);}.cream-pricing__head h2{margin:0;line-height:1.18}.cream-pricing__grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}.cream-pricing__card{background:var(--cream-surface);color:var(--cream-bg);border:1px solid var(--cream-border);border-radius:8px;padding:28px}.cream-pricing__card h3{margin:0 0 12px}.cream-pricing__card p{margin:0 0 18px;color:var(--cream-bg);line-height:1.8}.cream-pricing__card ul{margin:0;padding-left:1.2em;display:grid;gap:8px;line-height:1.75}.cream-pricing__note{margin:22px auto 0;max-width:760px;text-align:center;color:var(--cream-text-muted);line-height:1.8}@media(max-width:799px){.cream-pricing{padding:64px 16px}.cream-pricing__grid{grid-template-columns:1fr}}</style><section class='cream-pricing' id='cream-pricing'><div class='cream-pricing__inner'><div class='cream-pricing__head'><p class='hero__subheading'>Plan and pricing</p><h2>提供形態に合わせて、見せ方を選べます。</h2></div><div class='cream-pricing__grid'><article class='cream-pricing__card'><h3>テーマ単体で提供する場合</h3><p>テーマ購入・ライセンス・含まれる機能を明確にして、導入検討しやすく見せる構成です。</p><ul><li>テーマ価格</li><li>利用できるセクション・機能</li><li>アップデートやサポート範囲</li></ul></article><article class='cream-pricing__card'><h3>構築サービスに紐づける場合</h3><p>Basic / Standardなどの構築プランにCreamを標準採用し、導入フローとして見せる構成です。</p><ul><li>ヒアリング</li><li>テーマ設計・構築</li><li>公開前チェックと運用開始</li></ul></article></div><p class='cream-pricing__note'>※料金や提供条件は最終確認が必要です。実測値や価格が確定していない情報は断定せず、確認後に追記する前提で構成しています。</p></div></section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-10",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_accordion_cream_faq": {
      "type": "section-accordion-group",
      "blocks": {
        "subheading_cream": {
          "type": "subheading",
          "settings": {
            "title": "FAQ"
          }
        },
        "heading_cream": {
          "type": "heading",
          "settings": {
            "title": "よくある質問"
          }
        },
        "question_migrate": {
          "type": "question",
          "settings": {
            "default_open": true,
            "title": "既存のShopifyストアから移行できますか？",
            "content": "<p>既存ストアの構成、利用アプリ、商品データ、デザイン要件を確認したうえで移行可否と進め方をご案内します。テーマ移行では表示確認と購入導線の検証が重要です。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "question_apps": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "追加アプリは必要ですか？",
            "content": "<p>Countdown、Wishlist、Shop the look、Before & after、Testimonialsなど、よく使う販促・回遊・演出機能の一部はCream内で対応できます。ただし、レビュー、会員制度、配送連携、外部システム連携などは、要件に応じてアプリ導入を検討します。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "question_fonts": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "日本語フォントやブランドカラーは調整できますか？",
            "content": "<p>テーマ設定からタイポグラフィ、カラースキーム、ボタン、バッジ、商品カードなどを調整できます。ブランドの世界観に合わせたデザイン設計が可能です。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "question_global": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "越境運用を見据えた構成は可能ですか？",
            "content": "<p>多言語・多通貨セレクターを活用し、Shopify Marketsを使った越境運用を見据えた構成が可能です。対象国、決済、配送、翻訳運用については、Shopifyの設定や運用要件に応じた整理が必要です。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "question_support": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "カスタマイズやサポート範囲はどこまでですか？",
            "content": "<p>テーマ設定で対応できる範囲、構築時に調整する範囲、個別開発が必要な範囲を切り分けてご案内します。具体的なサポート条件は提供形態により異なります。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        }
      },
      "block_order": [
