    "section_custom_code_MEpB3b": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<!-- 実績ハイライト - SOLSTAR -->\n<div class=\"solstar-stats\">\n  <div class=\"solstar-stats__grid\">\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"100\"\n           data-decimals=\"0\"\n           data-suffix=\"億円以上\">\n        100億円以上\n      </div>\n      <div class=\"solstar-stats__label\">支援先ECサイトの年間売上規模</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"13\"\n           data-decimals=\"0\"\n           data-suffix=\"％\">\n        13％\n      </div>\n      <div class=\"solstar-stats__label\">表示速度改善率</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"4.37\"\n           data-decimals=\"2\"\n           data-suffix=\"％\">\n        4.37％\n      </div>\n      <div class=\"solstar-stats__label\">新規顧客の購入CVR</div>\n    </div>\n  </div>\n</div>\n\n<style>\n  .solstar-stats {\n    max-width: 1080px;\n    margin: 0 auto;\n    padding: 48px 16px;\n    background-color: var(--COLOR-BG);\n  }\n\n  .solstar-stats__grid {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 32px;\n  }\n\n  .solstar-stats__item {\n    text-align: center;\n    padding: 24px 16px;\n    opacity: 1;\n    transform: translateY(0);\n    transition:\n      opacity 0.6s ease-out,\n      transform 0.6s ease-out;\n  }\n\n  .solstar-stats.is-animated .solstar-stats__item:not(.is-visible) {\n    opacity: 0;\n    transform: translateY(24px);\n  }\n\n  .solstar-stats__item.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .solstar-stats__value {\n    font-weight: 700;\n    letter-spacing: 0;\n    font-size: clamp(40px, 4.2vw, 55px);\n    line-height: 1.1;\n    margin-bottom: 8px;\n    font-feature-settings: \"pnum\" on, \"lnum\" on;\n    color: var(--COLOR-TEXT);\n    white-space: nowrap;\n    word-break: keep-all;\n  }\n\n  .solstar-stats__label {\n    font-size: 20px;\n    font-weight: 700;\n    line-height: 1.6;\n    letter-spacing: 0;\n    color: var(--sp-page-accent);\n  }\n\n  @media (max-width: 767px) {\n    .solstar-stats {\n      padding: 32px 16px;\n    }\n\n    .solstar-stats__grid {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .solstar-stats__item {\n      padding: 20px 16px;\n    }\n\n    .solstar-stats__value {\n      font-size: clamp(38px, 12vw, 44px);\n    }\n\n    .solstar-stats__label {\n      font-size: 17px;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    function initSolstarStats() {\n      var sections = document.querySelectorAll('.solstar-stats');\n\n      if (!sections.length) return;\n\n      sections.forEach(function (section) {\n        if (section.dataset.solstarStatsInitialized === 'true') return;\n        section.dataset.solstarStatsInitialized = 'true';\n\n        var items = section.querySelectorAll('.solstar-stats__item');\n        var values = section.querySelectorAll('.solstar-stats__value');\n        var animated = false;\n\n        section.classList.add('is-animated');\n\n        function animateNumbers() {\n          if (animated) return;\n          animated = true;\n\n          values.forEach(function (el) {\n            var target = parseFloat(el.getAttribute('data-value') || '0');\n            var decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);\n            var suffix = el.getAttribute('data-suffix') || '';\n            var duration = 1500;\n            var start = null;\n\n            el.textContent = (0).toFixed(decimals) + suffix;\n\n            function step(timestamp) {\n              if (!start) start = timestamp;\n\n              var progress = Math.min((timestamp - start) / duration, 1);\n              var easedProgress = 1 - Math.pow(1 - progress, 3);\n              var current = target * easedProgress;\n\n              el.textContent = current.toFixed(decimals) + suffix;\n\n              if (progress < 1) {\n                window.requestAnimationFrame(step);\n              } else {\n                el.textContent = target.toFixed(decimals) + suffix;\n              }\n            }\n\n            window.requestAnimationFrame(step);\n          });\n        }\n\n        function revealItems() {\n          items.forEach(function (item, index) {\n            item.style.transitionDelay = (index * 0.12) + 's';\n            item.classList.add('is-visible');\n          });\n        }\n\n        function runAnimation() {\n          revealItems();\n          animateNumbers();\n        }\n\n        function isInViewport(el) {\n          var rect = el.getBoundingClientRect();\n          var windowHeight = window.innerHeight || document.documentElement.clientHeight;\n\n          return rect.top < windowHeight * 0.85 && rect.bottom > 0;\n        }\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(function (entries) {\n            entries.forEach(function (entry) {\n              if (entry.isIntersecting) {\n                runAnimation();\n                observer.unobserve(section);\n              }\n            });\n          }, {\n            root: null,\n            threshold: 0.2\n          });\n\n          observer.observe(section);\n\n          setTimeout(function () {\n            if (!animated && isInViewport(section)) {\n              runAnimation();\n              observer.unobserve(section);\n            }\n          }, 300);\n        } else {\n          runAnimation();\n        }\n      });\n    }\n\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', initSolstarStats);\n    } else {\n      initSolstarStats();\n    }\n\n    window.addEventListener('load', initSolstarStats);\n\n    document.addEventListener('shopify:section:load', function () {\n      initSolstarStats();\n    });\n  })();\n</script>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "contents": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .rs-plainlist { max-width: 760px; margin: 8px auto 0; padding: 0; list-style: none; }\n  .rs-plainlist li { position: relative; margin: 0 0 12px; padding-left: 1.5em; color: var(--COLOR-TEXT); font-size: var(--font-body-medium); line-height: 1.9; }\n  .rs-plainlist li:last-child { margin-bottom: 0; }\n  .rs-plainlist li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  @media (min-width: 761px) { .rs-plainlist { display: grid; grid-template-columns: 1fr 1fr; column-gap: 40px; row-gap: 12px; max-width: 920px; } .rs-plainlist li { margin-bottom: 0; } }\n</style>\n<section class=\"sp-sec sp-sec--contents\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Free Diagnosis</p>\n      <h2 class=\"sp-title\">何から始めればいいか分からない。<br>その状態のままで大丈夫です。</h2>\n      <p class=\"sp-lead\">「いきなり契約」ではありません。まずは無料診断で、どの商品をどこで売るべきか、何から始めるべきかを一緒に整理します。具体的には、こういったことが分かります。</p>\n    </div>\n    <ul class=\"rs-plainlist\">\n      <li>自社ECサイトに載せる商品、店頭で売る商品、既存の販路で早く販売・現金化する商品の分け方</li>\n      <li>全部の商品を載せずに、まずどのカテゴリから始めるべきか</li>\n      <li>半年以上動いていない在庫を、どの販路で販売・現金化するか</li>\n      <li>いまの運用体制のまま、無理なく始められるか</li>\n      <li>越境ECサイトを考えるべき商材か、後から足すか</li>\n      <li>まずはBasicプランで足りるか、将来どこを広げるか</li>\n    </ul>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "offer": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .rs-price-card { max-width: 920px; margin: 0 auto; border: 1px solid var(--sp-page-accent); border-radius: var(--sp-page-card-radius); background: var(--COLOR-TEXT-A5); padding: 32px; }\n  .rs-price-card__label { display: block; margin: 0 0 8px; color: var(--sp-page-accent); font-family: var(--FONT-STACK-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); }\n  .rs-price-card__name { margin: 0 0 6px; font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); color: var(--COLOR-TEXT); }\n  .rs-price-card__price { margin: 0 0 10px; font-family: var(--FONT-STACK-HEADING); font-size: clamp(28px, 4vw, 40px); line-height: 1.2; color: var(--COLOR-TEXT); }\n  .rs-price-card__price small { font-size: var(--font-body-medium); }\n  .rs-price-card__for { margin: 0 0 24px; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-small); line-height: 1.8; }\n  .rs-price-card__sub { margin: 0 0 14px; color: var(--COLOR-TEXT); font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); }\n  .rs-scope { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; margin: 0 0 24px; padding: 0; list-style: none; }\n  .rs-scope li { position: relative; padding-left: 1.5em; color: var(--COLOR-TEXT); font-size: var(--font-body-small); line-height: 1.7; }\n  .rs-scope li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  .rs-spec { display: grid; grid-template-columns: 1fr 1fr; gap: 0 32px; margin: 0 0 20px; padding: 0; list-style: none; }\n  .rs-spec li { display: flex; justify-content: space-between; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--sp-page-border); font-size: var(--font-body-small); }\n  .rs-spec li > span:first-child { color: var(--COLOR-TEXT-A80); white-space: nowrap; }\n  .rs-spec li > span:last-child { color: var(--COLOR-TEXT); font-weight: var(--FONT-WEIGHT-BODY-BOLD); text-align: right; }\n  .rs-price-card__note { margin: 0; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-small); line-height: 1.9; }\n  @media (max-width: 760px) { .rs-scope, .rs-spec { grid-template-columns: 1fr; } }\n</style>\n<section class=\"sp-sec sp-sec--offer\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Offer</p>\n      <h2 class=\"sp-title\">小さく始めて、<br>売上に合わせて育てるECサイト。</h2>\n      <p class=\"sp-lead\">最初から大きな投資を前提にせず、お店に合った範囲から始められます。</p>\n    </div>\n    <div class=\"rs-price-card\">\n      <p class=\"rs-price-card__name\">Basicプラン</p>\n      <p class=\"rs-price-card__price\">1,100,000円<small>（税込）〜</small></p>\n      <p class=\"rs-price-card__for\">小規模・少数SKUで、まずは価値を伝えたい商品から自社ECを始めたいお店向けのプランです。</p>\n      <p class=\"rs-price-card__sub\">構築内容</p>\n      <ul class=\"rs-scope\">\n        <li>コンセプト定義・要件定義（商品特性のヒアリング）</li>\n        <li>ECサイトの初期設定（基本情報・決済・配送・税）</li>\n        <li>各ページのデザイン制作</li>\n        <li>購入テスト・表示確認（PC / スマホ）</li>\n        <li>商品登録 20点 / カテゴリー登録 6件</li>\n        <li>アプリ連携 3点 / オリジナルページ制作 3ページ</li>\n      </ul>\n      <ul class=\"rs-spec\">\n        <li><span>構築期間</span><span>約4〜8週間</span></li>\n        <li><span>体制</span><span>ディレクター＋エンジニア</span></li>\n        <li><span>進捗打合せ</span><span>3回</span></li>\n        <li><span>修正・変更</span><span>3回まで</span></li>\n      </ul>\n      <p class=\"rs-price-card__note\">すべての商品を最初から載せる必要はありません。まずは価値や背景を伝えたい商品から小さく始め、売上や運用状況に合わせて商品数・在庫連携・運用サポートを広げていきます。</p>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "narrow": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .rs-fit { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 920px; margin: 0 auto; }\n  .rs-fit .sp-card h3 { font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); margin: 0 0 16px; text-align: center; }\n  .rs-fit .sp-card.is-fit h3 { color: var(--sp-page-accent); }\n  .rs-fit .sp-card ul { margin: 0; padding: 0; list-style: none; }\n  .rs-fit .sp-card li { position: relative; padding-left: 1.5em; font-size: var(--font-body-small); color: var(--COLOR-TEXT-A80); line-height: 1.9; margin-bottom: 10px; }\n  .rs-fit .sp-card li:last-child { margin-bottom: 0; }\n  .rs-fit .sp-card li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  .rs-close { max-width: 820px; margin: 32px auto 0; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-medium); line-height: 1.9; text-align: center; }\n  @media (max-width: 760px) { .rs-fit { grid-template-columns: 1fr; } }\n</style>\n<section class=\"sp-sec sp-sec--narrow\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Narrow</p>\n      <h2 class=\"sp-title\">正直にお伝えします。<br>このサービスが合うお店、合わないお店があります。</h2>\n    </div>\n    <div class=\"rs-fit\">\n      <div class=\"sp-card is-fit\"><h3>向いているお店</h3><ul><li>実店舗を中心に営業し、既存販路は使うが、自社ECはこれからのお店</li><li>商品化・出品が追いつかず、在庫回転と現金化に課題を感じているお店</li><li>すべての商品ではなく、価値を伝えたい商品から自社ECを始めたいお店</li><li>高額商品・専門商材・一点ものを、価格だけでなく背景まで伝えて売りたいお店</li><li>店頭・フリマ・オークションに加えて、自社の顧客リストを持ちたいお店</li><li>スタッフはいるが、EC運用の専任を置けないお店</li></ul></div>\n      <div class=\"sp-card\"><h3>いまは向いていないお店</h3><ul><li>とにかく最安値・最短販売だけを優先したいお店。その場合は、既存販路やモール中心の方が合います。</li><li>商品情報や画像の整理に、まったく協力できないお店</li><li>受注後の発送・問い合わせ対応を、社内で一切行えないお店</li><li>担当者を採用して、すべて自社の中でつくりたいお店</li></ul></div>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "action": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .rs-action-cta { text-align: center; margin-top: 36px; }\n  .rs-action-cta .btn { font-size: var(--font-body-medium); }\n  .rs-plainlist { max-width: 760px; margin: 8px auto 0; padding: 0; list-style: none; }\n  .rs-plainlist li { position: relative; margin: 0 0 12px; padding-left: 1.5em; color: var(--COLOR-TEXT); font-size: var(--font-body-medium); line-height: 1.9; }\n  .rs-plainlist li:last-child { margin-bottom: 0; }\n  .rs-plainlist li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  @media (min-width: 761px) { .rs-plainlist { display: grid; grid-template-columns: 1fr 1fr; column-gap: 40px; row-gap: 12px; max-width: 920px; } .rs-plainlist li { margin-bottom: 0; } }\n</style>\n<section class=\"sp-sec sp-sec--action\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Action</p>\n      <h2 class=\"sp-title\">全部の商品を載せなくて大丈夫。<br>まずは「価値を伝えたい商品」から始めましょう。</h2>\n      <p class=\"sp-lead\">まずは、店頭や既存販路だけでは魅力が伝わりにくい商品を数点選び、どう見せれば売れやすくなるかを考えるところから始められます。</p>\n    </div>\n    <ul class=\"rs-plainlist\">\n      <li>いまどの販路で売れていて、どのカテゴリを伸ばしたいか</li>\n      <li>買い取った商品の、どこで商品化・出品が止まっているか</li>\n      <li>どの商品を自社ECに載せ、どの商品は既存販路・店頭で早く現金化したいか</li>\n      <li>どの商品から、どんな順番で始めるのが無理がないか</li>\n    </ul>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
