      "settings": {
        "code": "<style>\n\n.se-beta{background:var(--bg);padding:64px 20px;box-sizing:border-box;color:var(--text);overflow:hidden;}\n.se-beta *{box-sizing:border-box;}\n.se-beta__inner{max-width:1100px;margin:0 auto;}\n.se-beta__eyebrow{display:block;text-align:center;color:var(--BTN-PRIMARY-BG);font-size:var(--font-subheading);font-family:var(--FONT-STACK-SUBHEADING);font-style:var(--FONT-STYLE-SUBHEADING);font-weight:var(--FONT-WEIGHT-SUBHEADING);letter-spacing:var(--LETTER-SPACING-SUBHEADING);text-transform:var(--FONT-UPPERCASE-SUBHEADING);margin:0 0 12px;}\n.se-beta__title{font-family:var(--FONT-STACK-HEADING);text-align:center;font-size:var(--font-heading-large);font-weight:800;line-height:1.45;margin:0 0 18px;color:var(--text);}\n.se-beta__lead{font-family:var(--FONT-STACK-BODY);text-align:center;font-size:var(--font-body-medium);line-height:1.95;max-width:780px;margin:0 auto 44px;opacity:.92;}\n.se-beta__note{font-family:var(--FONT-STACK-BODY);max-width:880px;margin:36px auto 0;padding:18px 22px;border-left:3px solid var(--BTN-PRIMARY-BG);background:rgba(0,0,0,.035);border-radius:6px;font-size:var(--font-body-small);line-height:1.85;opacity:.92;}\n@media (max-width:768px){.se-beta{padding:48px 18px;}.se-beta__lead{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);margin-bottom:32px;text-align:left;}.se-beta__title{line-height:1.4;}}\n\n.se-beta__card{max-width:720px;margin:0 auto;border:1px solid var(--BTN-PRIMARY-BG);border-radius:18px;padding:10px 32px;background:rgba(0,0,0,.015);}\n.se-beta__row{display:flex;justify-content:space-between;align-items:baseline;gap:18px;padding:16px 0;border-bottom:1px solid rgba(0,0,0,.08);}\n.se-beta__row:last-child{border-bottom:none;}\n.se-beta__k{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-small);font-weight:700;opacity:.8;flex:0 0 auto;}\n.se-beta__v{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);font-weight:800;text-align:right;}\n.se-beta__badge{display:inline-block;background:var(--BTN-PRIMARY-BG);color:var(--BTN-PRIMARY-TEXT,#fff);font-size:13px;font-weight:800;letter-spacing:.05em;padding:6px 16px;border-radius:999px;margin:0 auto 16px;text-align:center;}\n.se-beta__ctawrap{text-align:center;margin-top:38px;}\n.se-beta__ctawrap .btn{justify-content:center;}\n@media (max-width:768px){.se-beta__card{padding:6px 20px;}.se-beta__ctawrap .btn{width:100%;}}\n</style>\n<section class=\"se-beta\">\n  <div class=\"se-beta__inner\" style=\"text-align:center;\">\n    <span class=\"se-beta__eyebrow\">Early access</span>\n    <h2 class=\"se-beta__title\">先行導入枠として3社限定で募集します。</h2>\n    <p class=\"se-beta__lead\">EC担当者を採用する前に相談しやすいよう、先行導入枠を3社限定でご用意しています。</p>\n    <div class=\"se-beta__card\"><div class=\"se-beta__row\"><span class=\"se-beta__k\">募集社数</span><span class=\"se-beta__v\">3社限定</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">対象商品</span><span class=\"se-beta__v\">粗利率50%以上の商品</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">発送条件</span><span class=\"se-beta__v\">注文から2〜3営業日以内に発送可能</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">初期掲載商品数</span><span class=\"se-beta__v\">10〜30点程度</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">契約期間</span><span class=\"se-beta__v\">6ヶ月〜12ヶ月</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">メーカー様受取分</span><span class=\"se-beta__v\">販売価格の80%以上</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">SOLSTAR販売運営分</span><span class=\"se-beta__v\">販売価格の最大20%</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">精算条件</span><span class=\"se-beta__v\">月末締め・翌月払い</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">返品・返金</span><span class=\"se-beta__v\">契約条件に基づき精算時に調整</span></div></div>\n    <div class=\"se-beta__ctawrap\"><a class=\"btn btn--primary btn--solid\" href=\"/pages/contact\"><span>先行導入について相談する</span></a></div>\n  </div>\n</section>",
        "width": "wrapper--full",
