    "section_custom_code_w6tfFf": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  /* ============================================================\n     3. つまずきやすい3つの壁セクション (背景: グレー #ececf0)\n  ============================================================ */\n  .solstar-section-wrapper {\n    background-color: var(--bg-accent); /* 指定のグレー */\n    padding: 80px 0;\n    width: 100%;\n    box-sizing: border-box;\n    overflow: hidden; /* アニメーション時の横揺れ防止 */\n  }\n\n  .ec-hurdles-container {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 0 20px;\n  }\n\n  /* メイン見出し */\n  h2.ec-hurdles-title {\n    text-align: center;\n    font-size: var(--font-heading-large);\n    font-weight: 800;\n    margin: 0 0 50px 0;\n    color: var(--text);\n    line-height: 1.4;\n  }\n\n  .br-pc {\n    display: none;\n  }\n\n  .ec-hurdles-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 30px;\n    margin-bottom: 40px;\n  }\n\n  /* カード本体：角丸を24pxに統一 */\n  .ec-hurdle-card {\n    background: var(--bg);\n    border: 1px solid var(--border);\n    border-radius: 24px;\n    padding: 40px 25px;\n    text-align: center;\n    /* transitionからhover用を削除し、フェードイン用のみ残しています */\n    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.6s ease;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    box-shadow: 0 16px 40px rgba(0,0,0,0.05);\n  }\n\n  .ec-icon-wrapper {\n    width: 70px;\n    height: 70px;\n    margin-bottom: 20px;\n    background-color: var(--border);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .ec-icon-yen {\n    font-size: 32px;\n    font-weight: bold;\n    color: var(--text);\n    line-height: 1;\n  }\n\n  .ec-icon-wrapper svg {\n    width: 35px;\n    height: 35px;\n    fill: var(--text); \n  }\n\n  /* ISSUE # の色 */\n  .ec-hurdle-number {\n    display: block;\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--BTN-PRIMARY-BG);\n    margin-bottom: 10px;\n  }\n\n  .ec-hurdle-heading {\n    font-size: 18px;\n    font-weight: bold;\n    margin-bottom: 20px;\n    line-height: 1.5;\n    color: var(--text);\n    min-height: 3.6em;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .ec-hurdle-text {\n    font-size: 16px;\n    line-height: 1.8;\n    color: var(--text-light);\n    text-align: left;\n    margin: 0;\n  }\n\n  /* 下部メッセージ */\n  .ec-closing-message {\n    text-align: center;\n    margin-top: 20px;\n  }\n\n  .ec-closing-message p {\n    font-size: 18px;\n    line-height: 1.8;\n    color: var(--text);\n    margin: 0;\n    font-weight: bold;\n  }\n\n  /* ============================================================\n     4. フェードイン・アニメーション用のスタイル (新規追加)\n  ============================================================ */\n  .js-fade-in {\n    opacity: 0;\n    transform: translateY(40px); /* 初期状態は40px下に配置 */\n    transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n  }\n\n  .js-fade-in.is-visible {\n    opacity: 1;\n    transform: translateY(0); /* 元の位置に戻る */\n  }\n\n  /* カードを順番にフワッと出すための遅延設定 (PC表示時のみ) */\n  @media (min-width: 769px) {\n    .ec-hurdles-grid .ec-hurdle-card:nth-child(1) { transition-delay: 0.1s; }\n    .ec-hurdles-grid .ec-hurdle-card:nth-child(2) { transition-delay: 0.3s; }\n    .ec-hurdles-grid .ec-hurdle-card:nth-child(3) { transition-delay: 0.5s; }\n  }\n\n\n  /* モバイル対応 */\n  @media (max-width: 768px) {\n    .solstar-section-wrapper {\n      padding: 60px 0;\n    }\n    .ec-hurdles-grid {\n      grid-template-columns: 1fr;\n      gap: 20px;\n    }\n    .ec-hurdle-heading {\n      min-height: auto;\n    }\n    h2.ec-hurdles-title {\n      margin-bottom: 30px;\n    }\n    .br-pc {\n      display: block;\n    }\n    .ec-closing-message p {\n      font-size: 14px;\n    }\n    /* モバイル時は順番表示の遅延をリセット（縦並びのため一気に表示させるか、個別に判定） */\n    .ec-hurdles-grid .ec-hurdle-card {\n      transition-delay: 0s !important; \n    }\n  }\n</style>\n\n<div class=\"solstar-section-wrapper\">\n  <div class=\"ec-hurdles-container\">\n    <p class=\"js-fade-in\" style=\"display:block; text-align:center; margin:0 0 12px; color:var(--BTN-PRIMARY-BG); font-size:var(--font-subheading); font-family:var(--FONT-STACK-SUBHEADING); font-style:var(--FONT-STYLE-SUBHEADING); font-weight:var(--FONT-WEIGHT-SUBHEADING); letter-spacing:var(--LETTER-SPACING-SUBHEADING); text-transform:var(--FONT-UPPERCASE-SUBHEADING);\">Problem</p>\n    <h2 class=\"ec-hurdles-title js-fade-in\">自社ECサイト検討時に<br class=\"br-pc\">つまずきやすい3つの壁</h2>\n\n    <div class=\"ec-hurdles-grid\">\n      <div class=\"ec-hurdle-card js-fade-in\">\n        <div class=\"ec-icon-wrapper\">\n          <span class=\"ec-icon-yen\">¥</span>\n        </div>\n        <span class=\"ec-hurdle-number\">ISSUE 01</span>\n        <h3 class=\"ec-hurdle-heading\">初期費用のハードルが高い</h3>\n        <p class=\"ec-hurdle-text\">高品質なECサイトを構築しようとすると、初期費用は100万円以上が一般的。限られた資金で事業を回す立場にとっては、大きなリスクになっている。</p>\n      </div>\n\n      <div class=\"ec-hurdle-card js-fade-in\">\n        <div class=\"ec-icon-wrapper\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z\"></path></svg>\n        </div>\n        <span class=\"ec-hurdle-number\">ISSUE 02</span>\n        <h3 class=\"ec-hurdle-heading\">時間とリソース不足</h3>\n        <p class=\"ec-hurdle-text\">日々の業務に追われ、自社ECサイトの検討や企画まで手が回らない。「後でやろう」と思っているうちに、時間だけが過ぎていく。</p>\n      </div>\n\n      <div class=\"ec-hurdle-card js-fade-in\">\n        <div class=\"ec-icon-wrapper\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z\"></path></svg>\n        </div>\n        <span class=\"ec-hurdle-number\">ISSUE 03</span>\n        <h3 class=\"ec-hurdle-heading\">専任のEC担当者がいない</h3>\n        <p class=\"ec-hurdle-text\">「自社ECサイトをやった方がいい」と分かってはいても、社内に任せられるEC担当者がいない。その結果、始めるタイミングを先延ばしにしてしまっている。</p>\n      </div>\n    </div>\n\n    <div class=\"ec-closing-message js-fade-in\">\n      <p>\n        「やってみたいけど、高すぎて踏み出せない。。」<br>\n        これは、多くの事業者が抱える切実な悩みです。\n      </p>\n    </div>\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    // js-fade-inクラスを持つ全ての要素を取得\n    const fadeElements = document.querySelectorAll('.js-fade-in');\n\n    // Intersection Observerの設定\n    const observerOptions = {\n      root: null, // ビューポートを基準にする\n      rootMargin: '0px',\n      threshold: 0.2 // 要素が20%表示されたら発火\n    };\n\n    const observer = new IntersectionObserver(function(entries, observer) {\n      entries.forEach(function(entry) {\n        // 要素が画面に入った場合\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible'); // 表示用のクラスを付与\n          observer.unobserve(entry.target); // 一度表示したら監視を解除（何度もアニメーションさせないため）\n        }\n      });\n    }, observerOptions);\n\n    // 取得した要素を監視対象に追加\n    fadeElements.forEach(function(el) {\n      observer.observe(el);\n    });\n  });\n</script>",
