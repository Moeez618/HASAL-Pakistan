ACK-BODY);display:flex;gap:10px;font-size:var(--font-body-medium);line-height:1.7;padding:9px 0;border-bottom:1px dashed rgba(0,0,0,.08);}\n.se-role__li:last-child{border-bottom:none;}\n.se-role__chk{color:var(--BTN-PRIMARY-BG);font-weight:800;flex:0 0 auto;}\n.se-merit{max-width:1100px;margin:116px auto 0;}\n.se-merit__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}\n.se-merit__grid .se-merit__card:nth-child(4),.se-merit__grid .se-merit__card:nth-child(5){grid-column:span 1;}\n.se-merit__card{border:1px solid rgba(0,0,0,.1);border-radius:14px;padding:26px 24px;background:var(--bg);}\n.se-merit__no{display:block;text-align:center;font-size:13px;font-weight:800;color:var(--BTN-PRIMARY-BG);letter-spacing:.08em;margin-bottom:12px;}\n.se-merit__ttl{font-family:var(--FONT-STACK-HEADING);font-size:var(--font-heading-medium);font-weight:800;line-height:1.55;margin:0 0 11px;}\n.se-merit__txt{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);line-height:1.85;margin:0;opacity:.9;}\n.se-merit__head{text-align:center;margin-bottom:36px;}\n@media (max-width:768px){.se-role__cols{grid-template-columns:1fr;gap:16px;}.se-merit__grid{grid-template-columns:1fr;gap:14px;}.se-role__col{padding:24px 22px;}.se-merit{margin-top:64px;}}\n</style>\n<section class=\"se-role\">\n  <div class=\"se-role__inner\">\n    <span class=\"se-role__eyebrow\">Roles</span>\n    <h2 class=\"se-role__title\">SOLSTARが担うこと、<br class=\"se-sp-br\">メーカー様にお願いすること</h2>\n    <p class=\"se-role__lead\">EC販売に必要な実務はSOLSTARが担い、メーカー様には商品供給と発送に集中いただきます。</p>\n    <div class=\"se-role__cols\">\n      <div class=\"se-role__col is-primary\">\n        <p class=\"se-role__colhd\">SOLSTARが対応すること</p>\n        <p class=\"se-role__colsub\">EC販売に必要な実務</p>\n        <ul class=\"se-role__ul\"><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>ECサイトの制作</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品ページの作成・更新</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>販売管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>決済設定・管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>購入者対応の一次窓口</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>発送通知管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>販売データの共有</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>改善提案</li></ul>\n      </div>\n      <div class=\"se-role__col\">\n        <p class=\"se-role__colhd\">メーカー様に対応いただくこと</p>\n        <p class=\"se-role__colsub\">商品供給と発送</p>\n        <ul class=\"se-role__ul\"><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品情報の提供</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品画像・スペックの提供</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品在庫の管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品の発送</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>追跡番号の共有</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品専門知識が必要な問い合わせへの協力</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品不良・誤配送などメーカー様起因トラブルへの対応</li></ul>\n      </div>\n    </div>\n  </div>\n  <div class=\"se-merit\">\n    <div class=\"se-merit__head\">\n      <span class=\"se-role__eyebrow\">Benefits</span>\n      <h2 class=\"se-role__title\">採用せずにEC販売を始められる理由</h2>\n    </div>\n    <div class=\"se-merit__grid\"><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 01</span><h3 class=\"se-merit__ttl\">EC担当者を採用せずに始められる</h3><p class=\"se-merit__txt\">ECサイト制作、商品ページ作成、販売管理、購入者対応の一次窓口までSOLSTARが担うため、社内にEC専任担当者がいなくてもEC販売を始めやすいプランです。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 02</span><h3 class=\"se-merit__ttl\">初期費用を抑えてEC販売を検証できる</h3><p class=\"se-merit__txt\">いきなり高額なECサイト制作費をかけるのではなく、低コストでEC販売をスタート。どの商品が売れるのか、どの訴求が反応するのかを小さく検証できます。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 03</span><h3 class=\"se-merit__ttl\">商品供給と発送に集中できる</h3><p class=\"se-merit__txt\">メーカー様はECサイト管理や販売ページ改善に時間を取られず、商品開発・製造・品質管理・発送に集中できます。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 04</span><h3 class=\"se-merit__ttl\">販売データをもとに改善できる</h3><p class=\"se-merit__txt\">売上、商品別販売実績、購入傾向などをもとに、商品ページ、導線、訴求、キャンペーン内容を見直します。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 05</span><h3 class=\"se-merit__ttl\">将来的な自社EC化も見据えられる</h3><p class=\"se-merit__txt\">一定期間の運用後、条件に応じてECサイト資産をメーカー様へ譲渡することも可能です。低リスクで始め、売れる形が見えてから自社ECとして引き継げます。</p></div></div>\n  </div>\n</section>\n<style>.se-sp-br{display:none;}@media(max-width:768px){.se-sp-br{display:inline;}}</style>",
