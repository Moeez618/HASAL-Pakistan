    "section_custom_code_pricing": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n\n.se-price{background:var(--bg-accent);padding:64px 20px;box-sizing:border-box;color:var(--text);overflow:hidden;}\n.se-price *{box-sizing:border-box;}\n.se-price__inner{max-width:1100px;margin:0 auto;}\n.se-price__eyebrow{display:block;text-align:center;color:var(--BTN-PRIMARY-BG);font-size:var(--font-subheading);font-family:var(--FONT-STACK-SUBHEADING);font-style:var(--FONT-STYLE-SUBHEADING);font-weight:var(--FONT-WEIGHT-SUBHEADING);letter-spacing:var(--LETTER-SPACING-SUBHEADING);text-transform:var(--FONT-UPPERCASE-SUBHEADING);margin:0 0 12px;}\n.se-price__title{font-family:var(--FONT-STACK-HEADING);text-align:center;font-size:var(--font-heading-large);font-weight:800;line-height:1.45;margin:0 0 18px;color:var(--text);}\n.se-price__lead{font-family:var(--FONT-STACK-BODY);text-align:center;font-size:var(--font-body-medium);line-height:1.95;max-width:780px;margin:0 auto 44px;opacity:.92;}\n.se-price__note{font-family:var(--FONT-STACK-BODY);max-width:880px;margin:36px auto 0;padding:18px 22px;border-left:3px solid var(--BTN-PRIMARY-BG);border-radius:6px;font-size:var(--font-body-small);line-height:1.85;opacity:.92;}\n@media (max-width:768px){.se-price{padding:48px 18px;}.se-price__lead{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);margin-bottom:32px;text-align:left;}.se-price__title{line-height:1.4;}}\n\n.se-price__card{max-width:640px;margin:0 auto;background:var(--bg);border:1px solid rgba(0,0,0,.1);border-radius:18px;padding:14px 34px;}\n.se-price__row{display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:22px 0;border-bottom:1px solid rgba(0,0,0,.08);}\n.se-price__row:last-child{border-bottom:none;}\n.se-price__label{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);font-weight:700;opacity:.85;}\n.se-price__value{font-size:clamp(20px,3.6vw,26px);font-weight:800;color:var(--text);text-align:right;}\n.se-price__value em{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-small);font-weight:600;opacity:.6;font-style:normal;margin-left:4px;}\n.se-price__desc{font-family:var(--FONT-STACK-BODY);max-width:760px;margin:34px auto 0;font-size:var(--font-body-medium);line-height:1.95;opacity:.92;}\n@media (max-width:768px){.se-price__card{padding:8px 22px;}.se-price__row{padding:18px 0;}}\n</style>\n<section class=\"se-price\">\n  <div class=\"se-price__inner\">\n    <span class=\"se-price__eyebrow\">Pricing</span>\n    <h2 class=\"se-price__title\">EC担当者を採用するより、低リスクで始められる料金設計</h2>\n    <div class=\"se-price__card\"><div class=\"se-price__row\"><span class=\"se-price__label\">初期費用</span><span class=\"se-price__value\">55,000円 <em>税込</em></span></div><div class=\"se-price__row\"><span class=\"se-price__label\">月額費用</span><span class=\"se-price__value\">36,500円〜 <em>税込</em></span></div><div class=\"se-price__row\"><span class=\"se-price__label\">SOLSTAR販売運営分</span><span class=\"se-price__value\">販売価格の最大20%</span></div><div class=\"se-price__row\"><span class=\"se-price__label\">メーカー様受取分</span><span class=\"se-price__value\">販売価格の80%以上</span></div></div>\n    <p class=\"se-price__desc\">SOLSTAR販売運営分には、決済手数料だけでなく、商品ページ更新、販売管理、購入者対応の一次窓口、発送通知、販売データ共有、改善提案まで含まれます。EC担当者を採用する前に、必要なEC業務を外部チームとして活用できる料金設計です。</p>\n    <div class=\"se-price__note\">メーカー様受取分は、販売実績に基づき「商品仕入代金」としてお支払いします。詳細は商品カテゴリ・粗利率・発送体制・返品リスク・問い合わせ対応の負荷などをふまえ、契約条件に基づき協議のうえ決定します。</div>\n  </div>\n</section>",
