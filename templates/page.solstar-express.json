    "section_fit_notfit_solstar": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n\n.se-fit{background:var(--bg-accent);padding:64px 20px;box-sizing:border-box;color:var(--text);overflow:hidden;}\n.se-fit *{box-sizing:border-box;}\n.se-fit__inner{max-width:1100px;margin:0 auto;}\n.se-fit__eyebrow{display:block;text-align:center;color:var(--BTN-PRIMARY-BG);font-size:var(--font-subheading);font-family:var(--FONT-STACK-SUBHEADING);font-style:var(--FONT-STYLE-SUBHEADING);font-weight:var(--FONT-WEIGHT-SUBHEADING);letter-spacing:var(--LETTER-SPACING-SUBHEADING);text-transform:var(--FONT-UPPERCASE-SUBHEADING);margin:0 0 12px;}\n.se-fit__title{font-family:var(--FONT-STACK-HEADING);text-align:center;font-size:var(--font-heading-large);font-weight:800;line-height:1.45;margin:0 0 18px;color:var(--text);}\n.se-fit__lead{font-family:var(--FONT-STACK-BODY);text-align:center;font-size:var(--font-body-medium);line-height:1.95;max-width:780px;margin:0 auto 44px;opacity:.92;}\n.se-fit__note{font-family:var(--FONT-STACK-BODY);max-width:880px;margin:36px auto 0;padding:18px 22px;border-left:3px solid var(--BTN-PRIMARY-BG);border-radius:6px;font-size:var(--font-body-small);line-height:1.85;opacity:.92;}\n@media (max-width:768px){.se-fit{padding:48px 18px;}.se-fit__lead{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);margin-bottom:32px;text-align:left;}.se-fit__title{line-height:1.4;}}\n\n.se-fit__grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;max-width:980px;margin:0 auto;}\n.se-fit__card{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:10px;background:var(--bg);border:1px solid rgba(0,0,0,.08);border-radius:14px;padding:22px 14px;min-height:118px;transition:transform .2s,box-shadow .2s;}\n.se-fit__card:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,.06);}\n.se-fit__ic{display:flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:var(--BTN-PRIMARY-BG);color:var(--BTN-PRIMARY-TEXT,#fff);font-weight:800;font-size:16px;}\n.se-fit__lab{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-small);font-weight:700;line-height:1.5;}\n.se-fit__ex{font-family:var(--FONT-STACK-BODY);max-width:820px;margin:30px auto 0;text-align:center;font-size:var(--font-body-medium);line-height:1.9;opacity:.9;}\n.se-fit__ex strong{color:var(--BTN-PRIMARY-BG);}\n.se-fit__divider{max-width:920px;margin:96px auto 0;border-top:1px solid rgba(0,0,0,.12);padding-top:72px;}\n.se-fit__nfgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px 22px;max-width:820px;margin:0 auto;list-style:none;padding:0;}\n.se-fit__nf{font-family:var(--FONT-STACK-BODY);display:flex;gap:10px;align-items:center;font-size:var(--font-body-medium);padding:8px 0;border-bottom:1px dashed rgba(0,0,0,.1);}\n.se-fit__nfx{color:#c0392b;font-weight:800;}\n@media (max-width:980px){.se-fit__grid{grid-template-columns:repeat(3,1fr);}}\n@media (max-width:768px){.se-fit__grid{grid-template-columns:repeat(2,1fr);gap:10px;}.se-fit__card{min-height:104px;padding:18px 10px;}.se-fit__nfgrid{grid-template-columns:1fr;}.se-fit__divider{margin-top:48px;padding-top:48px;}}\n</style>\n<section class=\"se-fit\">\n  <div class=\"se-fit__inner\">\n    <span class=\"se-fit__eyebrow\">Good fit</span>\n    <h2 class=\"se-fit__title\">Solstar Expressと相性の良い商品</h2>\n    <p class=\"se-fit__lead\">次のような特性を持つ商品は、本プランと相性が良く、低リスクでEC販売を検証しやすい傾向があります。</p>\n    <div class=\"se-fit__grid\"><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">粗利率が高い</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">返品率が低い</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">小型で発送しやすい</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">壊れにくい</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">在庫が安定している</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">説明がシンプル</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">2〜3営業日以内に発送可能</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">法規制の負担が少ない</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">SNS・広告と相性が良い</span></div><div class=\"se-fit__card\"><span class=\"se-fit__ic\">✓</span><span class=\"se-fit__lab\">ギフト需要がある</span></div></div>\n    <p class=\"se-fit__ex\">具体例：<strong>雑貨、インテリア小物、バッグ、アパレル小物、アクセサリー、ガジェット周辺品、ギフト商品、アウトドア小物</strong> など。</p>\n    <div class=\"se-fit__divider\">\n      <span class=\"se-fit__eyebrow\">Please note</span>\n      <h2 class=\"se-fit__title\">本プランの対象外となる場合がある商品</h2>\n      <p class=\"se-fit__lead\">以下の商品は、法規制・返品対応・品質管理・購入者対応などを慎重に設計する必要があるため、通常のECサイト制作プランをご提案する場合があります。</p>\n      <ul class=\"se-fit__nfgrid\"><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>食品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>サプリメント</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>化粧品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>医療・健康効果を訴求する商品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>中古品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>高額ブランド品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>高額時計</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>壊れやすい商品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>大型家具</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>サイズ返品が多いアパレル</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>受注生産品</li><li class=\"se-fit__nf\"><span class=\"se-fit__nfx\">×</span>納期が不安定な商品</li></ul>\n      <div class=\"se-fit__note\">商品カテゴリや販売条件によっては、本プランでの対応が難しい場合があります。まずはお気軽にご相談ください。</div>\n    </div>\n  </div>\n</section>\n<style>.se-sp-br3{display:none;}@media(max-width:768px){.se-sp-br3{display:inline;}}</style>",
