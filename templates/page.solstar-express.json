    "section_custom_code_flow": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n\n.se-flow{background:var(--bg-accent);padding:64px 20px;box-sizing:border-box;color:var(--text);overflow:hidden;}\n.se-flow *{box-sizing:border-box;}\n.se-flow__inner{max-width:1100px;margin:0 auto;}\n.se-flow__eyebrow{display:block;text-align:center;color:var(--BTN-PRIMARY-BG);font-size:var(--font-subheading);font-family:var(--FONT-STACK-SUBHEADING);font-style:var(--FONT-STYLE-SUBHEADING);font-weight:var(--FONT-WEIGHT-SUBHEADING);letter-spacing:var(--LETTER-SPACING-SUBHEADING);text-transform:var(--FONT-UPPERCASE-SUBHEADING);margin:0 0 12px;}\n.se-flow__title{font-family:var(--FONT-STACK-HEADING);text-align:center;font-size:var(--font-heading-large);font-weight:800;line-height:1.45;margin:0 0 18px;color:var(--text);}\n.se-flow__lead{font-family:var(--FONT-STACK-BODY);text-align:center;font-size:var(--font-body-medium);line-height:1.95;max-width:780px;margin:0 auto 44px;opacity:.92;}\n.se-flow__note{font-family:var(--FONT-STACK-BODY);max-width:880px;margin:36px auto 0;padding:18px 22px;border-left:3px solid var(--BTN-PRIMARY-BG);background:rgba(0,0,0,.035);border-radius:6px;font-size:var(--font-body-small);line-height:1.85;opacity:.92;}\n@media (max-width:768px){.se-flow{padding:48px 18px;}.se-flow__lead{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);margin-bottom:32px;text-align:left;}.se-flow__title{line-height:1.4;}}\n\n.se-flow__list{list-style:none;max-width:840px;margin:0 auto;padding:0;position:relative;}\n.se-flow__step{display:flex;gap:20px;padding-bottom:26px;position:relative;}\n.se-flow__step:not(:last-child)::before{content:\"\";position:absolute;left:21px;top:46px;bottom:0;width:2px;background:rgba(0,0,0,.12);}\n.se-flow__n{flex:0 0 44px;width:44px;height:44px;border-radius:50%;background:var(--BTN-PRIMARY-BG);color:var(--BTN-PRIMARY-TEXT,#fff);font-weight:800;font-size:18px;display:flex;align-items:center;justify-content:center;z-index:1;}\n.se-flow__body{background:var(--bg);border:1px solid rgba(0,0,0,.08);border-radius:12px;padding:18px 22px;flex:1;}\n.se-flow__role{display:inline-block;font-size:12px;font-weight:800;letter-spacing:.04em;padding:3px 12px;border-radius:999px;margin-bottom:9px;}\n.se-flow__role.is-solstar{background:var(--BTN-PRIMARY-BG);color:var(--BTN-PRIMARY-TEXT,#fff);}\n.se-flow__role.is-maker{background:rgba(0,0,0,.08);color:var(--text);}\n.se-flow__role.is-buyer{background:transparent;color:var(--text);border:1px solid rgba(0,0,0,.25);}\n.se-flow__stepttl{font-family:var(--FONT-STACK-HEADING);font-size:var(--font-heading-medium);font-weight:800;line-height:1.6;margin:0 0 6px;}\n.se-flow__steptxt{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);line-height:1.85;margin:0;opacity:.9;}\n@media (max-width:768px){.se-flow__step{gap:14px;}.se-flow__n{flex:0 0 38px;width:38px;height:38px;font-size:16px;}.se-flow__step:not(:last-child)::before{left:18px;top:40px;}.se-flow__body{padding:15px 16px;}}\n</style>\n<section class=\"se-flow\">\n  <div class=\"se-flow__inner\">\n    <span class=\"se-flow__eyebrow\">How it works</span>\n    <h2 class=\"se-flow__title\">注文から精算までの流れ</h2>\n    <p class=\"se-flow__lead\">ECサイト制作から販売、発送通知、購入者対応の一次窓口、精算まで。<br>役割を分担しながら、EC販売を回していきます。</p>\n    <ol class=\"se-flow__list\"><li class=\"se-flow__step\"><div class=\"se-flow__n\">1</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-solstar\">SOLSTAR</span><h3 class=\"se-flow__stepttl\">SOLSTARがShopifyでECサイトを制作・運用</h3><p class=\"se-flow__steptxt\">SOLSTARがShopifyでECサイトを制作し、商品ページの作成・更新や販売管理を行います。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">2</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-buyer\">購入者</span><h3 class=\"se-flow__stepttl\">購入者がECサイトで商品を購入</h3><p class=\"se-flow__steptxt\">購入者はECサイト上で商品を購入します。購入者から見た販売者はSOLSTARです。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">3</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-solstar\">SOLSTAR</span><h3 class=\"se-flow__stepttl\">SOLSTARが注文情報を確認</h3><p class=\"se-flow__steptxt\">注文が入ると、SOLSTARが注文内容と配送先を確認し、メーカー様へ連携します。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">4</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-maker\">メーカー様</span><h3 class=\"se-flow__stepttl\">メーカー様が購入者へ商品を発送</h3><p class=\"se-flow__steptxt\">メーカー様が、購入者の配送先へ商品を発送します。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">5</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-maker\">メーカー様</span><h3 class=\"se-flow__stepttl\">追跡番号をSOLSTARへ共有</h3><p class=\"se-flow__steptxt\">発送後、メーカー様は追跡番号をSOLSTARへ共有します。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">6</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-solstar\">SOLSTAR</span><h3 class=\"se-flow__stepttl\">発送通知・購入者対応の一次窓口</h3><p class=\"se-flow__steptxt\">SOLSTARが購入者へ発送通知を行い、購入者対応の一次窓口を担います。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">7</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-solstar\">SOLSTAR</span><h3 class=\"se-flow__stepttl\">月末に販売実績を集計</h3><p class=\"se-flow__steptxt\">月末締めで販売実績を集計し、メーカー様へ共有します。</p></div></li><li class=\"se-flow__step\"><div class=\"se-flow__n\">8</div><div class=\"se-flow__body\"><span class=\"se-flow__role is-solstar\">SOLSTAR</span><h3 class=\"se-flow__stepttl\">翌月、商品仕入代金としてお支払い</h3><p class=\"se-flow__steptxt\">翌月、販売実績に基づき、商品仕入代金としてメーカー様へお支払いします。</p></div></li></ol>\n    <div class=\"se-flow__note\">本プランでは、購入者から見た販売者はSOLSTARです。メーカー様はSOLSTARの取引先として商品を供給し、注文が入った商品を購入者へ発送いただきます。月末に販売実績を集計し、翌月に商品仕入代金としてお支払いします。</div>\n  </div>\n</section>",
        "width": "wrapper--full",
