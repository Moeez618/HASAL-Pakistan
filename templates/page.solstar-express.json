      "settings": {
        "code": "<div class=\"solstar-video-section\">\n  <div class=\"solstar-video-container\">\n    \n    <div class=\"solstar-text-wrapper\">\n      <p style=\"display:block; margin:0 0 12px; color:var(--BTN-PRIMARY-BG); font-size:var(--font-subheading); font-family:var(--FONT-STACK-SUBHEADING); font-style:var(--FONT-STYLE-SUBHEADING); font-weight:var(--FONT-WEIGHT-SUBHEADING); letter-spacing:var(--LETTER-SPACING-SUBHEADING); text-transform:var(--FONT-UPPERCASE-SUBHEADING);\">Overview</p>\n      <h2 class=\"solstar-video-title\">Solstar Express<br class=\"solstar-video-br\">の概要を動画で知る</h2>\n      <p class=\"solstar-video-lead\">当サービスを8分程度でわかりやすく解説している動画となっています。</p>\n    </div>\n\n    <div class=\"youtube-facade\" data-id=\"ydV79fOPG5o\" aria-label=\"動画を再生する\">\n      <img src=\"https://img.youtube.com/vi/ydV79fOPG5o/maxresdefault.jpg\" alt=\"Solstar Express 概要動画\" loading=\"lazy\">\n      \n      <div class=\"play-button\">\n        <svg viewBox=\"0 0 68 48\" width=\"68\" height=\"48\">\n          <path class=\"play-bg\" d=\"M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z\"></path>\n          <path class=\"play-icon\" d=\"M 45,24 27,14 27,34\" fill=\"#FFFFFF\"></path>\n        </svg>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  /* 全体の背景設定（白背景の場合） */\n  .solstar-video-section {\n    width: 100%;\n    padding: 60px 20px;\n    background-color: var(--bg); /* 必要に応じて #ececf0 に変更してください */\n    box-sizing: border-box;\n  }\n\n  /* コンテナ設定：最大幅を800pxにしてサイズを小さく調整 */\n  .solstar-video-container {\n    max-width: 800px;\n    margin: 0 auto;\n    text-align: center;\n  }\n\n  /* 見出し：他セクションと統一 */\n  .solstar-video-title {\n    font-size: var(--font-heading-large);\n    font-weight: 800;\n    margin-bottom: 16px;\n    color: var(--text);\n  }\n\n  .solstar-video-br {\n    display: none;\n  }\n\n  /* 説明文：他セクションと統一 */\n  .solstar-video-lead {\n    font-size: 16px;\n    line-height: 1.6;\n    margin-bottom: 40px;\n    color: var(--text-light);\n  }\n\n  /* 動画枠：角丸を24pxに統一 */\n  .youtube-facade {\n    position: relative;\n    width: 100%;\n    padding-bottom: 56.25%; /* 16:9 アスペクト比 */\n    background-color: #000;\n    cursor: pointer;\n    overflow: hidden;\n    border-radius: 0; /* 他のカードと統一 */\n    box-shadow: 0 16px 40px rgba(0,0,0,0.1);\n    transform: translateZ(0); /* Safariでの角丸バグ防止 */\n  }\n\n  /* 画像とiframeの配置 */\n  .youtube-facade img,\n  .youtube-facade iframe {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    border: none;\n    border-radius: 0; /* iframe側にも適用 */\n  }\n\n  /* 再生ボタン */\n  .play-button {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    z-index: 2;\n    transition: transform 0.2s ease, opacity 0.2s ease;\n  }\n\n  .play-bg {\n    fill: #FF0000;\n    opacity: 0.9;\n    transition: fill 0.1s;\n  }\n\n  .youtube-facade:hover .play-bg {\n    fill: #CC0000;\n    opacity: 1;\n  }\n\n  .youtube-facade:hover .play-button {\n    transform: translate(-50%, -50%) scale(1.1);\n  }\n\n  /* モバイル対応 */\n  @media (max-width: 768px) {\n    .solstar-video-lead {\n      font-size: 16px;\n      margin-bottom: 30px;\n    }\n    .solstar-video-br {\n      display: inline;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    var videoContainers = document.querySelectorAll('.youtube-facade');\n\n    videoContainers.forEach(function(container) {\n      container.addEventListener('click', function() {\n        var videoId = this.getAttribute('data-id');\n        var iframe = document.createElement('iframe');\n        iframe.setAttribute('src', 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0');\n        iframe.setAttribute('frameborder', '0');\n        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');\n        iframe.setAttribute('allowfullscreen', 'true');\n        // 角丸をiframeにも強制適用\n        iframe.style.borderRadius = \"0\";\n        \n        this.innerHTML = '';\n        this.appendChild(iframe);\n      });\n    });\n  });\n</script>",
