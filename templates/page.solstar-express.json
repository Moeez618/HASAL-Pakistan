    "section_custom_code_8WDV9d": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n\n.se-role{background:var(--bg);padding:64px 20px;box-sizing:border-box;color:var(--text);overflow:hidden;}\n.se-role *{box-sizing:border-box;}\n.se-role__inner{max-width:1100px;margin:0 auto;}\n.se-role__eyebrow{display:block;text-align:center;color:var(--BTN-PRIMARY-BG);font-size:var(--font-subheading);font-family:var(--FONT-STACK-SUBHEADING);font-style:var(--FONT-STYLE-SUBHEADING);font-weight:var(--FONT-WEIGHT-SUBHEADING);letter-spacing:var(--LETTER-SPACING-SUBHEADING);text-transform:var(--FONT-UPPERCASE-SUBHEADING);margin:0 0 12px;}\n.se-role__title{font-family:var(--FONT-STACK-HEADING);text-align:center;font-size:var(--font-heading-large);font-weight:800;line-height:1.45;margin:0 0 18px;color:var(--text);}\n.se-role__lead{font-family:var(--FONT-STACK-BODY);text-align:center;font-size:var(--font-body-medium);line-height:1.95;max-width:780px;margin:0 auto 28px;opacity:.92;}\n.se-role__note{font-family:var(--FONT-STACK-BODY);max-width:880px;margin:36px auto 0;padding:18px 22px;border-left:3px solid var(--BTN-PRIMARY-BG);background:rgba(0,0,0,.035);border-radius:6px;font-size:var(--font-body-small);line-height:1.85;opacity:.92;}\n@media (max-width:768px){.se-role{padding:48px 18px;}.se-role__lead{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);margin-bottom:24px;text-align:left;}.se-role__title{line-height:1.4;}}\n\n.se-bying-process{padding:0 20px 64px;box-sizing:border-box;}\n.se-bying-process__inner{max-width:880px;margin:0 auto;}\n.se-bying-process__inner img{display:block;width:100%;height:auto;border-radius:14px;}\n@media (max-width:768px){.se-bying-process{padding:0 18px 40px;}.se-bying-process__inner{max-width:100%;}}\n\n.se-role__cols{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;}\n.se-role__col{border:1px solid rgba(0,0,0,.1);border-radius:16px;padding:30px 28px;background:var(--bg);}\n.se-role__col.is-primary{background:rgba(0,0,0,.02);border-color:var(--BTN-PRIMARY-BG);}\n.se-role__colhd{font-family:var(--FONT-STACK-HEADING);font-size:var(--font-heading-medium);font-weight:800;margin:0 0 4px;}\n.se-role__colsub{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-small);opacity:.7;margin:0 0 20px;}\n.se-role__ul{list-style:none;padding:0;margin:0;}\n.se-role__li{font-family:var(--FONT-STACK-BODY);display:flex;gap:10px;font-size:var(--font-body-medium);line-height:1.7;padding:9px 0;border-bottom:1px dashed rgba(0,0,0,.08);}\n.se-role__li:last-child{border-bottom:none;}\n.se-role__chk{color:var(--BTN-PRIMARY-BG);font-weight:800;flex:0 0 auto;}\n.se-merit{max-width:1100px;margin:116px auto 0;}\n.se-merit__grid{display:grid;grid-template-columns:repeat(6,1fr);gap:20px;align-items:stretch;}\n.se-merit__card{grid-column:span 2;border:1px solid rgba(0,0,0,.1);border-radius:14px;padding:26px 24px;background:var(--bg);}\n.se-merit__grid .se-merit__card:nth-child(4){grid-column:2 / span 2;}\n.se-merit__grid .se-merit__card:nth-child(5){grid-column:4 / span 2;}\n.se-merit__no{display:block;text-align:center;font-size:13px;font-weight:800;color:var(--BTN-PRIMARY-BG);letter-spacing:.08em;margin:0 auto 12px;}\n.se-merit__ttl{font-family:var(--FONT-STACK-HEADING);font-size:var(--font-heading-medium);font-weight:800;line-height:1.55;margin:0 0 11px;}\n.se-merit__txt{font-family:var(--FONT-STACK-BODY);font-size:var(--font-body-medium);line-height:1.85;margin:0;opacity:.9;}\n.se-merit__head{text-align:center;margin-bottom:36px;}\n@media (max-width:768px){.se-role__cols{grid-template-columns:1fr;gap:16px;}.se-merit__grid{grid-template-columns:1fr;gap:14px;}.se-merit__card,.se-merit__grid .se-merit__card:nth-child(4),.se-merit__grid .se-merit__card:nth-child(5){grid-column:auto;}.se-role__col{padding:24px 22px;}.se-merit{margin-top:64px;}}\n</style>\n<section class=\"se-role\">\n  <div class=\"se-role__inner\">\n    <span class=\"se-role__eyebrow\">Roles</span>\n    <h2 class=\"se-role__title\">SOLSTARが担うこと、<br class=\"se-sp-br\">メーカー様にお願いすること</h2>\n    <p class=\"se-role__lead\">EC販売に必要な実務はSOLSTARが担い、メーカー様は商品供給と発送に集中できます。</p>\n    <div class=\"se-bying-process\"><div class=\"se-bying-process__inner\"><img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/EC_PRocess.png?v=1782462934\" alt=\"SOLSTARが担うこと、メーカー様にお願いすること\" loading=\"lazy\" width=\"1200\" height=\"675\"></div></div>\n    <div class=\"se-role__cols\">\n      <div class=\"se-role__col is-primary\">\n        <p class=\"se-role__colhd\">SOLSTARが対応すること</p>\n        <p class=\"se-role__colsub\">EC販売に必要な実務</p>\n        <ul class=\"se-role__ul\"><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>ECサイトの制作</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品ページの作成・更新</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>販売管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>決済設定・管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>購入者からの問い合わせ初期対応</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>販売データの共有</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>改善提案</li></ul>\n      </div>\n      <div class=\"se-role__col\">\n        <p class=\"se-role__colhd\">メーカー様に対応いただくこと</p>\n        <p class=\"se-role__colsub\">商品供給と発送</p>\n        <ul class=\"se-role__ul\"><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品情報の提供</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品在庫の管理</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品の発送</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>追跡番号の共有</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品専門知識が必要な問い合わせへの協力</li><li class=\"se-role__li\"><span class=\"se-role__chk\">✓</span>商品不良・誤配送などメーカー様起因トラブルへの対応</li></ul>\n      </div>\n    </div>\n  </div>\n  <div class=\"se-merit\">\n    <div class=\"se-merit__head\">\n      <span class=\"se-role__eyebrow\">Benefits</span>\n      <h2 class=\"se-role__title\">EC担当者を採用せずに始められる5つの理由</h2>\n    </div>\n    <div class=\"se-merit__image\"><div class=\"se-merit__image-inner\"><img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Award.jpg?v=1782461491\" alt=\"EC担当者を採用せずに始められる5つの理由\" loading=\"lazy\" width=\"1200\" height=\"675\"></div></div>\n    <div class=\"se-merit__grid\"><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 01</span><h3 class=\"se-merit__ttl\">EC担当者を採用せずに始められる</h3><p class=\"se-merit__txt\">ECサイト制作、商品ページ作成、販売管理、購入者からの問い合わせ初期対応までSOLSTARが担うため、社内にEC専任担当者がいなくても始めやすいプランです。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 02</span><h3 class=\"se-merit__ttl\">初期費用を抑えて、売れるか検証できる</h3><p class=\"se-merit__txt\">いきなり高額な制作費をかけるのではなく、初期費用を抑えながらEC販売をスタートできます。どの商品が売れるのか、どの訴求が反応するのかを確かめられます。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 03</span><h3 class=\"se-merit__ttl\">メーカー様は商品供給と発送に集中できる</h3><p class=\"se-merit__txt\">メーカー様はECサイト管理や販売ページ改善に時間を取られず、商品づくりと発送業務に専念できます。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 04</span><h3 class=\"se-merit__ttl\">売上データをもとに改善できる</h3><p class=\"se-merit__txt\">売上データをもとに、商品ページ、導線、訴求、キャンペーン内容を見直しながら改善を進められます。</p></div><div class=\"se-merit__card\"><span class=\"se-merit__no\">REASON 05</span><h3 class=\"se-merit__ttl\">売れる形が見えたら、自社EC化も検討できる</h3><p class=\"se-merit__txt\">一定期間の運用後、条件に応じてECサイト資産をメーカー様へ譲渡することも可能です。初期費用を抑えて始め、売れる形が見えてから自社EC化を検討できます。</p></div></div>\n  </div>\n</section>\n<style>.se-bying-process{padding:0 20px 64px;box-sizing:border-box;}.se-bying-process__inner{max-width:880px;margin:0 auto;}.se-bying-process__inner img{display:block;width:100%;height:auto;border-radius:14px;}.se-merit__image{padding:0 0 40px;box-sizing:border-box;}.se-merit__image-inner{max-width:880px;margin:0 auto;}.se-merit__image-inner img{display:block;width:100%;height:auto;border-radius:14px;}@media (max-width:768px){.se-bying-process{padding:0 18px 40px;}.se-bying-process__inner{max-width:100%;}.se-merit__image{padding-bottom:32px;}.se-merit__image-inner{max-width:100%;}}.se-sp-br{display:none;}@media(max-width:768px){.se-sp-br{display:inline;}}</style>",
