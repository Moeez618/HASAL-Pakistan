    "section_custom_code_rjHKWi": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  /* セクション全体 */\n  .dynamic-cost-section {\n    background-color: var(--bg);\n    width: 100%;\n    padding: 0; /* 【変更】上下の余白を削除 */\n    font-family: \"Helvetica Neue\", Arial, sans-serif;\n    color: var(--text);\n    overflow: hidden;\n  }\n\n  .dynamic-container {\n    max-width: 1000px;\n    margin: 0 auto;\n    padding: 0 5%;\n    text-align: center;\n    position: relative;\n  }\n\n  /* H2見出し */\n  h2.dynamic-title {\n    font-size: var(--font-heading-large);\n    font-weight: 800;\n    margin-bottom: 60px;\n    line-height: 1.4;\n    color: var(--text);\n    position: relative;\n    display: inline-block;\n    margin-top: 0;\n  }\n\n  .dynamic-title-br {\n    display: none;\n  }\n\n  .dynamic-eyebrow {\n    display: block;\n    margin: 60px 0 12px;\n    color: var(--BTN-PRIMARY-BG);\n    font-size: var(--font-subheading);\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n\n  /* コスト表示エリア */\n  .impact-cost-wrapper {\n    margin-bottom: 50px;\n  }\n\n  .cost-label {\n    display: block;\n    font-size: 1.2rem;\n    font-weight: bold;\n    margin-bottom: 10px;\n    letter-spacing: 0.1em;\n  }\n\n  /* 数字エリア */\n  .cost-number-area {\n    line-height: 0.9;\n    font-weight: 900;\n    letter-spacing: -0.04em;\n    display: flex;\n    align-items: baseline;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  /* 数字（赤色・カウントアップ対象） */\n  .cost-big-num {\n    font-size: clamp(8rem, 20vw, 14rem); /* 巨大サイズ */\n    color: var(--BTN-PRIMARY-BG); /* 赤色 */\n    font-variant-numeric: tabular-nums;\n    position: relative;\n    z-index: 1;\n  }\n\n  /* 単位 */\n  .cost-approx {\n    font-size: clamp(2rem, 5vw, 4rem);\n    font-weight: 800;\n    margin-right: 6px;\n    color: var(--text);\n  }\n\n  .cost-unit {\n    font-size: clamp(2rem, 5vw, 4rem);\n    font-weight: 800;\n    margin-left: 10px;\n    color: var(--text);\n  }\n\n  /* 注釈 */\n  .cost-note {\n    display: block;\n    font-size: 13px;\n    color: var(--text-light);\n    margin-top: 20px;\n    font-weight: normal;\n  }\n\n  /* 説明文エリア */\n  .dynamic-text-area {\n    max-width: 700px;\n    margin: 0 auto;\n    text-align: left;\n    border-top: 1px solid var(--border);\n    padding-top: 40px;\n    /* セクションの余白を消したので、下部に余白を確保 */\n  }\n\n  .dynamic-text-area p {\n    font-size: 16px;\n    line-height: 2;\n    margin: 0;\n    color: var(--text);\n    font-weight: 500;\n  }\n\n  /* ふわっと表示のアニメーション用クラス */\n  .fade-up-element {\n    opacity: 0;\n    transform: translateY(20px);\n    transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n  }\n\n  .fade-up-element.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* モバイル対応 */\n  @media (max-width: 768px) {\n    .dynamic-cost-section {\n      padding: 0; /* 【変更】モバイルも削除 */\n    }\n    h2.dynamic-title {\n      text-align: center;\n    }\n    .dynamic-title-br {\n      display: inline;\n    }\n    .dynamic-eyebrow {\n      margin-top: 40px;\n    }\n    .cost-number-area {\n      flex-direction: row;\n      align-items: baseline;\n    }\n    .cost-note {\n      font-size: 12px;\n    }\n    .dynamic-text-area {\n      text-align: left;\n    }\n    .dynamic-text-area p {\n      font-size: 12px;\n    }\n  }\n</style>\n\n<div class=\"dynamic-cost-section\">\n  <div class=\"dynamic-container\">\n    \n    <p class=\"dynamic-eyebrow fade-up-element\">Research</p>\n    <h2 class=\"dynamic-title fade-up-element\">\n      5,000社以上の発注データから見えた<br>\n      ECサイト制作費が高くなる本当の理由\n    </h2>\n\n    <div class=\"impact-cost-wrapper fade-up-element\">\n      <span class=\"cost-label\">平均制作費は、</span>\n      <div class=\"cost-number-area\">\n        <span class=\"cost-approx\">約</span><span class=\"cost-big-num\" id=\"count-up-target\" data-target=\"163\">163</span>\n        <span class=\"cost-unit\">万円</span>\n      </div>\n      <span class=\"cost-note\">※弊社調査</span>\n    </div>\n\n    <div class=\"dynamic-text-area fade-up-element\">\n      <p>\n        ※多くの開発会社が、設計・構築・検証をすべて含めて対応する進め方を前提としているため、100〜200万円が標準的な価格帯になっています。\n      </p>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    const fadeElements = document.querySelectorAll('.fade-up-element');\n    const counterElement = document.getElementById('count-up-target');\n    if (counterElement) counterElement.textContent = '0';\n    let hasCounted = false; \n\n    const observerOptions = {\n      root: null,\n      rootMargin: '0px',\n      threshold: 0.2 \n    };\n\n    const observer = new IntersectionObserver((entries, observer) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n\n          if (entry.target.contains(counterElement) && !hasCounted) {\n            hasCounted = true;\n            runCountUp(counterElement);\n          }\n        }\n      });\n    }, observerOptions);\n\n    fadeElements.forEach(el => observer.observe(el));\n\n    function runCountUp(el) {\n      const target = parseInt(el.getAttribute('data-target'));\n      const duration = 2000; \n      const frameDuration = 1000 / 60; \n      const totalFrames = Math.round(duration / frameDuration);\n      let frame = 0;\n\n      const counter = setInterval(() => {\n        frame++;\n        const progress = frame / totalFrames;\n        const easeOut = 1 - Math.pow(1 - progress, 3); \n        \n        const currentCount = Math.round(target * easeOut);\n\n        if (frame === totalFrames) {\n          el.textContent = target;\n          clearInterval(counter);\n        } else {\n          el.textContent = currentCount;\n        }\n      }, frameDuration);\n    }\n  });\n</script>",
        "width": "wrapper--full",
        "color_scheme": "scheme-a834ebaa-257b-48bd-9853-4460159b9060",
        "padding_top": 0,
        "padding_bottom": 50
      }
    },
