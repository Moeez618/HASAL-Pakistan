        "code": "<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Organization\",\n      \"@id\": \"https://www.solstar.co.jp/#organization\",\n      \"name\": \"株式会社SOLSTAR\",\n      \"alternateName\": \"SOLSTAR\",\n      \"url\": \"https://www.solstar.co.jp/\",\n      \"description\": \"Shopifyを活用したECサイト制作・販売管理・運用支援を行う会社です。メーカー様に代わってEC販売の立ち上げから運営まで担う、メーカー向けEC販売アウトソーシング「Solstar Express」を提供しています。\",\n      \"sameAs\": [\n        \"https://www.instagram.com/solstar_official\",\n        \"https://www.youtube.com/@solstar-official\"\n      ]\n    },\n    {\n      \"@type\": \"WebSite\",\n      \"@id\": \"https://www.solstar.co.jp/#website\",\n      \"url\": \"https://www.solstar.co.jp/\",\n      \"name\": \"株式会社SOLSTAR\",\n      \"publisher\": {\n        \"@id\": \"https://www.solstar.co.jp/#organization\"\n      },\n      \"inLanguage\": \"ja\"\n    },\n    {\n      \"@type\": \"WebPage\",\n      \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#webpage\",\n      \"url\": \"https://www.solstar.co.jp/pages/solstar-express\",\n      \"name\": \"メーカー向けEC販売アウトソーシング｜EC販売を外部チームへ｜Solstar Express\",\n      \"description\": \"Solstar Express（メーカー向けEC販売アウトソーシング）は、ECサイト制作、商品ページ作成・更新、販売管理、購入者からの問い合わせ初期対応、販売データ共有、改善提案までをSOLSTARが担うサービスです。メーカー様は商品供給と発送に集中しながら、低リスクでEC販売を検証できます。\",\n      \"isPartOf\": {\n        \"@id\": \"https://www.solstar.co.jp/#website\"\n      },\n      \"about\": {\n        \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#service\"\n      },\n      \"mainEntity\": [\n        {\n          \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#service\"\n        },\n        {\n          \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#faq\"\n        }\n      ],\n      \"breadcrumb\": {\n        \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#breadcrumb\"\n      },\n      \"inLanguage\": \"ja\"\n    },\n    {\n      \"@type\": \"Service\",\n      \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#service\",\n      \"name\": \"Solstar Express メーカー向けEC販売アウトソーシング\",\n      \"alternateName\": \"メーカー向けEC販売アウトソーシング Solstar Express\",\n      \"serviceType\": \"EC販売アウトソーシング・運用代行\",\n      \"category\": \"メーカー向けEC販売アウトソーシング\",\n      \"url\": \"https://www.solstar.co.jp/pages/solstar-express\",\n      \"provider\": {\n        \"@id\": \"https://www.solstar.co.jp/#organization\"\n      },\n      \"areaServed\": {\n        \"@type\": \"Country\",\n        \"name\": \"日本\"\n      },\n      \"audience\": {\n        \"@type\": \"BusinessAudience\",\n        \"audienceType\": \"商品はあるが、ECサイト制作・運用・販売管理に十分なリソースを持たないメーカー、EC担当者を採用する前に低リスクでEC販売を検証したいメーカー\"\n      },\n      \"description\": \"Solstar Express（メーカー向けEC販売アウトソーシング）は、Shopifyを活用したECサイト制作、商品ページ作成・更新、販売管理、決済設定・管理、購入者からの問い合わせ初期対応、発送通知、販売データ共有、改善提案までをSOLSTARが担うサービスです。購入者から見た販売者はSOLSTARで、メーカー様は商品を供給・発送し、販売実績に基づき翌月に商品仕入代金を受け取ります。\",\n      \"termsOfService\": \"先行導入枠は3社限定。契約期間は6ヶ月〜12ヶ月。精算は月末締め・翌月払い。返品・返金は契約条件に基づき精算時に調整します。\",\n      \"offers\": {\n        \"@type\": \"Offer\",\n        \"priceCurrency\": \"JPY\",\n        \"price\": \"36500\",\n        \"description\": \"初期費用55,000円（税込）、月額費用36,500円（税込）〜、SOLSTAR販売運営分は販売価格の最大20%、メーカー様受取分は販売価格の80%以上。販売価格からSOLSTAR販売運営分を差し引いた金額がメーカー様受取分の目安で、詳細は商品カテゴリ・粗利率・発送体制・返品リスク・問い合わせ対応の負荷などにより個別に決定します。\",\n        \"availability\": \"https://schema.org/LimitedAvailability\"\n      },\n      \"additionalProperty\": [\n        {\n          \"@type\": \"PropertyValue\",\n          \"name\": \"初期費用\",\n          \"value\": \"55,000円（税込）\"\n        },\n        {\n          \"@type\": \"PropertyValue\",\n          \"name\": \"月額費用\",\n          \"value\": \"36,500円（税込）〜\"\n        },\n        {\n          \"@type\": \"PropertyValue\",\n          \"name\": \"SOLSTAR販売運営分\",\n          \"value\": \"販売価格の最大20%\"\n        },\n        {\n          \"@type\": \"PropertyValue\",\n          \"name\": \"メーカー様受取分\",\n          \"value\": \"販売価格の80%以上\"\n        },\n        {\n          \"@type\": \"PropertyValue\",\n          \"name\": \"募集枠\",\n          \"value\": \"先行導入枠 3社限定\"\n        },\n        {\n          \"@type\": \"PropertyValue\",\n          \"name\": \"対象プラットフォーム\",\n          \"value\": \"Shopify\"\n        }\n      ]\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#faq\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"ECの知識がなくても利用できますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"はい、問題ありません。ECサイトの制作・運用、商品ページ作成、販売管理、購入者からの問い合わせ初期対応までSOLSTARが担うため、EC専任の担当者がいなくても始められます。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"メーカー側は何を対応すればよいですか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"商品情報・画像・スペックのご提供、在庫の管理、商品の発送、追跡番号の共有などをお願いします。商品専門知識が必要な問い合わせには、協議のうえご協力をお願いする場合があります。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"商品の発送は誰が行いますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"商品の発送はメーカー様に行っていただきます。発送後は追跡番号をSOLSTARへ共有いただき、SOLSTARが購入者へ発送通知を行います。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"売上はどのように精算されますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"購入者からの売上はSOLSTARが受領し、販売実績に基づいてメーカー様から商品を仕入れる形になります。月末に集計し、翌月に商品仕入代金としてお支払いします。返品・返金・キャンセルが発生した場合は、契約条件に基づき精算で調整します。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"顧客情報は共有されますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"個人を特定できる顧客情報は、配送業務に必要な範囲でのみ共有します。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"返品・返金・キャンセル時はどうなりますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"返品・返金・キャンセル時の精算条件は、契約内容に沿って個別にご案内します。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"将来的に自社ECとして運用できますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"一定期間の運用後、条件に応じてECサイト資産をメーカー様へ譲渡することも可能です。低リスクで始め、売れる形が見えてから自社ECとして引き継ぐことができます。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"これはメーカーの自社ECですか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"本プランでは、購入者から見た販売者はSOLSTARとなります。そのため、メーカー様が直接運営する完全な自社ECではありません。一方で、一定期間の運用後、条件に応じてECサイト資産をメーカー様へ譲渡することも可能です。まずはEC販売を小さく検証し、売れる形が見えてから自社EC化を検討できます。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"販売価格や割引はSOLSTARが自由に決めますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"いいえ。販売価格、値引き、クーポン、商品ページの表現などは、事前にメーカー様とルールを定めたうえで運用します。ブランドイメージを損なわないよう、確認フローやNG表現も整理します。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"どのような商品が向いていますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"粗利率が高く、発送サイズが小さい商品などが向いています。雑貨、インテリア小物、アクセサリー、ギフト商品などが一例です。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"対象外の商品はありますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"食品・健康効果を訴求する商品・大型家具などは、法規制や返品・品質管理を慎重に設計する必要があるため、通常のECサイト制作プランをご提案する場合があります。\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"契約期間中に販売を停止できますか？\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"契約条件に基づき、販売停止や掲載商品の変更について協議可能です。商品の在庫状況、返品対応、未発送注文の有無などを確認したうえで対応します。\"\n          }\n        }\n      ]\n    },\n    {\n      \"@type\": \"BreadcrumbList\",\n      \"@id\": \"https://www.solstar.co.jp/pages/solstar-express#breadcrumb\",\n      \"itemListElement\": [\n        {\n          \"@type\": \"ListItem\",\n          \"position\": 1,\n          \"name\": \"ホーム\",\n          \"item\": \"https://www.solstar.co.jp/\"\n        },\n        {\n          \"@type\": \"ListItem\",\n          \"position\": 2,\n          \"name\": \"サービス\",\n          \"item\": \"https://www.solstar.co.jp/pages/solstar-express\"\n        },\n        {\n          \"@type\": \"ListItem\",\n          \"position\": 3,\n          \"name\": \"Solstar Express メーカー向けEC販売アウトソーシング\",\n          \"item\": \"https://www.solstar.co.jp/pages/solstar-express\"\n        }\n      ]\n    }\n  ]\n}\n</script>\n<style>\n/* =====================================================================\n   Solstar Express LP — responsive layout refinements (page-scoped)\n   Only layout/spacing/grid/flow. No font-size, color or letter-spacing changes.\n   ===================================================================== */\n\n/* ---------- cross-cutting guards (custom-code content sections) ---------- */\n.custom-code__inner *{box-sizing:border-box}\n.custom-code__inner img{max-width:100%;height:auto}\n/* allow grid/flex children to shrink so long content never forces horizontal scroll */\n.custom-code__inner [class*=\"__grid\"]>*,\n.custom-code__inner [class*=\"__cols\"]>*,\n.custom-code__inner [class*=\"__tags\"]>*,\n.custom-code__inner [class*=\"__list\"]>*{min-width:0}\n\n/* ====================== §2 Problem — tablet 2-col ====================== */\n@media (min-width:768px) and (max-width:1023px){\n  .se-problem__grid{grid-template-columns:repeat(2,1fr)}\n}\n\n/* ============ §3 Solution emphasis — give the number room to breathe ============ */\n.se-research__big{margin-top:18px;margin-bottom:6px}\n.se-research__emph{margin-top:10px}\n\n/* ====== §4 How it works — mobile = vertical stepper (base, unchanged);\n          tablet = 2-col grid; desktop = 4-col grid ====== */\n\n\n/* ====================== §6 Benefits — tablet 2-col ====================== */\n@media (min-width:768px) and (max-width:1023px){\n  .se-merit__grid{grid-template-columns:repeat(2,1fr)}\n}\n\n/* ====== §7 Pricing — mobile = definition list (base, unchanged);\n          ≥560px = 2×2 cards; ≥1024px = 4 cards ====== */\n@media (min-width:560px){\n  .se-price__card{max-width:760px;display:grid;grid-template-columns:repeat(2,1fr);gap:14px;padding:0;border:none;background:transparent}\n  .se-price__row{flex-direction:column;align-items:flex-start;gap:6px;padding:20px 18px;border:1px solid rgba(0,0,0,.1);border-radius:14px;background:var(--bg)}\n  .se-price__row:last-child{border:1px solid rgba(0,0,0,.1)}\n  .se-price__value{text-align:left}\n}\n@media (min-width:1024px){\n  .se-price__card{grid-template-columns:repeat(4,1fr);max-width:980px}\n}\n\n/* ====== §8 Settlement — mobile = vertical flow (arrow points down) ====== */\n@media (max-width:560px){\n  .se-settle__flag{flex-direction:column;gap:10px}\n  .se-settle__arrow{transform:rotate(90deg)}\n  .se-settle__pill{width:100%;text-align:center}\n}\n\n/* ============ §9/10 Good fit & Please note — tablet tidy, no overflow ============ */\n@media (min-width:768px) and (max-width:1023px){\n  .se-fit__nfgrid{grid-template-columns:repeat(2,1fr)}\n}\n\n/* ====================== By the Numbers — mobile 1-col ====================== */\n@media (max-width:767px){\n  .solstar-stats__grid{grid-template-columns:1fr;gap:20px}\n}\n\n/* ====================== Early access — CTA breathing room ====================== */\n@media (max-width:767px){ .se-beta__ctawrap{margin-top:28px} }\n\n/* =====================================================================\n   THEME sections — safe, additive responsive enhancements only\n   (image sizing & column layout are left to the theme's own responsive CSS)\n   ===================================================================== */\n\n/* Image-with-text (FV + Story/Expertise/Message) — full-width CTA on mobile */\n@media (max-width:767px){\n  .index-image-text .hero__button{justify-content:center}\n  .index-image-text .hero__button .btn{width:100%;justify-content:center}\n}\n\n/* Solution image banner — full-width CTA on mobile */\n@media (max-width:767px){\n  .index-hero .hero__button .btn{width:100%;justify-content:center}\n}\n\n/* Mid CTA (Text with Banner) & final CTA (rich text) — full-width button on mobile */\n@media (max-width:767px){\n  #shopify-section-section_custom_content_iJUFkV .hero__button .btn,\n  #shopify-section-section_rich_text_pijWhf .hero__button .btn{width:100%;justify-content:center}\n}\n\n/* Contact form — inputs/selects never overflow, full-width submit, captcha contained */\n.index-contact *{box-sizing:border-box}\n.index-contact .field,\n.index-contact input:not([type=\"checkbox\"]):not([type=\"radio\"]),\n.index-contact select,\n.index-contact textarea{max-width:100%;width:100%}\n.index-contact .btn--full{width:100%}\n.index-contact .h-captcha,\n.index-contact .h-captcha iframe,\n.index-contact iframe[src*=\"captcha\"]{max-width:100%}\n\n/* FAQ accordion — long questions wrap cleanly inside the summary */\n.accordion-group .accordion__title{white-space:normal;overflow-wrap:anywhere;word-break:normal}\n</style>",
