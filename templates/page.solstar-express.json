    "section_custom_code_faqschema": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\n      \"@type\": \"Question\",\n      \"name\": \"本当にECの知識がなくても大丈夫ですか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"はい、問題ありません。ECサイトの設計、構築から公開までを弊社が主導して進めるため、専門知識がなくても安心してご利用いただけます。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"どこまでをSolstarが対応してくれますか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"ECサイトの設計・構築・初期設定・公開までを一貫して対応します。公開後も、弊社にて更新・運用を行います。商品の在庫管理や出荷、CS対応などは、お客様対応となります。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"30日間キャッシュバックの条件を教えてください\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"ご契約後30日以内に、サービス内容にご納得いただけなかった場合、初期費用および月額費用を返金いたします。専属の担当者へメールにて解約の旨ご連絡頂ければと思います。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"Shopifyの有料テーマは別途購入が必要ですか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"弊社が提供するオリジナルテーマ「CREAM」をご利用される場合は、有料テーマの購入は不要です。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"初期費用と月額料金以外に、追加費用はかかりますか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"基本的な構築・運用範囲については、追加費用は発生致しません。ただし、大幅な仕様変更や特別なカスタマイズ、有料アプリの導入などをご希望の場合は、別途費用が発生します。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"どれくらいの期間でECサイトは公開できますか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"最短2〜4週間でローンチ可能です。商品情報や素材のご提出状況によって前後する場合はありますが、スピード感を重視し、可能な限り早く公開できるよう進行いたします。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"商品点数が少なくても利用できますか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"はい、問題ありません。Solstar Expressは、商品数が少ない立ち上げ初期フェーズに最適化されたサービスです。まずは売れるかを検証し、段階的に拡張していくことが可能です。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"途中で解約することはできますか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"30日間のキャッシュバック期間中であれば、解約が可能です。Solstar Expressの契約期間は最低1年間となりますが、ご契約から1年経過後は月ごとの契約となり、解約をご希望の場合はお申し出いただけますと幸いです。なお、最低契約期間中（キャッシュバック期間終了後）の解約はお受けしておりませんので、あらかじめご了承ください。詳細な条件や手続きについては、ご契約時に書面にてご案内いたします。\"\n      }\n    }\n  ]\n}\n</script>",
        "width": "wrapper--full",
