e-block;background:var(--BTN-PRIMARY-BG);color:var(--BTN-PRIMARY-TEXT,#fff);font-size:13px;font-weight:800;letter-spacing:.05em;padding:6px 16px;border-radius:999px;margin:0 auto 16px;text-align:center;}\n.se-beta__ctawrap{text-align:center;margin-top:38px;}\n.se-beta__cta{display:inline-block;background:var(--BTN-PRIMARY-BG);color:var(--BTN-PRIMARY-TEXT,#fff);font-size:16px;font-weight:800;text-decoration:none;padding:16px 40px;border-radius:999px;transition:opacity .2s;}\n.se-beta__cta:hover{opacity:.85;}\n@media (max-width:768px){.se-beta__card{padding:6px 20px;}.se-beta__cta{width:100%;}}\n</style>\n<section class=\"se-beta\">\n  <div class=\"se-beta__inner\" style=\"text-align:center;\">\n    <span class=\"se-beta__eyebrow\">Early access</span>\n    <h2 class=\"se-beta__title\">先行導入枠として3社限定で募集します。</h2>\n    <p class=\"se-beta__lead\">運用品質を担保するため、対象メーカー様を限定して先行募集します。</p>\n    <div class=\"se-beta__card\"><div class=\"se-beta__row\"><span class=\"se-beta__k\">募集社数</span><span class=\"se-beta__v\">3社限定</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">対象商品</span><span class=\"se-beta__v\">粗利率50%以上の商品</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">発送条件</span><span class=\"se-beta__v\">注文から2〜3営業日以内に発送可能</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">対象SKU</span><span class=\"se-beta__v\">初期は10〜30点程度</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">契約期間</span><span class=\"se-beta__v\">6ヶ月〜12ヶ月</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">メーカー様受取分</span><span class=\"se-beta__v\">販売価格の80%以上</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">SOLSTAR販売運営分</span><span class=\"se-beta__v\">販売価格の最大20%</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">精算条件</span><span class=\"se-beta__v\">月末締め・翌月払い</span></div><div class=\"se-beta__row\"><span class=\"se-beta__k\">返品・返金</span><span class=\"se-beta__v\">契約条件に基づき精算時に調整</span></div></div>\n    <div