    "section_custom_code_8WDV9d": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  /* ---------------------------\n     共通ユーティリティ & 設定\n     --------------------------- */\n  .solstar-sp-br {\n    display: none;\n  }\n\n  @media (max-width: 600px) {\n    .solstar-sp-br {\n      display: inline;\n    }\n  }\n\n  /* ============================================================\n     アニメーション用のスタイル (新規追加)\n  ============================================================ */\n  .js-fade-in {\n    opacity: 0;\n    transform: translateY(40px);\n    transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n  }\n\n  .js-fade-in.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* PC表示時の順番表示（ディレイ）設定 */\n  @media (min-width: 769px) {\n    /* Benefitセクション / Whyセクション / Roleセクション共通のカードディレイ */\n    .solstar-benefits-grid > .js-fade-in:nth-child(1),\n    .solstar-why-grid > .js-fade-in:nth-child(1),\n    .solstar-role-grid > .js-fade-in:nth-child(1) { transition-delay: 0.1s; }\n\n    .solstar-benefits-grid > .js-fade-in:nth-child(2),\n    .solstar-why-grid > .js-fade-in:nth-child(2),\n    .solstar-role-grid > .js-fade-in:nth-child(2) { transition-delay: 0.3s; }\n\n    .solstar-benefits-grid > .js-fade-in:nth-child(3),\n    .solstar-why-grid > .js-fade-in:nth-child(3),\n    .solstar-role-grid > .js-fade-in:nth-child(3) { transition-delay: 0.5s; }\n  }\n\n  /* モバイル表示時は縦並びになるためディレイをリセット */\n  @media (max-width: 768px) {\n    .js-fade-in {\n      transition-delay: 0s !important;\n    }\n  }\n\n  /* ---------------------------\n     1. Solstar – Benefit Cards\n     --------------------------- */\n  .solstar-benefits-section {\n    background: var(--bg);\n    padding: 50px 16px; /* PCは50px */\n    color: var(--text);\n    overflow: hidden; /* アニメーション時の横揺れ防止 */\n  }\n\n  @media (max-width: 600px) {\n    .solstar-benefits-section {\n      padding: 25px 16px; /* Mobileは25px */\n    }\n  }\n\n  .solstar-benefits-inner {\n    max-width: 1260px;\n    margin: 0 auto;\n  }\n\n  .solstar-benefits-header {\n    text-align: center;\n    margin-bottom: 32px;\n  }\n\n  .solstar-benefits-header-title {\n    font-size: var(--font-heading-large);\n    font-weight: 700;\n    margin: 0;\n    color: var(--text);\n    line-height: 1.4;\n  }\n\n  .solstar-section-eyebrow {\n    display: block;\n    margin: 0 0 12px;\n    color: var(--BTN-PRIMARY-BG);\n    font-size: var(--font-subheading);\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n\n  /* Cards Layout */\n  .solstar-benefits-grid {\n    display: flex;\n    gap: 21px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  .solstar-benefit-card {\n    position: relative;\n    border-radius: 20px;\n    border: 1px solid var(--border);\n    overflow: hidden;\n    flex: 1 1 360px;\n    max-width: 406px;\n    height: 257px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0 22px;\n    box-sizing: border-box;\n    background: var(--bg);\n    color: var(--text);\n  }\n\n  /* 背景 wipe（下→上） */\n  .solstar-benefit-card::after {\n    content: \"\";\n    position: absolute;\n    inset: auto 0 0 0;\n    height: 0%;\n    background: var(--border-light);\n    z-index: 0;\n    transition: height 260ms ease;\n  }\n\n  /* 前面レイヤー */\n  .solstar-benefit-card-default,\n  .solstar-benefit-card-hover {\n    position: relative;\n    z-index: 1;\n    color: var(--text);\n  }\n\n  /* Default（通常表示） */\n  .solstar-benefit-card-default {\n    transition: opacity 180ms ease, transform 180ms ease;\n    text-align: center;\n  }\n\n  .solstar-benefit-heading-main {\n    font-size: 36px;\n    font-weight: 700;\n    line-height: 1.1;\n    margin: 0 0 10px;\n  }\n\n  .solstar-benefit-heading-sub {\n    font-size: 24px;\n    font-weight: 700;\n    line-height: 1.4;\n  }\n\n  /* Hover Content（PCのみ使用） */\n  .solstar-benefit-card-hover {\n    position: absolute;\n    inset: 0;\n    opacity: 0;\n    transform: translateY(10px);\n    pointer-events: none;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    padding: 0 28px;\n    transition: opacity 220ms ease, transform 220ms ease;\n  }\n\n  .solstar-benefit-card-hover-inner {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n\n  .solstar-benefit-card-hover p {\n    margin: 0;\n    font-size: 16px;\n    line-height: 1.7;\n    font-weight: 700;\n    color: var(--text);\n  }\n\n  /* Hover behavior（PCのみ） */\n  @media (hover: hover) and (pointer: fine) {\n    .solstar-benefit-card:hover {\n      border-color: var(--border-dark);\n    }\n\n    .solstar-benefit-card:hover::after {\n      height: 100%;\n    }\n\n    .solstar-benefit-card:hover .solstar-benefit-card-default {\n      opacity: 0;\n      transform: translateY(-8px);\n    }\n\n    .solstar-benefit-card:hover .solstar-benefit-card-hover {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  /* Mobile：切り替え完全無効（常にdefaultのみ） */\n  @media (max-width: 600px), (hover: none), (pointer: coarse) {\n    .solstar-benefit-card {\n      height: auto;\n      min-height: 220px;\n      padding: 26px 20px;\n    }\n\n    .solstar-benefit-card-hover {\n      display: none !important;\n      opacity: 0 !important;\n      transform: none !important;\n      transition: none !important;\n      pointer-events: none !important;\n    }\n\n    .solstar-benefit-card::after {\n      display: none !important;\n      height: 0% !important;\n      transition: none !important;\n    }\n\n    .solstar-benefit-card-default {\n      opacity: 1 !important;\n      transform: none !important;\n      transition: none !important;\n    }\n  }\n\n  /* ---------------------------\n     2. Solstar – Why Affordable\n     --------------------------- */\n  .solstar-why {\n    background: var(--bg);\n    padding: 50px 16px; /* PCは50px */\n    color: var(--text);\n    overflow: hidden;\n  }\n\n  @media (max-width: 600px) {\n    .solstar-why {\n      padding: 25px 16px; /* Mobileは25px */\n    }\n  }\n\n  .solstar-why-inner {\n    max-width: 1260px;\n    margin: 0 auto;\n  }\n\n  .solstar-why-head {\n    max-width: 860px;\n    margin: 0 auto 40px;\n    text-align: center;\n  }\n\n  .solstar-why-title {\n    font-size: var(--font-heading-large);\n    font-weight: 400;\n    line-height: 1.25;\n    margin: 0 0 14px;\n  }\n\n  .solstar-why-lead {\n    margin: 0;\n    font-size: 16px;\n    line-height: 1.9;\n    font-weight: 400;\n    color: var(--text);\n  }\n\n  .solstar-why-grid {\n    display: grid;\n    gap: 28px;\n  }\n\n  @media (min-width: 900px) {\n    .solstar-why-grid {\n      grid-template-columns: repeat(3, 1fr);\n    }\n  }\n\n  .solstar-why-card {\n    background: var(--bg-accent);\n    border: 1px solid var(--border);\n    border-radius: 20px;\n    overflow: hidden;\n  }\n\n  .solstar-why-card-media img {\n    width: 100%;\n    height: auto;\n    display: block;\n  }\n\n  .solstar-why-card-body {\n    padding: 24px 22px 28px;\n  }\n\n  .solstar-why-card-label {\n    font-size: 12px;\n    font-weight: 800;\n    color: var(--BTN-PRIMARY-BG);\n    margin: 0 0 10px;\n  }\n\n  .solstar-why-card-heading {\n    font-size: 18px;\n    font-weight: 400;\n    line-height: 1.45;\n    margin: 0 0 12px;\n    color: var(--text);\n  }\n\n  .solstar-why-card-text {\n    margin: 0;\n    font-size: 14px;\n    line-height: 1.9;\n    font-weight: 400;\n    color: var(--text);\n  }\n\n  @media (max-width: 600px) {\n    .solstar-why-card-label {\n      font-size: 12px;\n      font-weight: 800;\n    }\n  }\n\n  /* ---------------------------\n     3. Solstar – Roles / Partnership\n     --------------------------- */\n  .solstar-role-wrap {\n    --text: var(--COLOR-TEXT);\n    --bg: var(--COLOR-BG);\n    --gray: var(--border);\n\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, \"Noto Sans JP\", \"Hiragino Kaku Gothic ProN\", \"Yu Gothic\", sans-serif;\n    color: var(--text);\n    background: var(--bg);\n    padding: 50px 16px; /* PCは50px */\n    overflow: hidden;\n  }\n\n  @media (max-width: 600px) {\n    .solstar-role-wrap {\n      padding: 25px 16px; /* Mobileは25px */\n    }\n  }\n\n  .solstar-role-inner {\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  .solstar-role-head {\n    text-align: center;\n  }\n\n  .solstar-role-title {\n    margin: 0 0 50px;\n    font-size: var(--font-heading-large);\n    font-weight: 800;\n    line-height: 1.2;\n  }\n\n  .solstar-role-grid {\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 14px;\n  }\n\n  @media (min-width: 860px) {\n    .solstar-role-grid {\n      grid-template-columns: 1fr 120px 1fr;\n      gap: 18px;\n    }\n  }\n\n  .solstar-card {\n    border: none;\n    border-radius: 18px;\n    padding: 18px;\n  }\n\n  .solstar-card-title,\n  .solstar-card-desc {\n    text-align: center;\n  }\n\n  .solstar-card-title {\n    font-size: 18px;\n    font-weight: 800;\n    margin: 0 0 6px;\n    line-height: 1.4;\n  }\n\n  .solstar-card-desc {\n    font-size: 13px;\n    margin: 0 0 14px;\n  }\n\n  .solstar-list {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n    display: grid;\n    gap: 10px;\n  }\n\n  .solstar-li {\n    background: var(--gray);\n    border-radius: 14px;\n    overflow: hidden;\n  }\n\n  .solstar-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 12px;\n  }\n\n  .solstar-item-text {\n    font-weight: 700;\n    font-size: 18px;\n    line-height: 1.2;\n    margin: 0;\n  }\n\n  @media (max-width: 768px) {\n    .solstar-item-text {\n      font-size: 16px;\n    }\n  }\n\n  .solstar-plus {\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n    border: 1px solid var(--text);\n    background: var(--gray);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    flex-shrink: 0;\n    padding: 0;\n    transition: transform .25s ease;\n  }\n\n  .solstar-plus .plusmark {\n    position: relative;\n    width: 14px;\n    height: 14px;\n  }\n\n  .solstar-plus .plusmark::before,\n  .solstar-plus .plusmark::after {\n    content: \"\";\n    position: absolute;\n    left: 50%;\n    top: 50%;\n    background: var(--text);\n    border-radius: 2px;\n    transform: translate(-50%, -50%);\n  }\n\n  .solstar-plus .plusmark::before {\n    width: 14px;\n    height: 2px;\n  }\n\n  .solstar-plus .plusmark::after {\n    width: 2px;\n    height: 14px;\n  }\n\n  .solstar-li.is-open .solstar-plus {\n    transform: rotate(135deg);\n  }\n\n  .solstar-detail {\n    max-height: 0;\n    opacity: 0;\n    overflow: hidden;\n    padding: 0 12px 0 58px;\n    font-size: 14px;\n    line-height: 1.75;\n    transition: max-height .35s ease, opacity .25s ease, padding-bottom .35s ease;\n  }\n\n  .solstar-li.is-open .solstar-detail {\n    max-height: 240px;\n    opacity: 1;\n    padding-bottom: 12px;\n  }\n\n  .solstar-note {\n    display: block;\n    margin-top: 8px;\n    font-size: 12px;\n    line-height: 1.6;\n    opacity: .9;\n  }\n\n  @media (max-width: 768px) {\n    .solstar-note {\n      font-size: 11px;\n    }\n  }\n\n  .solstar-connector {\n    display: none;\n  }\n\n  @media (min-width: 860px) {\n    .solstar-connector {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .solstar-connector-x {\n      font-size: 56px;\n      font-weight: 900;\n      color: var(--text);\n      line-height: 1;\n    }\n  }\n\n  .solstar-partnership {\n    text-align: center;\n    font-weight: 800;\n    font-size: 20px;\n    margin: 80px 0 40px;\n    line-height: 1.6;\n  }\n\n  @media (max-width: 768px) {\n    .solstar-partnership {\n      font-size: 18px;\n      margin-top: 32px;\n    }\n  }\n\n  .solstar-partnership-image {\n    text-align: center;\n  }\n\n  .solstar-partnership-image img {\n    width: 100%;\n    max-width: 820px;\n    margin: 0 auto;\n    display: block;\n    border-radius: 14px;\n  }\n</style>\n\n<div class=\"solstar-benefits-section\">\n  <div class=\"solstar-benefits-inner\">\n    <div class=\"solstar-benefits-header\">\n      <p class=\"solstar-section-eyebrow js-fade-in\">Features</p>\n      <h2 class=\"solstar-benefits-header-title js-fade-in\">\n        Solstar Expressが<br class=\"solstar-sp-br\">選ばれる3つの理由\n      </h2>\n    </div>\n\n    <div class=\"solstar-benefits-grid\">\n      <div class=\"solstar-benefit-card js-fade-in\" role=\"group\">\n        <div class=\"solstar-benefit-card-default\">\n          <h3 class=\"solstar-benefit-heading-main\">低リスク</h3>\n          <div class=\"solstar-benefit-heading-sub\">初期費用を抑えて始められる</div>\n        </div>\n\n        <div class=\"solstar-benefit-card-hover\" aria-hidden=\"true\">\n          <div class=\"solstar-benefit-card-hover-inner\">\n            <p>初期費用55,000円（税込）／月額36,500円（税込）から。</p>\n            <p>大きな初期投資は不要。</p>\n            <p>まずは「売れるか」を試せる。</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"solstar-benefit-card js-fade-in\" role=\"group\">\n        <div class=\"solstar-benefit-card-default\">\n          <h3 class=\"solstar-benefit-heading-main\">お任せ</h3>\n          <div class=\"solstar-benefit-heading-sub\">構築・更新・運用まで対応</div>\n        </div>\n\n        <div class=\"solstar-benefit-card-hover\" aria-hidden=\"true\">\n          <div class=\"solstar-benefit-card-hover-inner\">\n            <p>設計・構築・更新までお任せ。</p>\n            <p>専任EC担当者不要。</p>\n            <p>本業に集中しながらECに挑戦できる。</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"solstar-benefit-card js-fade-in\" role=\"group\">\n        <div class=\"solstar-benefit-card-default\">\n          <h3 class=\"solstar-benefit-heading-main\">伴走</h3>\n          <div class=\"solstar-benefit-heading-sub\">制作だけでなく販売施策まで相談できる</div>\n        </div>\n\n        <div class=\"solstar-benefit-card-hover\" aria-hidden=\"true\">\n          <div class=\"solstar-benefit-card-hover-inner\">\n            <p>Shopifyアカデミー認定スタッフによる</p>\n            <p>データに基づいた</p>\n            <p>売上改善施策をサポート。</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<section class=\"solstar-why\">\n  <div class=\"solstar-why-inner\">\n\n    <div class=\"solstar-why-head js-fade-in\">\n      <p class=\"solstar-section-eyebrow\">Why Affordable</p>\n      <h2 class=\"solstar-why-title\">\n        なぜこの価格で提供できるのか\n      </h2>\n      <p class=\"solstar-why-lead\">\n        Solstar Expressが低価格なのは、<br class=\"solstar-sp-br\">品質を削っているからではありません。\n      </p>\n    </div>\n\n    <div class=\"solstar-why-grid\">\n      <article class=\"solstar-why-card js-fade-in\">\n        <div class=\"solstar-why-card-media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Untitled-1_62dc15f7-7c39-48c2-8899-6bfce9e28079.webp?v=1765155857\" alt=\"設計・構築・検証を自社で一元管理する体制\" loading=\"lazy\">\n        </div>\n        <div class=\"solstar-why-card-body\">\n          <p class=\"solstar-why-card-label\">POINT 01</p>\n          <h3 class=\"solstar-why-card-heading\">体制を分けず、すべて自社で一元管理</h3>\n          <p class=\"solstar-why-card-text\">\n            一般的なECサイト構築では、フロントエンド・バックエンド・進行管理が分業され、その分だけ調整工数とコストが膨らみます。Solstar Expressでは、設計・構築・検証までを自社で一元管理。確立された組織と人材で、無駄なコミュニケーションを発生させません。\n          </p>\n        </div>\n      </article>\n\n      <article class=\"solstar-why-card js-fade-in\">\n        <div class=\"solstar-why-card-media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/SOLSTAR_EXPRESS_Hero_image_5_copy_2_45076a4d-9efd-4f94-9fd9-8f1f5e50217c.webp?v=1765196138\" alt=\"Shopifyの仕組みを活用したECサイト構築\" loading=\"lazy\">\n        </div>\n        <div class=\"solstar-why-card-body\">\n          <p class=\"solstar-why-card-label\">POINT 02</p>\n          <h3 class=\"solstar-why-card-heading\">Shopifyの仕組みで、品質と安全性を担保</h3>\n          <p class=\"solstar-why-card-text\">\n            Solstar Expressでは、世界中で実績のあるShopifyを活用しています。表示速度・スマホ対応・UXに加え、サーバー管理やセキュリティなども、Shopifyの仕組みを利用。そのため、一から設計・開発する必要がなく、高品質なECサイトを低コストで提供できます。\n          </p>\n        </div>\n      </article>\n\n      <article class=\"solstar-why-card js-fade-in\">\n        <div class=\"solstar-why-card-media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Shopify_Academy_Latest_Version_copy.png?v=1767237404\" alt=\"Shopifyアカデミー認定資格\" loading=\"lazy\">\n        </div>\n        <div class=\"solstar-why-card-body\">\n          <p class=\"solstar-why-card-label\">POINT 03</p>\n          <h3 class=\"solstar-why-card-heading\">Shopifyアカデミー認定人材が設計</h3>\n          <p class=\"solstar-why-card-text\">\n            設計・ディレクションは、Shopifyアカデミー認定資格を取得した専門人材が担当します。Shopifyに標準で備わっている機能や仕組みを前提に設計することで、過度な作り込みや不要なカスタマイズを避け、効率的な構築を実現しています。\n          </p>\n        </div>\n      </article>\n\n    </div>\n  </div>\n</section>\n\n<section class=\"solstar-role-wrap\" id=\"solstarRoleSection\">\n  <div class=\"solstar-role-inner\">\n\n    <div class=\"solstar-role-head js-fade-in\">\n      <p class=\"solstar-section-eyebrow\">Partnership</p>\n      <h2 class=\"solstar-role-title\">Solstar × お客様でつくる<br>売れるEC運用体制</h2>\n    </div>\n\n    <div class=\"solstar-role-grid\">\n\n      <div class=\"solstar-card js-fade-in\">\n        <h3 class=\"solstar-card-title\">Solstarが担うこと</h3>\n        <p class=\"solstar-card-desc\">ECサイトの設計・構築・運用</p>\n\n        <ul class=\"solstar-list\">\n          <li class=\"solstar-li\" data-detail=\"お客様の事業と商品を理解し、売れる導線を設計。ブランドの価値や世界観が伝わるUIを整え、各ページを形にします。\">\n            <div class=\"solstar-row\">\n              <button class=\"solstar-plus\" type=\"button\" aria-label=\"詳細を開く\"><span class=\"plusmark\"></span></button>\n              <h4 class=\"solstar-item-text\">ECサイト構築</h4>\n            </div>\n            <div class=\"solstar-detail\"></div>\n          </li>\n\n          <li class=\"solstar-li\" data-detail=\"更新・運用\n商品登録、バナー差し替え、ページ更新など、日々の運用作業をサポートします。<span class='solstar-note'>※対応内容により、一部有料となる場合がございます。</span>\">\n            <div class=\"solstar-row\">\n              <button class=\"solstar-plus\" type=\"button\" aria-label=\"詳細を開く\"><span class=\"plusmark\"></span></button>\n              <h4 class=\"solstar-item-text\">更新・運用</h4>\n            </div>\n            <div class=\"solstar-detail\"></div>\n          </li>\n\n          <li class=\"solstar-li\" data-detail=\"売上データ分析・改善提案\n売上やアクセス状況を確認しながら、次に取り組むべき改善施策を一緒に考えます。\">\n            <div class=\"solstar-row\">\n              <button class=\"solstar-plus\" type=\"button\" aria-label=\"詳細を開く\"><span class=\"plusmark\"></span></button>\n              <h4 class=\"solstar-item-text\">売上データ分析・改善提案</h4>\n            </div>\n            <div class=\"solstar-detail\"></div>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"solstar-connector js-fade-in\">\n        <div class=\"solstar-connector-x\">X</div>\n      </div>\n\n      <div class=\"solstar-card js-fade-in\">\n        <h3 class=\"solstar-card-title\">お客様に担っていただくこと</h3>\n        <p class=\"solstar-card-desc\">商品の在庫管理・出荷・CS対応</p>\n\n        <ul class=\"solstar-list\">\n          <li class=\"solstar-li\" data-detail=\"商品の在庫状況をご確認いただき、販売できる状態を管理していただきます。\">\n            <div class=\"solstar-row\">\n              <button class=\"solstar-plus\" type=\"button\" aria-label=\"詳細を開く\"><span class=\"plusmark\"></span></button>\n              <h4 class=\"solstar-item-text\">在庫管理</h4>\n            </div>\n            <div class=\"solstar-detail\"></div>\n          </li>\n\n          <li class=\"solstar-li\" data-detail=\"注文情報は弊社から共有いたします。その情報をもとに、出荷・配送をご対応いただきます。\">\n            <div class=\"solstar-row\">\n              <button class=\"solstar-plus\" type=\"button\" aria-label=\"詳細を開く\"><span class=\"plusmark\"></span></button>\n              <h4 class=\"solstar-item-text\">出荷・発送</h4>\n            </div>\n            <div class=\"solstar-detail\"></div>\n          </li>\n\n          <li class=\"solstar-li\" data-detail=\"購入商品に関するお問い合わせや返品対応などをご担当いただきます。\">\n            <div class=\"solstar-row\">\n              <button class=\"solstar-plus\" type=\"button\" aria-label=\"詳細を開く\"><span class=\"plusmark\"></span></button>\n              <h4 class=\"solstar-item-text\">カスタマーサポート</h4>\n            </div>\n            <div class=\"solstar-detail\"></div>\n          </li>\n        </ul>\n      </div>\n\n    </div>\n\n    <div class=\"solstar-partnership js-fade-in\">\n      ECサイトを一緒に育てる<br class=\"solstar-sp-br\">パートナーシップ。\n    </div>\n\n    <div class=\"solstar-partnership-image js-fade-in\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Solstar_x_Customer_Result_Image_Fixed_copy.webp?v=1771409441\" alt=\"Solstarとお客様のパートナーシップ\" loading=\"lazy\">\n    </div>\n\n  </div>\n</section>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    // ---------------------------\n    // 1. フェードイン・アニメーション (Intersection Observer)\n    // ---------------------------\n    const fadeElements = document.querySelectorAll('.js-fade-in');\n    const observerOptions = {\n      root: null,\n      rootMargin: '0px',\n      threshold: 0.15 // 要素が15%表示されたら発火\n    };\n\n    const observer = new IntersectionObserver(function(entries, observer) {\n      entries.forEach(function(entry) {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, observerOptions);\n\n    fadeElements.forEach(function(el) {\n      observer.observe(el);\n    });\n\n    // ---------------------------\n    // 2. アコーディオンメニュー (元のコード)\n    // ---------------------------\n    const root = document.getElementById('solstarRoleSection');\n    if (root) {\n      root.addEventListener('click', e => {\n        const btn = e.target.closest('.solstar-plus');\n        if (!btn) return;\n\n        const item = btn.closest('.solstar-li');\n        if (!item) return;\n\n        const detail = item.querySelector('.solstar-detail');\n        if (detail && !detail.innerHTML.trim()) {\n          detail.innerHTML = item.getAttribute('data-detail') || '';\n        }\n\n        root.querySelectorAll('.solstar-li.is-open').forEach(el => {\n          if (el !== item) el.classList.remove('is-open');\n        });\n\n        item.classList.toggle('is-open');\n      });\n    }\n  });\n</script>",
