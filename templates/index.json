    "section_custom_code_YPEkCV": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<!-- 実績ハイライト - SOLSTAR -->\n<div class=\"solstar-stats\">\n  <div class=\"solstar-stats__grid\">\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"100\"\n           data-decimals=\"0\"\n           data-suffix=\"億円＋\">\n        0\n      </div>\n      <div class=\"solstar-stats__label\">ECサイト支援総売上</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"13\"\n           data-decimals=\"0\"\n           data-suffix=\"％\">\n        0\n      </div>\n      <div class=\"solstar-stats__label\">サイトパフォーマンス高速化</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"4.37\"\n           data-decimals=\"2\"\n           data-suffix=\"％\">\n        0\n      </div>\n      <div class=\"solstar-stats__label\">新規獲得CVR</div>\n    </div>\n  </div>\n</div>\n\n<style>\n  .solstar-stats {\n    max-width: 1080px;\n    margin: 0 auto;\n    padding: 48px 16px;\n    background-color: #0D0326; /* 背景色 */\n  }\n\n  .solstar-stats__grid {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 32px;\n  }\n\n  .solstar-stats__item {\n    text-align: center;\n    padding: 24px 16px;\n    /* 背景・角丸・ボーダー・影などの装飾は削除済み */\n    opacity: 0;\n    transform: translateY(24px);\n    transition:\n      opacity 0.6s ease-out,\n      transform 0.6s ease-out;\n  }\n\n  .solstar-stats__item.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .solstar-stats__value {\n    font-weight: 700;\n    letter-spacing: 0;        /* ★ 0% に変更 */\n    font-size: 55px;          /* デスクトップ */\n    line-height: 1.1;\n    margin-bottom: 8px;\n    font-feature-settings: \"pnum\" on, \"lnum\" on;\n    color: #ffffff;           /* 白のまま */\n  }\n\n  .solstar-stats__label {\n    font-size: 20px;          /* デスクトップ */\n    font-weight: 700;         /* 太字 */\n    line-height: 1.6;\n    letter-spacing: 0;        /* ★ 0% に変更 */\n    color: #9CA3AF;           /* グレー */\n  }\n\n  /* モバイル対応 */\n  @media (max-width: 767px) {\n    .solstar-stats {\n      padding: 32px 16px;\n    }\n\n    .solstar-stats__grid {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .solstar-stats__item {\n      padding: 20px 16px;\n    }\n\n    .solstar-stats__value {\n      font-size: 40px;        /* モバイル */\n    }\n\n    .solstar-stats__label {\n      font-size: 17px;        /* モバイル */\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    var section = document.querySelector('.solstar-stats');\n    if (!section) return;\n\n    var items = section.querySelectorAll('.solstar-stats__item');\n    var values = section.querySelectorAll('.solstar-stats__value');\n    var animated = false;\n\n    function animateNumbers() {\n      if (animated) return;\n      animated = true;\n\n      values.forEach(function (el) {\n        var target = parseFloat(el.getAttribute('data-value') || '0');\n        var decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);\n        var suffix = el.getAttribute('data-suffix') || '';\n        var duration = 1500;\n        var start = null;\n\n        function step(timestamp) {\n          if (!start) start = timestamp;\n          var progress = Math.min((timestamp - start) / duration, 1);\n          var current = target * progress;\n          el.textContent = current.toFixed(decimals) + suffix;\n          if (progress < 1) {\n            window.requestAnimationFrame(step);\n          }\n        }\n\n        window.requestAnimationFrame(step);\n      });\n    }\n\n    function revealItems() {\n      items.forEach(function (item, index) {\n        item.style.transitionDelay = (index * 0.12) + 's';\n        item.classList.add('is-visible');\n      });\n    }\n\n    if ('IntersectionObserver' in window) {\n      var observer = new IntersectionObserver(function (entries) {\n        entries.forEach(function (entry) {\n          if (entry.isIntersecting) {\n            revealItems();\n            animateNumbers();\n            observer.disconnect();\n          }\n        });\n      }, {\n        root: null,\n        threshold: 0.35\n      });\n\n      observer.observe(section);\n    } else {\n      // 古いブラウザ用フォールバック\n      revealItems();\n      animateNumbers();\n    }\n  })();\n</script>",
        "width": "wrapper--full",
        "color_scheme": "scheme-10",
        "padding_top": 0,
        "padding_bottom": 50
      }
    },
    "section_custom_code_AaQ3Ee": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n/* ===============================\n   MODERN AI STYLE - ENHANCED IMAGE\n================================ */\n\n.solstar-testimonial {\n  padding: 60px 20px;\n  font-family: \"Inter\", \"Plus Jakarta Sans\", sans-serif;\n  color: #ffffff;\n  background-color: #0D0326;\n}\n\n.solstar-testimonial-inner {\n  max-width: 1100px;\n  margin: 0 auto;\n}\n\n/* 見出し：グラデーション削除、純白に変更 */\n.solstar-testimonial-heading {\n  font-size: 36px;\n  font-weight: 800;\n  margin-bottom: 8px; /* 隙間を縮小 */\n  text-align: center;\n  color: #ffffff; \n  letter-spacing: -0.01em;\n}\n\n.solstar-testimonial-heading-sub {\n  font-size: 16px;\n  color: #94a3b8;\n  text-align: center;\n  margin-bottom: 32px; /* カードとの隙間を大幅に縮小 */\n}\n\n/* コンテナ */\n.solstar-testimonial-container {\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 30px;\n}\n\n.solstar-testimonial-card {\n  flex: 1;\n  max-width: 800px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 32px;\n  padding: 50px 40px;\n  backdrop-filter: blur(12px);\n  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n/* 画像：さらに大きく */\n.solstar-testimonial-media {\n  width: 240px; /* 大幅にサイズアップ */\n  height: 240px;\n  margin-bottom: 32px;\n}\n\n.solstar-testimonial-img-clip {\n  width: 100%;\n  height: 100%;\n  border-radius: 50%;\n  overflow: hidden;\n  border: 4px solid #6366f1;\n  box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);\n}\n\n.solstar-testimonial-img-clip img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n/* 矢印ボタン */\n.solstar-img-arrow {\n  width: 56px;\n  height: 56px;\n  border-radius: 50%;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  background: rgba(255, 255, 255, 0.05);\n  color: #ffffff;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  flex-shrink: 0;\n}\n\n.solstar-img-arrow:hover {\n  background: #6366f1;\n  border-color: #818cf8;\n  box-shadow: 0 0 20px rgba(99, 102, 241, 0.5);\n}\n\n/* モバイル対応 */\n@media (max-width: 768px) {\n  .solstar-testimonial-container {\n    flex-direction: column;\n  }\n  \n  .solstar-testimonial-card {\n    padding: 32px 20px;\n  }\n\n  .solstar-testimonial-media {\n    width: 180px; /* モバイルでもしっかり大きく */\n    height: 180px;\n  }\n\n  .solstar-mobile-nav {\n    display: flex;\n    gap: 20px;\n    margin-top: 32px;\n    order: 10;\n  }\n\n  .solstar-img-arrow.pc-only {\n    display: none;\n  }\n\n  .solstar-testimonial-heading { font-size: 28px; }\n}\n\n@media (min-width: 769px) {\n  .solstar-mobile-nav { display: none; }\n}\n\n/* テキストエリア */\n.solstar-testimonial-text {\n  text-align: center;\n  width: 100%;\n}\n\n.solstar-testimonial-title {\n  font-size: 24px;\n  font-weight: 700;\n  margin-bottom: 8px;\n}\n\n.solstar-testimonial-sub {\n  font-size: 15px;\n  color: #6366f1;\n  font-weight: 600;\n  margin-bottom: 32px;\n}\n\n.solstar-testimonial-quote {\n  font-size: 20px;\n  font-weight: 700;\n  line-height: 1.6;\n  color: #f1f5f9;\n  margin-bottom: 24px;\n}\n\n.solstar-testimonial-body {\n  font-size: 16px;\n  line-height: 1.8;\n  color: #94a3b8;\n}\n\n/* アニメーション */\n.solstar-anim {\n  animation: solstarFadeIn 0.5s ease-out forwards;\n}\n@keyframes solstarFadeIn {\n  from { opacity: 0; transform: scale(0.98); }\n  to { opacity: 1; transform: scale(1); }\n}\n</style>\n\n<div class=\"solstar-testimonial\">\n  <div class=\"solstar-testimonial-inner\">\n    <h2 class=\"solstar-testimonial-heading\">ECサイト構築実績</h2>\n    <div class=\"solstar-testimonial-heading-sub\">\n      立ち上げ初期でも成果に繋がった事例を一部ご紹介致します。\n    </div>\n\n    <div class=\"solstar-testimonial-container\">\n      <button type=\"button\" class=\"solstar-img-arrow pc-only\" data-prev aria-label=\"前へ\">\n        <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M15 18l-6-6 6-6\"/></svg>\n      </button>\n\n      <div class=\"solstar-testimonial-card\">\n        <div class=\"solstar-testimonial-media\">\n          <div class=\"solstar-testimonial-img-clip\">\n            <img id=\"solstar-person-img\" src=\"\" alt=\"\">\n          </div>\n        </div>\n\n        <div class=\"solstar-testimonial-text\" id=\"solstar-content\">\n          <div class=\"solstar-testimonial-title\" id=\"solstar-author\"></div>\n          <div class=\"solstar-testimonial-sub\" id=\"solstar-sub\"></div>\n          <div class=\"solstar-testimonial-quote\" id=\"solstar-quote\"></div>\n          <div class=\"solstar-testimonial-body\" id=\"solstar-body\"></div>\n        </div>\n\n        <div class=\"solstar-mobile-nav\">\n          <button type=\"button\" class=\"solstar-img-arrow\" data-prev-mob aria-label=\"前へ\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M15 18l-6-6 6-6\"/></svg>\n          </button>\n          <button type=\"button\" class=\"solstar-img-arrow\" data-next-mob aria-label=\"次へ\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18l6-6-6-6\"/></svg>\n          </button>\n        </div>\n      </div>\n\n      <button type=\"button\" class=\"solstar-img-arrow pc-only\" data-next aria-label=\"次へ\">\n        <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18l6-6-6-6\"/></svg>\n      </button>\n    </div>\n  </div>\n</div>\n\n<script>\n(function () {\n  const data = [\n    {\n      img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_5.webp?v=1766473796\",\n      title: \"合同会社Rsworks様\",\n      sub: \"鍛冶の匠 ─ 日本の技を受け継ぐ包丁ブランド\",\n      body: \"ブランドの世界観と高級感を保ったECサイトを構築。キャンペーンではLINE登録単価30円、登録者2,306人を達成。\",\n      quote: \"洗練されたクリエイティブセンスで一目置くECサイトを構築していただき、とても満足しています。\"\n    },\n    {\n      img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_3.webp?v=1766473796\",\n      title: \"PAW MINT様\",\n      sub: \"愛犬との「時間」を大切にするペットブランド\",\n      body: \"ブランドの世界観をポップに表現したLPを制作。広告施策により2,000名以上のメルマガ登録獲得。\",\n      quote: \"可愛くポップなECサイトを作って頂きました。\"\n    },\n    {\n      img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_2.webp?v=1766473796\",\n      title: \"株式会社EDGBLACK様\",\n      sub: \"高品質な砥石ブランドのEC基盤を既存プラットフォームから移行\",\n      body: \"誰でも簡単にプロ級の刃物研ぎができる、高品質な砥石とアクセサリを展開。Shopify移行後、公開初月に27万円以上の売上を実現。\",\n      quote: \"とても丁寧かつ詳細に説明してくださったので、困ることは一切ありませんでした。\"\n    },\n    {\n      img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_1.webp?v=1766473795\",\n      title: \"株式会社ONETREE様\",\n      sub: \"1秒で履けるスニーカー「LAQUN」の公式ECサイト構築\",\n      body: \"公式ECサイトを約2か月で立ち上げ、公開初月に12万円以上の売上を達成されました。Shopifyを活用し、ブランドの認知拡大とファンづくりを進められています。\",\n      quote: \"調整にも柔軟に対応してもらえ、安心して任せられました。\"\n    },\n    {\n      img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_4.webp?v=1766473796\",\n      title: \"SANDY HAZE様\",\n      sub: \"自由と美しさをまとう女性のための水着ブランド\",\n      body: \"英語圏向け越境EC（アメリカ・カナダ・オーストラリア）を構築。商品撮影から広告運用まで対応し、3ヶ月で月商100万円を達成。\",\n      quote: \"They made our first e-commerce site look amazing.\"\n    }\n  ];\n\n  let index = 0;\n  const img = document.getElementById(\"solstar-person-img\");\n  const author = document.getElementById(\"solstar-author\");\n  const sub = document.getElementById(\"solstar-sub\");\n  const quote = document.getElementById(\"solstar-quote\");\n  const body = document.getElementById(\"solstar-body\");\n  const content = document.getElementById(\"solstar-content\");\n\n  function render(i) {\n    const d = data[i];\n    [img, content].forEach(el => {\n      el.classList.remove('solstar-anim');\n      void el.offsetWidth;\n      el.classList.add('solstar-anim');\n    });\n    img.src = d.img;\n    img.alt = d.title || \"\";\n    author.textContent = d.title || \"\";\n    sub.textContent = d.sub || \"\";\n    quote.textContent = d.quote ? `「${d.quote}」` : \"\";\n    body.textContent = d.body || \"\";\n  }\n\n  document.querySelectorAll(\"[data-next], [data-next-mob]\").forEach(btn => {\n    btn.addEventListener(\"click\", () => {\n      index = (index + 1) % data.length;\n      render(index);\n    });\n  });\n\n  document.querySelectorAll(\"[data-prev], [data-prev-mob]\").forEach(btn => {\n    btn.addEventListener(\"click\", () => {\n      index = (index - 1 + data.length) % data.length;\n      render(index);\n    });\n  });\n\n  render(index);\n})();\n</script>",
