      "settings": {
        "code": "<div class=\"solstar-container\">\n  <h2 class=\"solstar-main-title\">料金プランの詳細</h2>\n\n  <div class=\"solstar-scroll-wrapper\">\n    <table class=\"solstar-comparison-table\">\n      <thead>\n        <tr>\n          <th class=\"sticky-col\">サービス内容 / プラン</th>\n          <th class=\"plan-header basic\">Basic</th>\n          <th class=\"plan-header plus\">Plus<br><span class=\"recommend-badge\">RECOMMEND</span></th>\n          <th class=\"plan-header pro\">Pro</th>\n        </tr>\n      </thead>\n      <tbody>\n        <!-- 1. 料金セクション -->\n        <tr>\n          <td class=\"feature-title sticky-col\">月払い（税込）</td>\n          <td class=\"price-cell\">36,500円</td>\n          <td class=\"price-cell plus-focus\">69,500円</td>\n          <td class=\"price-cell\">115,000円</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">年払い（税込）<br><small>※月額より10％割引</small></td>\n          <td class=\"price-cell\">32,850円</td>\n          <td class=\"price-cell plus-focus\">62,550円</td>\n          <td class=\"price-cell\">103,500円</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">初期費用（税込）</td>\n          <td class=\"price-cell\">55,000円</td>\n          <td class=\"price-cell plus-focus\">55,000円</td>\n          <td class=\"price-cell\">55,000円</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">最低契約期間</td>\n          <td>1年間<br><small>（以降1ヶ月毎更新）</small></td>\n          <td class=\"plus-focus\">1年間<br><small>（以降1ヶ月毎更新）</small></td>\n          <td>1年間<br><small>（以降1ヶ月毎更新）</small></td>\n        </tr>\n\n        <!-- 2. 運用基本ルール -->\n        <tr>\n          <td class=\"feature-title sticky-col\">月間稼働時間（目安）</td>\n          <td>3時間</td>\n          <td class=\"plus-focus\">6時間</td>\n          <td>10時間</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">繰り越し</td>\n          <td>無</td>\n          <td class=\"plus-focus\">無</td>\n          <td>無</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">販売手数料</td>\n          <td>20％<br><small>※クレジット手数料等含む</small></td>\n          <td class=\"plus-focus\">19％<br><small>※クレジット手数料等含む</small></td>\n          <td>18％<br><small>※クレジット手数料等含む</small></td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">売上金の振込</td>\n          <td>月末締め<br>翌月20日払い</td>\n          <td class=\"plus-focus\">月末締め<br>翌月20日払い</td>\n          <td>月末締め<br>翌月20日払い</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">体制</td>\n          <td>ディレクター1名<br>エンジニア1名</td>\n          <td class=\"plus-focus\">ディレクター1名<br>エンジニア1名</td>\n          <td>ディレクター1名<br>エンジニア1名</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">コミュニケーションツール</td>\n          <td>Email, Zoom, Meets</td>\n          <td class=\"plus-focus\">Slack, Meets, Email, Zoom</td>\n          <td>Slack, Meets, Email, Zoom, Phone</td>\n        </tr>\n\n        <!-- 3. 実務詳細 -->\n        <tr>\n          <td class=\"feature-title sticky-col\">ストア決済方法</td>\n          <td>Shopify Payments</td>\n          <td class=\"plus-focus\">Shopify Payments / PayPal</td>\n          <td>Shopify Payments / PayPal / Paidy</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">商品登録・更新代行</td>\n          <td>月5点まで</td>\n          <td class=\"plus-focus\">月10点まで</td>\n          <td>無制限</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">デザイン調整・改修</td>\n          <td>\n            月5回まで<br>\n            <small>バナー差し替えや文言調整などの軽微な修正</small>\n          </td>\n          <td class=\"plus-focus\">\n            月10回まで<br>\n            <small>バナー差し替えや文言調整などの軽微な修正・HTML、CSS、JSコードによる軽微なカスタマイズ。</small>\n          </td>\n          <td>\n            月15回まで<br>\n            <small>バナー差し替えや文言調整などの軽微な修正・HTML、CSS、JSコードによる中規模なカスタマイズ。</small>\n          </td>\n        </tr>\n        \n        <!-- 4. SEO対策 -->\n        <tr>\n          <td class=\"feature-title sticky-col\">SEO対策</td>\n          <td>\n            <div class=\"seo-detail\">\n              <p><strong>コンテンツSEO：</strong>見出し構成の最適化</p>\n              <p><strong>内部SEO：</strong>URL構造の整理</p>\n              <p><strong>テクニカルSEO：</strong>モバイル対応</p>\n            </div>\n          </td>\n          <td class=\"plus-focus\">\n            <div class=\"seo-detail\">\n              <p><strong>コンテンツSEO：</strong>見出し構成の最適化</p>\n              <p><strong>内部SEO：</strong>URL構造の整理、title / meta description の最適化</p>\n              <p><strong>テクニカルSEO：</strong>インデックス制御（noindex / canonical）</p>\n            </div>\n          </td>\n          <td>\n            <div class=\"seo-detail\">\n              <p><strong>コンテンツSEO：</strong>見出し構成の最適化</p>\n              <p><strong>内部SEO：</strong>URL構造の整理、title / meta description の最適化、構造化データ（JSON-LD）</p>\n              <p><strong>テクニカルSEO：</strong>インデックス制御（noindex / canonical）</p>\n              <p><strong>E-E-A-T強化</strong></p>\n            </div>\n          </td>\n        </tr>\n\n        <tr>\n          <td class=\"feature-title sticky-col\">アプリ導入・設定支援</td>\n          <td>メールアプリのみ導入</td>\n          <td class=\"plus-focus\">メールアプリ、レビュー、<br>セット販売、サブスクアプリ</td>\n          <td>メールアプリ、レビュー、セット販売、サブスク、他2アプリ無料実装</td>\n        </tr>\n        <tr>\n          <td class=\"feature-title sticky-col\">定例MTG・改善提案</td>\n          <td>月1回</td>\n          <td class=\"plus-focus\">月1回</td>\n          <td>月1回</td>\n        </tr>\n\n        <!-- 6. 初期構築詳細 -->\n        <tr>\n          <td class=\"feature-title sticky-col\">初期構築・制作一式<br><small>（全プラン共通内容）</small></td>\n          <td colspan=\"3\" class=\"setup-detail-cell\">\n            <div class=\"setup-grid\">\n              <div class=\"setup-item\">\n                <strong>【ページ構成】</strong>\n                <ul>\n                  <li>ホームページ / 商品詳細 / コレクション / 検索 / カート</li>\n                  <li>★LP（ランディングページ）※構成企画・構築含む</li>\n                  <li>ブランド紹介 / お問い合わせ / 利用規約 / 特商法 / 各種ポリシー</li>\n                </ul>\n              </div>\n              <div class=\"setup-item\">\n                <strong>【Shopifyストア設定】</strong>\n                <ul>\n                  <li>ドメイン / 通知 / Cookie / 送料 / 消費税 / 決済設定</li>\n                  <li>販売チャネル連携（Google / Shop / Meta）</li>\n                </ul>\n              </div>\n              <div class=\"setup-item\">\n                <strong>【UI/UXデザイン】</strong>\n                <ul>\n                  <li>Shopifyテーマを活用したデザイン調整</li>\n                  <li>ブランドカラー / ロゴ / ファビコン / レスポンシブ対応</li>\n                </ul>\n              </div>\n            </div>\n          </td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <div class=\"solstar-footer-notes\">\n    <p>※価格はすべて税込表示です。</p>\n    <p>※最低契約期間終了後は、1ヶ月ごとの自動更新となります。</p>\n    <p>※各作業項目は、月間稼働時間の範囲内で対応いたします。</p>\n    <p>※【超過料金の目安】5,000円（税込） / 時間</p>\n    <p>※追加アプリの導入・設定代行：33,000円（税込）〜</p>\n    <p>※月額料金に含まれる外部システム・アプリ利用料は、導入時の標準プラン範囲内となります。売上拡大等に伴う従量課金の増加や、プランのアップグレードが必要な場合は、別途差額をご負担いただきます。</p>\n  </div>\n</div>\n\n<style>\n/* --- 全体レイアウト --- */\n.solstar-container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 20px;\n  font-family: sans-serif;\n  color: #000000;\n  background-color: #ffffff;\n}\n\n.solstar-main-title {\n  text-align: center;\n  font-size: 1.8em;\n  font-weight: bold;\n  margin: 0 0 1.2em 0;\n  color: #000000;\n}\n\n.solstar-scroll-wrapper {\n  overflow-x: auto;\n  border: none;\n}\n\n/* --- テーブル基本スタイル --- */\n.solstar-comparison-table {\n  width: 100%;\n  min-width: 950px;\n  border-collapse: collapse;\n  background: #ffffff;\n  table-layout: fixed;\n  border: 1px solid #e0e0e0;\n}\n\n.solstar-comparison-table th, \n.solstar-comparison-table td {\n  padding: 1.2em 0.8em;\n  border: 1px solid #e0e0e0;\n  text-align: center;\n  vertical-align: middle;\n  line-height: 1.4;\n  background-color: #ffffff;\n  color: #000000;\n}\n\n.sticky-col { width: 220px; }\n.plan-header { width: 240px; }\n\n/* --- ヘッダー・バッジ --- */\n.plan-header {\n  background-color: #ffffff !important;\n  font-size: 1.1em;\n  font-weight: bold;\n  border-top: 1px solid #e0e0e0 !important;\n  color: #000000;\n}\n\n.recommend-badge {\n  display: inline-block;\n  background: #005bac;\n  color: #ffffff;\n  font-size: 0.6em;\n  padding: 2px 10px;\n  border-radius: 12px;\n  margin-top: 8px;\n  letter-spacing: 0.05em;\n  font-weight: bold;\n}\n\n.plan-header.plus, \n.plus-focus { \n  background-color: #f0f7ff !important;\n}\n\n/* --- コンテンツ内スタイル --- */\n.feature-title {\n  background-color: #ffffff !important;\n  font-weight: bold;\n  text-align: left !important;\n  font-size: 0.9em;\n}\n\n.price-cell {\n  font-size: 1em;\n  font-weight: bold;\n}\n\n.seo-detail { text-align: left; }\n.seo-detail p {\n  margin: 0 0 6px 0;\n  font-size: 0.75em;\n  color: #000000;\n}\n\n.setup-detail-cell {\n  text-align: left !important;\n  padding: 1.5em !important;\n}\n\n.setup-grid {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n.setup-item strong {\n  display: block;\n  margin-bottom: 4px;\n  font-size: 0.85em;\n}\n.setup-item ul {\n  margin: 0;\n  padding-left: 1.2em;\n  font-size: 0.8em;\n  list-style-type: disc;\n}\n\n/* --- フッター注釈 --- */\n.solstar-footer-notes {\n  margin-top: 1.5em;\n  font-size: 0.82em;\n  color: #000000;\n  line-height: 1.6;\n  padding-left: 5px;\n}\n.solstar-footer-notes p { \n  margin: 0.4em 0; \n  text-indent: -1em;\n  padding-left: 1em;\n}\n\nsmall {\n  display: block;\n  font-weight: normal;\n  font-size: 0.85em;\n  color: #000000;\n  margin-top: 4px;\n}\n\n/* --- モバイル対応 --- */\n@media (max-width: 768px) {\n  .solstar-container {\n    padding: 0 15px;\n  }\n  .solstar-main-title { font-size: 1.5em; }\n  .solstar-comparison-table th, .solstar-comparison-table td {\n    padding: 1em 0.8em;\n    font-size: 0.85em;\n  }\n}\n</style>",
