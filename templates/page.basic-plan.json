    "stats": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<!-- 実績ハイライト - SOLSTAR -->\n<div class=\"solstar-stats\">\n  <div class=\"solstar-stats__grid\">\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"100\"\n           data-decimals=\"0\"\n           data-suffix=\"億円以上\">\n        100億円以上\n      </div>\n      <div class=\"solstar-stats__label\">支援先ECサイトの年間売上規模</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"13\"\n           data-decimals=\"0\"\n           data-suffix=\"％\">\n        13％\n      </div>\n      <div class=\"solstar-stats__label\">表示速度改善率</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"4.37\"\n           data-decimals=\"2\"\n           data-suffix=\"％\">\n        4.37％\n      </div>\n      <div class=\"solstar-stats__label\">新規顧客の購入CVR</div>\n    </div>\n  </div>\n</div>\n\n<style>\n  .solstar-stats {\n    max-width: 1080px;\n    margin: 0 auto;\n    padding: 48px 16px;\n    background-color: var(--COLOR-BG);\n  }\n\n  .solstar-stats__grid {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 32px;\n  }\n\n  .solstar-stats__item {\n    text-align: center;\n    padding: 24px 16px;\n    opacity: 1;\n    transform: translateY(0);\n    transition:\n      opacity 0.6s ease-out,\n      transform 0.6s ease-out;\n  }\n\n  .solstar-stats.is-animated .solstar-stats__item:not(.is-visible) {\n    opacity: 0;\n    transform: translateY(24px);\n  }\n\n  .solstar-stats__item.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .solstar-stats__value {\n    font-weight: 700;\n    letter-spacing: 0;\n    font-size: clamp(40px, 4.2vw, 55px);\n    line-height: 1.1;\n    margin-bottom: 8px;\n    font-feature-settings: \"pnum\" on, \"lnum\" on;\n    color: var(--COLOR-TEXT);\n    white-space: nowrap;\n    word-break: keep-all;\n  }\n\n  .solstar-stats__label {\n    font-size: 20px;\n    font-weight: 700;\n    line-height: 1.6;\n    letter-spacing: 0;\n    color: var(--sp-page-accent);\n  }\n\n  @media (max-width: 767px) {\n    .solstar-stats {\n      padding: 32px 16px;\n    }\n\n    .solstar-stats__grid {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .solstar-stats__item {\n      padding: 20px 16px;\n    }\n\n    .solstar-stats__value {\n      font-size: clamp(38px, 12vw, 44px);\n    }\n\n    .solstar-stats__label {\n      font-size: 17px;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    function initSolstarStats() {\n      var sections = document.querySelectorAll('.solstar-stats');\n\n      if (!sections.length) return;\n\n      sections.forEach(function (section) {\n        if (section.dataset.solstarStatsInitialized === 'true') return;\n        section.dataset.solstarStatsInitialized = 'true';\n\n        var items = section.querySelectorAll('.solstar-stats__item');\n        var values = section.querySelectorAll('.solstar-stats__value');\n        var animated = false;\n\n        section.classList.add('is-animated');\n\n        function animateNumbers() {\n          if (animated) return;\n          animated = true;\n\n          values.forEach(function (el) {\n            var target = parseFloat(el.getAttribute('data-value') || '0');\n            var decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);\n            var suffix = el.getAttribute('data-suffix') || '';\n            var duration = 1500;\n            var start = null;\n\n            el.textContent = (0).toFixed(decimals) + suffix;\n\n            function step(timestamp) {\n              if (!start) start = timestamp;\n\n              var progress = Math.min((timestamp - start) / duration, 1);\n              var easedProgress = 1 - Math.pow(1 - progress, 3);\n              var current = target * easedProgress;\n\n              el.textContent = current.toFixed(decimals) + suffix;\n\n              if (progress < 1) {\n                window.requestAnimationFrame(step);\n              } else {\n                el.textContent = target.toFixed(decimals) + suffix;\n              }\n            }\n\n            window.requestAnimationFrame(step);\n          });\n        }\n\n        function revealItems() {\n          items.forEach(function (item, index) {\n            item.style.transitionDelay = (index * 0.12) + 's';\n            item.classList.add('is-visible');\n          });\n        }\n\n        function runAnimation() {\n          revealItems();\n          animateNumbers();\n        }\n\n        function isInViewport(el) {\n          var rect = el.getBoundingClientRect();\n          var windowHeight = window.innerHeight || document.documentElement.clientHeight;\n\n          return rect.top < windowHeight * 0.85 && rect.bottom > 0;\n        }\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(function (entries) {\n            entries.forEach(function (entry) {\n              if (entry.isIntersecting) {\n                runAnimation();\n                observer.unobserve(section);\n              }\n            });\n          }, {\n            root: null,\n            threshold: 0.2\n          });\n\n          observer.observe(section);\n\n          setTimeout(function () {\n            if (!animated && isInViewport(section)) {\n              runAnimation();\n              observer.unobserve(section);\n            }\n          }, 300);\n        } else {\n          runAnimation();\n        }\n      });\n    }\n\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', initSolstarStats);\n    } else {\n      initSolstarStats();\n    }\n\n    window.addEventListener('load', initSolstarStats);\n\n    document.addEventListener('shopify:section:load', function () {\n      initSolstarStats();\n    });\n  })();\n</script>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "growth": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .bpl-growth-figure { max-width: 800px; margin: 32px auto 0; border-radius: var(--sp-page-card-radius); overflow: hidden; }\n  .bpl-growth-figure img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }\n  .bpl-steps-lead { max-width: 720px; margin: 24px auto 0; text-align: center; color: var(--COLOR-TEXT); font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); line-height: 1.6; }\n  .bpl-growth-cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; max-width: 980px; margin: 32px auto 0; }\n  .bpl-growth-cards .sp-card { text-align: center; }\n  .bpl-growth-no { margin: 0 0 10px; color: var(--sp-page-accent); font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); }\n  .bpl-growth-text { margin: 0; color: var(--COLOR-TEXT); font-size: var(--font-body-medium); line-height: 1.7; }\n  @media (max-width: 760px) {\n    .bpl-growth-cards { grid-template-columns: 1fr; }\n  }\n</style>\n<section class=\"sp-sec sp-sec--growth\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Growth</p>\n      <h2 class=\"sp-title\">自社ECは、<br>公開してから育てていくものです。</h2>\n    </div>\n    <figure class=\"bpl-growth-figure\"><img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Small_Business_Success.png?v=1782979345\" alt=\"Basicプラン公開後の育て方のイメージ\" loading=\"lazy\"></figure>\n    <p class=\"bpl-steps-lead\">Basicプランで土台を作ったあとは、次のように段階的に育てていけます。</p>\n    <div class=\"bpl-growth-cards\">\n      <div class=\"sp-card\"><p class=\"bpl-growth-no\">01</p><p class=\"bpl-growth-text\">まずは自分たちで運用しながら、売れる兆しを確かめる</p></div>\n      <div class=\"sp-card\"><p class=\"bpl-growth-no\">02</p><p class=\"bpl-growth-text\">反応が見えてきたら、商品・ページ・アプリを少しずつ広げる</p></div>\n      <div class=\"sp-card\"><p class=\"bpl-growth-no\">03</p><p class=\"bpl-growth-text\">手が回らなくなってきたら、運用・改善のサポートに切り替える</p></div>\n    </div>\n    <p class=\"sp-note\">公開後の運用・集客サポートが必要になった際も、フェーズに合わせてご提案します。</p>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "offer": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .bpl-price-card { max-width: 920px; margin: 0 auto; border: 1px solid var(--sp-page-accent); border-radius: var(--sp-page-card-radius); background: var(--COLOR-TEXT-A5); padding: 32px; }\n  .bpl-price-card__name { margin: 0 0 6px; font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); color: var(--COLOR-TEXT); }\n  .bpl-price-card__price { margin: 0 0 10px; font-family: var(--FONT-STACK-HEADING); font-size: clamp(28px, 4vw, 40px); line-height: 1.2; color: var(--COLOR-TEXT); }\n  .bpl-price-card__price small { font-size: var(--font-body-medium); }\n  .bpl-price-card__for { margin: 0 0 24px; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-small); line-height: 1.8; }\n  .bpl-price-card__sub { margin: 0 0 14px; color: var(--COLOR-TEXT); font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); }\n  .bpl-scope { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; margin: 0 0 24px; padding: 0; list-style: none; }\n  .bpl-scope li { position: relative; padding-left: 1.5em; color: var(--COLOR-TEXT); font-size: var(--font-body-small); line-height: 1.7; }\n  .bpl-scope li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  .bpl-spec { display: grid; grid-template-columns: 1fr 1fr; gap: 0 32px; margin: 0 0 20px; padding: 0; list-style: none; }\n  .bpl-spec li { display: flex; justify-content: space-between; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--sp-page-border); font-size: var(--font-body-small); }\n  .bpl-spec li > span:first-child { color: var(--COLOR-TEXT-A80); white-space: nowrap; }\n  .bpl-spec li > span:last-child { color: var(--COLOR-TEXT); font-weight: var(--FONT-WEIGHT-BODY-BOLD); text-align: right; }\n  .bpl-price-card__note { margin: 0; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-small); line-height: 1.9; }\n  @media (max-width: 760px) { .bpl-scope, .bpl-spec { grid-template-columns: 1fr; } .bpl-price-card__note { text-align: center; } }\n</style>\n<section class=\"sp-sec sp-sec--offer\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Offer</p>\n      <h2 class=\"sp-title\">Basicプラン</h2>\n      <p class=\"sp-lead\">必要な範囲に絞って、Shopify自社ECを立ち上げる構築プランです。</p>\n    </div>\n    <div class=\"bpl-price-card\">\n      <p class=\"bpl-price-card__name\">Basicプラン</p>\n      <p class=\"bpl-price-card__price\">1,100,000円<small>（税込）〜</small></p>\n      <p class=\"bpl-price-card__for\">Shopifyで小さく始めて、売上に合わせて育てる、自社EC構築プランです。</p>\n      <p class=\"bpl-price-card__sub\">構築内容</p>\n      <ul class=\"bpl-scope\">\n        <li>コンセプト定義・要件定義</li>\n        <li>Shopify初期セットアップ・決済・配送・税設定</li>\n        <li>ECサイトデザイン制作</li>\n        <li>商品登録 20点 / カテゴリ・コレクション登録 6点</li>\n        <li>アプリ連携 3点 / オリジナルページ制作 3ページ</li>\n        <li>購入テスト・表示確認</li>\n      </ul>\n      <ul class=\"bpl-spec\">\n        <li><span>納期</span><span>約4〜8週間</span></li>\n        <li><span>体制</span><span>ディレクター1名 / エンジニア1名</span></li>\n        <li><span>進捗打ち合わせ</span><span>3回</span></li>\n        <li><span>修正対応</span><span>3回まで</span></li>\n      </ul>\n      <p class=\"bpl-price-card__note\">進捗打ち合わせ3回は、要件確認／構築内容確認／公開前確認を予定しています。※大幅な仕様変更は別途お見積りとなります。</p>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "narrow": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .bpl-fit { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 980px; margin: 0 auto; }\n  .bpl-fit .sp-card h3 { font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); margin: 0 0 16px; text-align: center; }\n  .bpl-fit .sp-card.is-fit h3 { color: var(--sp-page-accent); }\n  .bpl-fit .sp-card ul { margin: 0; padding: 0; list-style: none; }\n  .bpl-fit .sp-card li { position: relative; padding-left: 1.5em; font-size: var(--font-body-small); color: var(--COLOR-TEXT-A80); line-height: 1.9; margin-bottom: 10px; }\n  .bpl-fit .sp-card li:last-child { margin-bottom: 0; }\n  .bpl-fit .sp-card li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  @media (max-width: 760px) { .bpl-fit { grid-template-columns: 1fr; } }\n</style>\n<section class=\"sp-sec sp-sec--narrow\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Narrow</p>\n      <h2 class=\"sp-title\">正直にお伝えします。<br>Basicプランが向いている企業、向いていない企業があります。</h2>\n    </div>\n    <div class=\"bpl-fit\">\n      <div class=\"sp-card is-fit\"><h3>Basicプランが向いている企業</h3><ul><li>自社ECサイトを立ち上げたい企業</li><li>商品数を絞って、まずは販売基盤を整えたい企業</li><li>まずは自社ECで売れるかを検証したい企業</li><li>ブランドの世界観を反映したECサイトを作りたい企業</li><li>モールやSNSだけに頼らず、自社の販売拠点を作りたい企業</li><li>公開後は、自社で商品追加や更新を行っていきたい企業</li></ul></div>\n      <div class=\"sp-card\"><h3>上位プランが向いているケース</h3><ul><li>最初から大量の商品登録が必要な企業</li><li>独自機能や複雑なカスタマイズが必要な企業</li><li>基幹システム、POS、倉庫システムなど外部連携が必要な企業</li><li>越境EC、多言語、多通貨対応を本格的に進めたい企業</li><li>広告運用や日々の更新まで丸ごと依頼したい企業</li><li>すでに売上規模が大きく、リニューアルや運用改善まで含めた設計が必要な企業</li></ul></div>\n    </div>\n    <p class=\"sp-note\">Basicプランは、すべての企業に向けたプランではありません。まずは必要な範囲に絞って、自社ECの販売基盤を整えたい企業に向いています。</p>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
