      "name": "Custom code",
      "settings": {
        "code": "<script>\n  (function () {\n    function getForm() { return document.querySelector('.index-contact'); }\n\n    function headerOffset() {\n      var off = 0;\n      var els = document.querySelectorAll('header, [class*=\"header\"], [class*=\"Header\"]');\n      for (var i = 0; i < els.length; i++) {\n        var el = els[i], s = window.getComputedStyle(el);\n        if ((s.position === 'fixed' || s.position === 'sticky') && el.offsetHeight && el.getBoundingClientRect().top <= 1) {\n          off = Math.max(off, el.offsetHeight);\n        }\n      }\n      return off;\n    }\n\n    function jumpToForm() {\n      var form = getForm();\n      if (!form) return;\n      var top = form.getBoundingClientRect().top + window.pageYOffset - headerOffset() - 12;\n      window.scrollTo({ top: top < 0 ? 0 : top, behavior: 'smooth' });\n    }\n\n    // Make every CTA button (a.btn) scroll to the contact form (now and in the future).\n    document.addEventListener('click', function (e) {\n      var trigger = e.target.closest('a.btn');\n      if (!trigger) return;\n      var form = getForm();\n      if (!form || form.contains(trigger)) return;\n      e.preventDefault();\n      jumpToForm();\n    });\n\n    // Also point the native href at the real section id (fallback / correct anchor).\n    function fixHrefs() {\n      var form = getForm();\n      if (!form) return;\n      var wrap = form.closest('[id^=\"shopify-section-\"]');\n      if (!wrap) return;\n      var btns = document.querySelectorAll('a.btn');\n      for (var i = 0; i < btns.length; i++) {\n        if (!form.contains(btns[i])) btns[i].setAttribute('href', '#' + wrap.id);\n      }\n    }\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', fixHrefs);\n    } else {\n      fixHrefs();\n    }\n  })();\n</script>",
