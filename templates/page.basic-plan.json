    "stats": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<!-- 実績ハイライト - SOLSTAR -->\n<div class=\"solstar-stats\">\n  <div class=\"solstar-stats__grid\">\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"100\"\n           data-decimals=\"0\"\n           data-suffix=\"億円以上\">\n        100億円以上\n      </div>\n      <div class=\"solstar-stats__label\">支援先ECサイトの年間売上規模</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"13\"\n           data-decimals=\"0\"\n           data-suffix=\"％\">\n        13％\n      </div>\n      <div class=\"solstar-stats__label\">表示速度改善率</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"4.37\"\n           data-decimals=\"2\"\n           data-suffix=\"％\">\n        4.37％\n      </div>\n      <div class=\"solstar-stats__label\">新規顧客の購入CVR</div>\n    </div>\n  </div>\n</div>\n\n<style>\n  .solstar-stats {\n    max-width: 1080px;\n    margin: 0 auto;\n    padding: 48px 16px;\n    background-color: var(--COLOR-BG);\n  }\n\n  .solstar-stats__grid {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 32px;\n  }\n\n  .solstar-stats__item {\n    text-align: center;\n    padding: 24px 16px;\n    opacity: 1;\n    transform: translateY(0);\n    transition:\n      opacity 0.6s ease-out,\n      transform 0.6s ease-out;\n  }\n\n  .solstar-stats.is-animated .solstar-stats__item:not(.is-visible) {\n    opacity: 0;\n    transform: translateY(24px);\n  }\n\n  .solstar-stats__item.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .solstar-stats__value {\n    font-weight: 700;\n    letter-spacing: 0;\n    font-size: clamp(40px, 4.2vw, 55px);\n    line-height: 1.1;\n    margin-bottom: 8px;\n    font-feature-settings: \"pnum\" on, \"lnum\" on;\n    color: var(--COLOR-TEXT);\n    white-space: nowrap;\n    word-break: keep-all;\n  }\n\n  .solstar-stats__label {\n    font-size: 20px;\n    font-weight: 700;\n    line-height: 1.6;\n    letter-spacing: 0;\n    color: var(--sp-page-accent);\n  }\n\n  @media (max-width: 767px) {\n    .solstar-stats {\n      padding: 32px 16px;\n    }\n\n    .solstar-stats__grid {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .solstar-stats__item {\n      padding: 20px 16px;\n    }\n\n    .solstar-stats__value {\n      font-size: clamp(38px, 12vw, 44px);\n    }\n\n    .solstar-stats__label {\n      font-size: 17px;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    function initSolstarStats() {\n      var sections = document.querySelectorAll('.solstar-stats');\n\n      if (!sections.length) return;\n\n      sections.forEach(function (section) {\n        if (section.dataset.solstarStatsInitialized === 'true') return;\n        section.dataset.solstarStatsInitialized = 'true';\n\n        var items = section.querySelectorAll('.solstar-stats__item');\n        var values = section.querySelectorAll('.solstar-stats__value');\n        var animated = false;\n\n        section.classList.add('is-animated');\n\n        function animateNumbers() {\n          if (animated) return;\n          animated = true;\n\n          values.forEach(function (el) {\n            var target = parseFloat(el.getAttribute('data-value') || '0');\n            var decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);\n            var suffix = el.getAttribute('data-suffix') || '';\n            var duration = 1500;\n            var start = null;\n\n            el.textContent = (0).toFixed(decimals) + suffix;\n\n            function step(timestamp) {\n              if (!start) start = timestamp;\n\n              var progress = Math.min((timestamp - start) / duration, 1);\n              var easedProgress = 1 - Math.pow(1 - progress, 3);\n              var current = target * easedProgress;\n\n              el.textContent = current.toFixed(decimals) + suffix;\n\n              if (progress < 1) {\n                window.requestAnimationFrame(step);\n              } else {\n                el.textContent = target.toFixed(decimals) + suffix;\n              }\n            }\n\n            window.requestAnimationFrame(step);\n          });\n        }\n\n        function revealItems() {\n          items.forEach(function (item, index) {\n            item.style.transitionDelay = (index * 0.12) + 's';\n            item.classList.add('is-visible');\n          });\n        }\n\n        function runAnimation() {\n          revealItems();\n          animateNumbers();\n        }\n\n        function isInViewport(el) {\n          var rect = el.getBoundingClientRect();\n          var windowHeight = window.innerHeight || document.documentElement.clientHeight;\n\n          return rect.top < windowHeight * 0.85 && rect.bottom > 0;\n        }\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(function (entries) {\n            entries.forEach(function (entry) {\n              if (entry.isIntersecting) {\n                runAnimation();\n                observer.unobserve(section);\n              }\n            });\n          }, {\n            root: null,\n            threshold: 0.2\n          });\n\n          observer.observe(section);\n\n          setTimeout(function () {\n            if (!animated && isInViewport(section)) {\n              runAnimation();\n              observer.unobserve(section);\n            }\n          }, 300);\n        } else {\n          runAnimation();\n        }\n      });\n    }\n\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', initSolstarStats);\n    } else {\n      initSolstarStats();\n    }\n\n    window.addEventListener('load', initSolstarStats);\n\n    document.addEventListener('shopify:section:load', function () {\n      initSolstarStats();\n    });\n  })();\n</script>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_custom_code_qiTqCd": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  /* ============================================================\n     0. フェードイン・アニメーション用のスタイル (共通追加)\n  ============================================================ */\n  .js-fade-in {\n    opacity: 0;\n    transform: translateY(40px);\n    transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n  }\n\n  .js-fade-in.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* ============================================================\n     1. コンセプト設計セクション (背景: Color scheme 1 surface)\n  ============================================================ */\n  #se-concept-section {\n    width: 100%;\n    margin: 0;\n    padding: 0 40px 20px; /* 上の余白を削除 */\n    box-sizing: border-box;\n    overflow: hidden;\n    background-color: var(--COLOR-BG);\n  }\n\n  #se-concept-section * { box-sizing: border-box; }\n\n  .se-container {\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  /* 見出し位置の微調整（余白削除に伴う調整） */\n  .se-heading-wrapper {\n    text-align: center;\n    margin-bottom: 60px;\n    max-width: 800px;\n    margin-left: auto;\n    margin-right: auto;\n    padding-top: 60px; /* コンテンツとしての適切な間隔は維持 */\n  }\n\n  .se-section-title {\n    margin-bottom: 20px;\n    position: relative;\n    display: inline-block;\n    font-size: var(--font-body-medium);\n    font-weight: 800;\n    color: var(--COLOR-TEXT);\n  }\n\n  .se-lead-text {\n    text-align: left;\n    font-size: var(--font-body-medium);\n    line-height: 1.8;\n    color: var(--COLOR-TEXT-A80);\n  }\n\n  .se-layout-wrapper {\n    display: flex;\n    flex-direction: column;\n    gap: 80px;\n  }\n\n  .se-card {\n    display: flex;\n    flex-direction: column;\n    position: relative;\n  }\n\n  .se-card-figure {\n    width: 100%;\n    position: relative;\n    overflow: hidden;\n    aspect-ratio: 16 / 9;\n    border-radius: 12px;\n  }\n\n  .se-card-figure img {\n    width: 100%;\n    height: 100%;\n    display: block;\n    object-fit: cover;\n  }\n\n  .se-card-body {\n    padding: 30px 0;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .se-card-header { margin-bottom: 16px; }\n  .se-card-title { margin: 0; font-size: var(--font-body-medium); font-weight: 700; color: var(--COLOR-TEXT); }\n  .se-card-title span.en-prefix {\n    display: block;\n    margin-bottom: 4px;\n    color: var(--sp-page-accent);\n    font-size: var(--font-body-medium);\n    text-transform: uppercase;\n  }\n\n  .se-card-desc { margin-bottom: 24px; font-size: var(--font-body-medium); color: var(--COLOR-TEXT-A80); font-weight: 500; }\n\n  .se-content-block { margin-bottom: 20px; }\n  \n  .se-label {\n    display: flex;\n    align-items: center;\n    margin-bottom: 10px;\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n  }\n\n  .se-label-hearing::before,\n  .se-label-reflect::before {\n    display: inline-flex;\n    justify-content: center;\n    align-items: center;\n    width: 28px;\n    height: 28px;\n    margin-right: 10px;\n    flex-shrink: 0;\n    font-weight: bold;\n    border-radius: 50%;\n  }\n\n  .se-label-hearing::before { content: 'Q'; background: transparent; color: var(--COLOR-TEXT-A80); border: 1.5px solid var(--COLOR-TEXT-A35); }\n  .se-label-reflect::before { content: 'A'; background: var(--sp-page-accent); color: var(--BTN-PRIMARY-TEXT); border: 1.5px solid var(--sp-page-accent); }\n  .se-label-hearing { color: var(--COLOR-TEXT); }\n  .se-label-reflect { color: var(--sp-page-accent); }\n\n  .se-text-box {\n    padding: 16px 20px;\n    background: var(--COLOR-TEXT-A5);\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 12px;\n    color: var(--COLOR-TEXT);\n    font-size: var(--font-body-medium);\n    line-height: 1.7;\n  }\n\n  .se-text-box.is-reflect {\n    background: rgba(171, 140, 82, 0.12);\n    border: 1px solid var(--sp-page-accent);\n    border-left: 1px solid var(--COLOR-TEXT-A35);\n    color: var(--COLOR-TEXT);\n  }\n\n  .se-text-box ul { margin: 0; padding-left: 20px; }\n  .se-text-box li { margin-bottom: 6px; }\n\n  /* Concept Animation Styles (既存のスライドインアニメーションを保持) */\n  .se-card .se-card-figure,\n  .se-card .se-card-body {\n    opacity: 0;\n    transition: opacity 1.0s ease-out, transform 1.0s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .se-card .se-card-figure { transform: translateY(30px); }\n  .se-card .se-card-body { transform: translateY(30px); transition-delay: 0.2s; }\n\n  @media (min-width: 768px) {\n    .se-lead-text { text-align: center; }\n    .se-card { flex-direction: row; align-items: center; gap: 60px; }\n    .se-card-figure, .se-card-body { width: 50%; padding: 0; margin: 0; }\n    .se-card:nth-child(even) { flex-direction: row-reverse; }\n    \n    .se-card:nth-child(odd) .se-card-figure { transform: translateX(-60px); }\n    .se-card:nth-child(odd) .se-card-body { transform: translateX(60px); }\n    .se-card:nth-child(even) .se-card-figure { transform: translateX(60px); }\n    .se-card:nth-child(even) .se-card-body { transform: translateX(-60px); }\n  }\n\n  .se-card.is-visible .se-card-figure,\n  .se-card.is-visible .se-card-body {\n    opacity: 1;\n    transform: translate(0, 0);\n  }\n\n  /* ============================================================\n     2. 構築実績セクション (背景: Color scheme 1 accent background)\n  ============================================================ */\n  .solstar-testimonial {\n    padding: 40px 20px 0; /* 下の余白を削除 */\n    background-color: var(--COLOR-BG);\n    color: var(--COLOR-TEXT);\n    box-sizing: border-box;\n  }\n\n  .solstar-testimonial-inner {\n    max-width: 1000px;\n    margin: 0 auto;\n    padding-bottom: 80px; /* カードの影を収めるための内側余白 */\n  }\n\n  .solstar-heading-wrapper {\n    text-align: center;\n    max-width: 800px;\n    margin: 0 auto 48px;\n  }\n\n  .solstar-heading {\n    font-size: var(--font-body-medium);\n    font-weight: 800;\n    color: var(--COLOR-TEXT);\n    margin-top: 0;\n    margin-bottom: 16px;\n  }\n\n  .solstar-sub-heading {\n    font-size: var(--font-body-medium);\n    color: var(--COLOR-TEXT-A80);\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .solstar-testimonial-card {\n    background: var(--COLOR-TEXT-A5);\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 12px;\n    padding: 40px;\n    box-shadow: 0 16px 40px var(--COLOR-TEXT-A5);\n    display: flex;\n    flex-direction: row;\n    gap: 40px;\n    height: 480px; \n    box-sizing: border-box;\n    overflow: hidden;\n  }\n\n  .solstar-col-img {\n    flex: 0 0 40%;\n    position: relative;\n    display: flex;\n    align-items: flex-start;\n    height: 100%;\n  }\n\n  .solstar-img-frame {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    border-radius: 12px;\n    overflow: hidden;\n    max-height: 100%; \n  }\n\n  .solstar-img-frame img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    transition: opacity 0.3s ease;\n  }\n\n  .solstar-col-text {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    text-align: left;\n    height: 100%;\n    padding-top: 10px;\n    box-sizing: border-box;\n  }\n\n  .solstar-label {\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    color: var(--sp-page-accent);\n    margin-bottom: 24px;\n    display: block;\n    flex-shrink: 0;\n  }\n\n  .solstar-content-body {\n    flex-grow: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-start;\n    overflow: hidden;\n  }\n\n  .solstar-quote-heading {\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    line-height: 1.4;\n    color: var(--COLOR-TEXT);\n    margin-bottom: 20px;\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .solstar-body-text {\n    font-size: var(--font-body-medium);\n    line-height: 1.7;\n    color: var(--COLOR-TEXT-A80);\n    display: -webkit-box;\n    -webkit-line-clamp: 4;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .solstar-divider {\n    width: 100%;\n    height: 1px;\n    background: var(--COLOR-TEXT-A35);\n    margin-bottom: 24px;\n    margin-top: 24px;\n    flex-shrink: 0;\n  }\n\n  .solstar-footer {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    flex-shrink: 0;\n  }\n\n  .solstar-author-name { font-size: var(--font-body-medium); font-weight: 700; color: var(--COLOR-TEXT); margin-bottom: 4px; }\n  .solstar-author-role { font-size: var(--font-body-medium); color: var(--COLOR-TEXT-A80); }\n\n  .solstar-nav-buttons { display: flex; gap: 12px; }\n  .solstar-btn-arrow {\n    width: 44px;\n    height: 44px;\n    border-radius: var(--btn-radius);\n    border: 1px solid var(--BTN-PRIMARY-BORDER);\n    background: var(--BTN-PRIMARY-BG);\n    color: var(--BTN-PRIMARY-TEXT);\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.2s ease;\n  }\n  .solstar-btn-arrow:hover { background: var(--BTN-PRIMARY-BG-BRIGHTER); border-color: var(--BTN-PRIMARY-BG-BRIGHTER); color: var(--BTN-PRIMARY-TEXT); }\n\n  .solstar-anim-fade { animation: solstarFadeIn 0.4s ease-out forwards; }\n  @keyframes solstarFadeIn {\n    from { opacity: 0; transform: translateY(5px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  @media (max-width: 768px) {\n    .solstar-testimonial { padding: 40px 20px 0; }\n    .solstar-heading { font-size: var(--font-body-medium); }\n    .solstar-testimonial-card { flex-direction: column; padding: 24px; height: auto; min-height: 550px; }\n    .solstar-col-img { width: 100%; height: auto; }\n    .solstar-quote-heading { font-size: var(--font-body-medium); }\n  }\n\n  /* Theme typography overrides */\n\n  #se-concept-section,\n  .solstar-testimonial {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .se-card-title span.en-prefix,\n  .solstar-label {\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n  .se-section-title,\n  .se-card-title,\n  .solstar-heading,\n  .solstar-quote-heading {\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n  .se-section-title,\n  .solstar-heading { font-size: var(--font-heading-large); }\n  .se-card-title,\n  .solstar-quote-heading { font-size: var(--font-heading-medium); }\n  .se-lead-text,\n  .solstar-sub-heading { font-size: var(--font-body-medium); }\n  .se-card-desc,\n  .se-label,\n  .se-text-box,\n  .solstar-body-text,\n  .solstar-author-name,\n  .solstar-author-role {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .se-card-desc,\n  .se-text-box,\n  .se-text-box.is-reflect,\n  .solstar-body-text { font-size: var(--font-body-small); }\n  .se-label,\n  .solstar-author-role { font-size: var(--font-body-x-small); }\n  /* End theme typography overrides */\n</style>\n\n<section id=\"se-concept-section\">\n  <div class=\"se-container\">\n    <div class=\"se-heading-wrapper js-fade-in\">\n      <h2 class=\"se-section-title\">ブランドらしさを、<br>言葉・導線・デザインに落とし込む。</h2>\n      <p class=\"se-lead-text\">\n        ECサイトは、単なる「商品を並べる場所」ではありません。私たちはECサイト構築の前に、お客様の中にすでにあるブランドの想いや価値を整理し、サイト上でどう表現するかというコンセプト定義を徹底的に行います。</p>\n    </div>\n\n    <div class=\"se-layout-wrapper\">\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Basic_plan_brand_concept_1.png?v=1783341772\" alt=\"ECコンセプト設計：ペルソナ整理のイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">Who</span>誰の心を動かしたいのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">ターゲットの表面的な属性だけでなく、その奥にある「感情」や「価値観」を捉えます。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>その商品はどんな人の悩みを解決するのですか？</li>\n                <li>ターゲットとなる方の年齢層や、日常の過ごし方、ライフスタイルは？</li>\n                <li>その人は普段どのような価値に共感してブランドを選びますか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              属性だけでなく価値観まで掘り下げて定義。感性に合わせた言葉選び、ビジュアル、情報設計を通じて、ブランドらしさが直感的に伝わる体験をつくります。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Basic_plan_brand_concept_2.png?v=1783342451\" alt=\"ECコンセプト設計：選ばれる理由を言語化するイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">What</span>そのブランドは何故選ばれるのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">市場における立ち位置を整理し、他にはない「選ばれる理由」を言語化します。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>巨大モールではなく、あえて自社サイトで購入してもらう理由は？</li>\n                <li>競合商品と比較されたとき、あなたの商品が選ばれる理由は？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              市場での優位性を特定し、商品を手にしたお客様の未来（ベネフィット）を言語化。オリジナルテーマ「CREAM」の標準機能を活かし、迷わず購入できる体験を設計します。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Basic_plan_brand_concept_3.png?v=1783342852\" alt=\"ECコンセプト設計：ブランド価値を可視化するイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">Why</span>なぜそのブランドが必要なのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">ブランドに込めた「想い」を可視化し、共感によって選ばれるブランドへ導きます。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>なぜ、この商品を世に送り出そうと思ったのですか？</li>\n                <li>ブランドを通じて、どのような価値や理想の未来を実現したいですか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              創業ストーリーや想いを「ブランド紹介（About Us）」として形にし、信頼を獲得。価格競争に巻き込まれない、共感を軸にしたブランド基盤を構築します。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Basic_plan_brand_concept_4.png?v=1783344009\" alt=\"ECコンセプト設計：ブランドの世界観とUIデザインのイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">How</span>どう見え、どう感じられたいか？</h3>\n          </div>\n          <p class=\"se-card-desc\">一貫したトーンで、ひと目で「このブランドらしい」と感じられる体験をつくります。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>ブランドの世界観として、大切にしたい雰囲気や印象はありますか？</li>\n                <li>ブランドカラーや、取り入れたいデザイン・表現はありますか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              デザインシステムを活用し、配色・フォント・配置を統一。Shopify認定資格を持つプロによるUI/UX設計で、ユーザーへの印象を丁寧に設計し信頼感を高めます。\n            </div>\n          </div>\n        </div>\n      </article>\n    </div>\n  </div>\n</section>\n\n<div class=\"solstar-testimonial\">\n  <div class=\"solstar-testimonial-inner\">\n    <div class=\"solstar-heading-wrapper js-fade-in\">\n      <h2 class=\"solstar-heading\">ECサイト構築実績</h2>\n      <p class=\"solstar-sub-heading\">立ち上げ初期でも成果に繋がった事例を一部ご紹介致します。</p>\n    </div>\n\n    <div class=\"solstar-testimonial-card js-fade-in\">\n      <div class=\"solstar-col-img\">\n        <div class=\"solstar-img-frame\">\n          <img id=\"solstar-img\" src=\"\" alt=\"Shopify ECサイト構築のお客様事例イメージ\" loading=\"lazy\">\n        </div>\n      </div>\n      <div class=\"solstar-col-text\">\n        <span class=\"solstar-label\">お客様の声</span>\n        <div class=\"solstar-content-body\" id=\"solstar-anim-wrapper\">\n            <div class=\"solstar-quote-heading\" id=\"solstar-quote\"></div>\n            <div class=\"solstar-body-text\" id=\"solstar-body\"></div>\n        </div>\n        <div class=\"solstar-divider\"></div>\n        <div class=\"solstar-footer\">\n          <div class=\"solstar-author-info\">\n            <div class=\"solstar-author-name\" id=\"solstar-title\"></div>\n            <div class=\"solstar-author-role\" id=\"solstar-sub\"></div>\n          </div>\n          <div class=\"solstar-nav-buttons\">\n            <button type=\"button\" class=\"solstar-btn-arrow\" id=\"btn-prev\" aria-label=\"Previous\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg>\n            </button>\n            <button type=\"button\" class=\"solstar-btn-arrow\" id=\"btn-next\" aria-label=\"Next\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  /* Intersection Observer for Concept Section & Fade-in Animations */\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    const observer = new IntersectionObserver((entries, observer) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.15 }); // 15%表示されたら発火に調整\n\n    // 元々の左右スライド用カードを監視\n    document.querySelectorAll('.se-card').forEach(card => observer.observe(card));\n    // 今回追加した上部見出し・実績カードを監視\n    document.querySelectorAll('.js-fade-in').forEach(el => observer.observe(el));\n  });\n\n  /* Testimonial Data & Logic */\n  (function () {\n    const data = [\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_5.webp?v=1766473796\",\n        title: \"合同会社Rsworks\",\n        sub: \"キッチンブランド\",\n        body: \"ブランドの世界観と高級感を保ったECサイトを構築。キャンペーンではLINE登録単価30円、登録者2,306人を達成。\",\n        quote: \"洗練されたクリエイティブセンスで一目置くECサイトを構築していただき、とても満足しています。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_3.webp?v=1766473796\",\n        title: \"PAW MINT\",\n        sub: \"ペットブランド\",\n        body: \"ブランドの世界観をポップに表現したLPを制作。広告施策により2,000名以上のメルマガ登録獲得。\",\n        quote: \"可愛くポップなECサイトを作って頂きました。世界観の表現が素晴らしいです。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_2.webp?v=1766473796\",\n        title: \"株式会社EDGBLACK\",\n        sub: \"キッチンブランド\",\n        body: \"Shopify移行後、公開初月に27万円以上の売上を実現。\",\n        quote: \"とても丁寧かつ詳細に説明してくださったので、困ることは一切ありませんでした。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_1.webp?v=1766473795\",\n        title: \"株式会社ONETREE\",\n        sub: \"スニーカーブランド\",\n        body: \"公式ECサイトを約2か月で立ち上げ、公開初月に12万円以上の売上を達成されました。Shopifyを活用し、ブランドの認知拡大とファンづくりを進められています。\",\n        quote: \"調整にも柔軟に対応してもらえ、安心して任せられました。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_4.webp?v=1766473796\",\n        title: \"SANDY HAZE\",\n        sub: \"水着ブランド\",\n        body: \"英語圏向け越境ECを構築。商品撮影から広告運用まで対応し、3ヶ月で月商100万円を達成。\",\n        quote: \"They made our first e-commerce site look amazing.\"\n      }\n    ];\n\n    let index = 0;\n    const imgEl = document.getElementById(\"solstar-img\");\n    const quoteEl = document.getElementById(\"solstar-quote\");\n    const bodyEl = document.getElementById(\"solstar-body\");\n    const titleEl = document.getElementById(\"solstar-title\");\n    const subEl = document.getElementById(\"solstar-sub\");\n    const animWrapper = document.getElementById(\"solstar-anim-wrapper\");\n\n    function render(i) {\n      const d = data[i];\n      imgEl.style.opacity = 0;\n      animWrapper.classList.remove('solstar-anim-fade');\n      void animWrapper.offsetWidth; \n      animWrapper.classList.add('solstar-anim-fade');\n\n      setTimeout(() => {\n          imgEl.src = d.img;\n          imgEl.onload = () => { imgEl.style.opacity = 1; };\n          quoteEl.textContent = d.quote; \n          bodyEl.textContent = d.body;\n          titleEl.textContent = d.title;\n          subEl.textContent = d.sub;\n      }, 100);\n    }\n\n    document.getElementById(\"btn-next\").addEventListener(\"click\", () => {\n      index = (index + 1) % data.length;\n      render(index);\n    });\n\n    document.getElementById(\"btn-prev\").addEventListener(\"click\", () => {\n      index = (index - 1 + data.length) % data.length;\n      render(index);\n    });\n\n    render(index);\n  })();\n</script>\n<style>\n/* BRAND CONCEPT REFINED */\n#se-concept-section { padding: 72px 40px; }\n#se-concept-section .se-heading-wrapper { padding-top: 0; margin-bottom: 72px; }\n#se-concept-section .se-heading-wrapper::before { content: 'Brand Concept'; display: block; margin-bottom: 14px; color: var(--sp-page-accent); font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); text-transform: var(--FONT-UPPERCASE-SUBHEADING); }\n#se-concept-section .se-section-title { position: relative; }\n#se-concept-section .se-section-title::after { display: none; }\n#se-concept-section .se-lead-text { text-align: center; }\n#se-concept-section .se-layout-wrapper { gap: 72px; }\n#se-concept-section .se-card-figure { border: 1px solid var(--COLOR-TEXT-A35); box-shadow: 0 18px 44px rgba(0,0,0,0.30); }\n#se-concept-section .se-card-figure img { transition: transform 1.4s cubic-bezier(0.22,1,0.36,1); }\n#se-concept-section .se-card-figure:hover img { transform: scale(1.05); }\n#se-concept-section .se-card-title span.en-prefix { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; color: var(--sp-page-accent); font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); text-transform: var(--FONT-UPPERCASE-SUBHEADING); }\n#se-concept-section .se-card-title span.en-prefix::before { display: none; }\n#se-concept-section .se-card-desc { padding-bottom: 0; margin-bottom: 24px; border-bottom: 0; }\n#se-concept-section .se-label-hearing { color: var(--COLOR-TEXT-A80); }\n#se-concept-section .se-label-reflect { color: var(--sp-page-accent); }\n@media (min-width: 768px) {\n  #se-concept-section .se-card { gap: 56px; align-items: center; }\n  #se-concept-section .se-card-body { padding: 8px 0; }\n}\n@media (max-width: 767px) {\n  #se-concept-section { padding: 48px 20px; }\n  #se-concept-section .se-heading-wrapper { margin-bottom: 40px; }\n  #se-concept-section .se-layout-wrapper { gap: 34px; }\n  #se-concept-section .se-card-body { padding: 14px 0; }\n  #se-concept-section .se-content-block { margin-bottom: 12px; }\n}\n</style>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "growth": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .bpl-growth-figure { max-width: 800px; margin: 32px auto 0; border-radius: var(--sp-page-card-radius); overflow: hidden; }\n  .bpl-growth-figure img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }\n  .bpl-steps-lead { max-width: 720px; margin: 24px auto 0; text-align: center; color: var(--COLOR-TEXT); font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); line-height: 1.6; }\n  .bpl-growth-cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; max-width: 980px; margin: 32px auto 0; }\n  .bpl-growth-cards .sp-card { text-align: center; }\n  .sp-card .bpl-growth-no { margin: 0 0 10px; color: var(--sp-page-accent); font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); }\n  .bpl-growth-text { margin: 0; color: var(--COLOR-TEXT); font-size: var(--font-body-medium); line-height: 1.7; }\n  @media (max-width: 760px) {\n    .bpl-growth-cards { grid-template-columns: 1fr; }\n  }\n</style>\n<section class=\"sp-sec sp-sec--growth\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Growth</p>\n      <h2 class=\"sp-title\">自社ECは、公開してから少しずつ改善していくものです。</h2>\n    </div>\n    <figure class=\"bpl-growth-figure\"><img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Small_Business_Success.png?v=1782979345\" alt=\"Basicプラン公開後の育て方のイメージ\" loading=\"lazy\"></figure>\n    <p class=\"bpl-steps-lead\">Basicプランで販売開始に必要な土台を整えたあとは、運用しながら反応を見て、段階的に広げていくことができます。</p>\n    <div class=\"bpl-growth-cards\">\n      <div class=\"sp-card\"><p class=\"bpl-growth-no\">01</p><p class=\"bpl-growth-text\">まずは自社で運用しながら、売れやすい商品や購入されやすい導線を確認する</p></div>\n      <div class=\"sp-card\"><p class=\"bpl-growth-no\">02</p><p class=\"bpl-growth-text\">反応が見えてきたら、商品・ページ・アプリを少しずつ追加する</p></div>\n      <div class=\"sp-card\"><p class=\"bpl-growth-no\">03</p><p class=\"bpl-growth-text\">更新や改善に手が回らなくなってきたら、運用・改善のサポートを活用する</p></div>\n    </div>\n    <p class=\"sp-note\">公開後の運用や集客サポートが必要になった際も、事業フェーズに合わせてご提案します。</p>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "offer": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .bpl-price-card { max-width: 920px; margin: 0 auto; border: 1px solid var(--sp-page-accent); border-radius: var(--sp-page-card-radius); background: var(--COLOR-TEXT-A5); padding: 32px; }\n  .bpl-price-card__name { margin: 0 0 6px; font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); color: var(--COLOR-TEXT); }\n  .bpl-price-card__price { margin: 0 0 10px; font-family: var(--FONT-STACK-HEADING); font-size: clamp(28px, 4vw, 40px); line-height: 1.2; color: var(--COLOR-TEXT); }\n  .bpl-price-card__price small { font-size: var(--font-body-medium); }\n  .bpl-price-card__for { margin: 0 0 24px; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-small); line-height: 1.8; }\n  .bpl-price-card__sub { margin: 0 0 14px; color: var(--COLOR-TEXT); font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); }\n  .bpl-scope { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; margin: 0 0 24px; padding: 0; list-style: none; }\n  .bpl-scope li { position: relative; padding-left: 1.5em; color: var(--COLOR-TEXT); font-size: var(--font-body-small); line-height: 1.7; }\n  .bpl-scope li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  .bpl-spec { display: grid; grid-template-columns: 1fr 1fr; gap: 0 32px; margin: 0 0 20px; padding: 0; list-style: none; }\n  .bpl-spec li { display: flex; justify-content: space-between; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--sp-page-border); font-size: var(--font-body-small); }\n  .bpl-spec li > span:first-child { color: var(--COLOR-TEXT-A80); white-space: nowrap; }\n  .bpl-spec li > span:last-child { color: var(--COLOR-TEXT); font-weight: var(--FONT-WEIGHT-BODY-BOLD); text-align: right; }\n  .bpl-price-card__note { margin: 0; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-small); line-height: 1.9; }\n  @media (max-width: 760px) { .bpl-scope, .bpl-spec { grid-template-columns: 1fr; } .bpl-price-card__note { text-align: center; } }\n</style>\n<section class=\"sp-sec sp-sec--offer\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Offer</p>\n      <h2 class=\"sp-title\">Basicプラン</h2>\n      <p class=\"sp-lead\">Shopifyで自社ECを立ち上げ、販売開始まで整えるプランです。</p>\n    </div>\n    <div class=\"bpl-price-card\">\n      <p class=\"bpl-price-card__name\">Basicプラン</p>\n      <p class=\"bpl-price-card__price\">1,100,000円<small>（税込）〜</small></p>\n      <p class=\"bpl-price-card__for\">販売開始に必要な商品登録、カテゴリ設計、決済・配送設定、オリジナルページ制作までをまとめて整え、自社で運用を始めやすいECサイトを構築します。</p>\n      <p class=\"bpl-price-card__sub\">構築内容</p>\n      <ul class=\"bpl-scope\">\n        <li>コンセプト定義・要件定義</li>\n        <li>Shopify初期セットアップ・決済・配送・税設定</li>\n        <li>ECサイトデザイン制作</li>\n        <li>商品登録 20点 / カテゴリ・コレクション設計 6点</li>\n        <li>アプリ連携 3点 / オリジナルページ制作 3ページ</li>\n        <li>購入テスト・表示確認</li>\n      </ul>\n      <ul class=\"bpl-spec\">\n        <li><span>納期</span><span>約4〜8週間</span></li>\n        <li><span>体制</span><span>ディレクター1名 / エンジニア1名</span></li>\n        <li><span>進捗打ち合わせ</span><span>3回</span></li>\n        <li><span>修正対応</span><span>3回まで</span></li>\n      </ul>\n      <p class=\"bpl-price-card__note\">進捗打ち合わせ3回は、要件確認／構築内容確認／公開前確認を予定しています。※大幅な仕様変更は別途お見積りとなります。</p>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "narrow": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .bpl-fit { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 980px; margin: 0 auto; }\n  .bpl-fit .sp-card h3 { font-family: var(--FONT-STACK-HEADING); font-size: var(--font-heading-small); margin: 0 0 16px; text-align: center; }\n  .bpl-fit .sp-card.is-fit h3 { color: var(--sp-page-accent); }\n  .bpl-fit .sp-card ul { margin: 0; padding: 0; list-style: none; }\n  .bpl-fit .sp-card li { position: relative; padding-left: 1.5em; font-size: var(--font-body-small); color: var(--COLOR-TEXT-A80); line-height: 1.9; margin-bottom: 10px; }\n  .bpl-fit .sp-card li:last-child { margin-bottom: 0; }\n  .bpl-fit .sp-card li::before { content: ''; position: absolute; left: 0.2em; top: 0.78em; width: 6px; height: 6px; border-radius: 50%; background: var(--sp-page-accent); }\n  @media (max-width: 760px) { .bpl-fit { grid-template-columns: 1fr; } }\n</style>\n<section class=\"sp-sec sp-sec--narrow\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Narrow</p>\n      <h2 class=\"sp-title\">正直にお伝えします。<br>Basicプランが向いている企業、向いていない企業があります。</h2>\n    </div>\n    <div class=\"bpl-fit\">\n      <div class=\"sp-card is-fit\"><h3>Basicプランが向いている企業</h3><ul><li>モール型ECやSNS販売だけに頼らず、自社の販売拠点を作りたい企業</li><li>公開後は、自社で商品追加やページ更新を行っていきたい企業</li></ul></div>\n      <div class=\"sp-card\"><h3>上位プランが向いているケース</h3><ul><li>広告運用や日々の更新までまとめて依頼したい企業</li><li>すでに売上規模が大きく、リニューアルや運用改善まで含めた設計が必要な企業</li></ul></div>\n    </div>\n    <p class=\"sp-note\">Basicプランは、販売開始に必要な商品登録、カテゴリ設計、ページ制作、決済・配送設定を整え、まずは自社ECを立ち上げたい企業に向いています。</p>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-7",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
