    "seo_jsonld": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Organization\",\n      \"@id\": \"https://www.solstar.co.jp/#organization\",\n      \"name\": \"株式会社SOLSTAR\",\n      \"url\": \"https://www.solstar.co.jp\",\n      \"description\": \"ShopifyによるECサイト構築・伴走支援を行う制作会社。\"\n    },\n    {\n      \"@type\": \"WebPage\",\n      \"@id\": \"{{ canonical_url }}#webpage\",\n      \"url\": \"{{ canonical_url }}\",\n      \"name\": \"自社ECサイト構築 Basicプラン｜SOLSTAR\",\n      \"description\": \"Shopifyで自社ECを無理なく始めるBasicプラン。ブランドの世界観、購入導線、商品登録、決済・配送設定まで整理し、公開後も自社で運用・改善しやすいECサイトの土台を構築します。\",\n      \"inLanguage\": \"ja\",\n      \"about\": { \"@id\": \"{{ canonical_url }}#service\" },\n      \"audience\": {\n        \"@type\": \"Audience\",\n        \"audienceType\": \"自社ECサイトの立ち上げを検討する企業\"\n      }\n    },\n    {\n      \"@type\": \"Service\",\n      \"@id\": \"{{ canonical_url }}#service\",\n      \"name\": \"自社ECサイト構築 Basicプラン\",\n      \"serviceType\": \"Shopify自社ECサイト構築\",\n      \"description\": \"Shopifyで自社ECを立ち上げ、販売開始まで整える構築プラン。商品登録、カテゴリ設計、決済・配送設定、オリジナルページ制作までをまとめて整えます。\",\n      \"provider\": { \"@id\": \"https://www.solstar.co.jp/#organization\" },\n      \"areaServed\": { \"@type\": \"Country\", \"name\": \"日本\" },\n      \"audience\": {\n        \"@type\": \"Audience\",\n        \"audienceType\": \"自社ECサイトの立ち上げを検討する企業\"\n      },\n      \"offers\": {\n        \"@type\": \"Offer\",\n        \"name\": \"Basicプラン\",\n        \"priceCurrency\": \"JPY\",\n        \"price\": \"1100000\",\n        \"description\": \"販売開始に必要な基本構築を整え、まずは自社ECを立ち上げたい企業向け。構築期間の目安は約4〜8週間（税込1,100,000円〜）。\",\n        \"url\": \"{{ canonical_url }}\"\n      }\n    },\n    {\n      \"@type\": \"BreadcrumbList\",\n      \"itemListElement\": [\n        { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"ホーム\", \"item\": \"{{ shop.url }}\" },\n        { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"自社ECサイト構築 Basicプラン\", \"item\": \"{{ canonical_url }}\" }\n      ]\n    }\n  ]\n}\n</script>",
