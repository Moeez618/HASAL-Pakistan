    "benefit": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .sp-sec--benefit3 .sp-flow__desc { font-size: var(--font-body-medium); }\n</style>\n<section class=\"sp-sec sp-sec--benefit3\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Benefit</p>\n      <h2 class=\"sp-title\">Basicプランで得られること</h2>\n    </div>\n    <div class=\"sp-flow\">\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>01</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">自社でも販売できるECサイトを持てる</h3><p class=\"sp-flow__desc\">モール型ECやSNS販売だけに頼らず、自社でも商品を販売できるECサイトを構築します。<br>売上だけでなく、顧客との接点やブランドの伝え方を自社に蓄積しやすい状態を目指します。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>02</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">ブランドの世界観を反映できる</h3><p class=\"sp-flow__desc\">ブランドの方向性、商品の魅力、ターゲットに伝えるべき価値を整理しながら、ECサイトに反映します。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>03</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">検索エンジンやAIに伝わりやすい情報設計を整えられる</h3><p class=\"sp-flow__desc\">商品情報、カテゴリ、ブランド情報、FAQなどを整理し、検索エンジンやAIに内容を理解されやすい構成を整えます。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>04</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">公開後も、自社で運用・改善しやすくなる</h3><p class=\"sp-flow__desc\">商品追加、ページ更新、情報修正などを自社で進めやすい構成にします。<br>公開して終わりではなく、公開後も少しずつ商品、ページ、施策を広げていきやすい状態を作ります。</p></div></div>\n    </div>\n  </div>\n</section>",
