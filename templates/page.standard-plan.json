      "settings": {
        "code": "<style>\n  /* ============================================================\n     Fit / Not Fit Section\n     - Outer background gradient removed\n     - Text content updated as requested\n     - List item cards removed\n     - Check / X icons aligned center\n     - Intersection Observer animation\n     - Lazyload ready for future images\n  ============================================================ */\n\n  #sp-fit-section {\n    position: relative;\n    width: 100%;\n    overflow: hidden;\n    padding: clamp(64px, 8vw, 112px) 20px;\n    background-color: #0D0326;\n    color: var(--COLOR-TEXT);\n    isolation: isolate;\n  }\n\n  #sp-fit-section *,\n  #sp-fit-section *::before,\n  #sp-fit-section *::after {\n    box-sizing: border-box;\n  }\n\n  .sp-fit__inner {\n    width: min(100%, 1040px);\n    margin: 0 auto;\n  }\n\n  .sp-fit__head {\n    max-width: 840px;\n    margin: 0 auto clamp(40px, 5vw, 64px);\n    text-align: center;\n  }\n\n  .sp-fit__eyebrow {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 0 18px;\n    color: #AB8C52;\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    line-height: 1;\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n\n  .sp-fit__eyebrow::before,\n  .sp-fit__eyebrow::after {\n    content: '';\n    display: inline-block;\n    width: 34px;\n    height: 1px;\n    background: #AB8C52;\n  }\n\n  .sp-fit__eyebrow::before {\n    margin-right: 14px;\n  }\n\n  .sp-fit__eyebrow::after {\n    margin-left: 14px;\n  }\n\n  .sp-fit__lead {\n    margin: 0;\n    color: var(--COLOR-TEXT-A80);\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n    line-height: 2;\n  }\n\n  .sp-fit__lead + .sp-fit__lead {\n    margin-top: 14px;\n  }\n\n  .sp-fit__layout {\n    display: grid;\n    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);\n    gap: clamp(28px, 5vw, 64px);\n    align-items: start;\n  }\n\n  .sp-fit-group {\n    position: relative;\n    min-width: 0;\n    padding: clamp(22px, 3vw, 32px);\n    border: 1px solid rgba(255, 255, 255, 0.14);\n    border-radius: 24px;\n    background: rgba(255, 255, 255, 0.035);\n  }\n\n  .sp-fit-group--fit {\n    border-color: rgba(171, 140, 82, 0.42);\n  }\n\n  .sp-fit-group__title {\n    margin: 0 0 24px;\n    padding-bottom: 18px;\n    border-bottom: 1px solid rgba(255, 255, 255, 0.14);\n    color: var(--COLOR-TEXT);\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    font-size: var(--font-heading-medium);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    line-height: 1.4;\n    text-align: center;\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n\n  .sp-fit-list {\n    display: grid;\n    gap: 14px;\n    max-width: 520px;\n    margin: 0 auto;\n    padding: 0;\n    list-style: none;\n  }\n\n  .sp-fit-list__item {\n    position: relative;\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n    color: var(--COLOR-TEXT);\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-size: var(--font-body-small);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n    line-height: 1.8;\n  }\n\n  .sp-fit-list__icon {\n    position: relative;\n    display: inline-flex;\n    width: 22px;\n    height: 22px;\n    flex: 0 0 22px;\n    align-items: center;\n    justify-content: center;\n    margin-top: 0.28em;\n    border-radius: 999px;\n  }\n\n  .sp-fit-list__icon--check {\n    border: 1px solid rgba(171, 140, 82, 0.72);\n    background: rgba(171, 140, 82, 0.16);\n  }\n\n  .sp-fit-list__icon--check::before {\n    content: '';\n    width: 5px;\n    height: 9px;\n    border: solid #AB8C52;\n    border-width: 0 2px 2px 0;\n    transform: translateY(-1px) rotate(45deg);\n  }\n\n  .sp-fit-list__icon--x {\n    border: 1px solid rgba(255, 255, 255, 0.34);\n    background: rgba(255, 255, 255, 0.045);\n  }\n\n  .sp-fit-list__icon--x::before,\n  .sp-fit-list__icon--x::after {\n    content: '';\n    position: absolute;\n    left: 50%;\n    top: 50%;\n    width: 10px;\n    height: 1.5px;\n    border-radius: 999px;\n    background: rgba(255, 255, 255, 0.72);\n    transform-origin: center;\n  }\n\n  .sp-fit-list__icon--x::before {\n    transform: translate(-50%, -50%) rotate(45deg);\n  }\n\n  .sp-fit-list__icon--x::after {\n    transform: translate(-50%, -50%) rotate(-45deg);\n  }\n\n  .sp-fit-list__text {\n    display: block;\n    min-width: 0;\n  }\n\n  /* ============================================================\n     Animation\n  ============================================================ */\n\n  .sp-fit-animate {\n    opacity: 0;\n    transform: translateY(34px);\n    transition:\n      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),\n      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);\n    will-change: opacity, transform;\n  }\n\n  .sp-fit-animate.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .sp-fit-group.sp-fit-animate:nth-child(2) {\n    transition-delay: 0.12s;\n  }\n\n  .sp-fit-list__item {\n    opacity: 0;\n    transform: translateY(12px);\n    transition:\n      opacity 0.68s cubic-bezier(0.22, 1, 0.36, 1),\n      transform 0.68s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  .sp-fit-group.is-visible .sp-fit-list__item {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .sp-fit-group.is-visible .sp-fit-list__item:nth-child(1) { transition-delay: 0.08s; }\n  .sp-fit-group.is-visible .sp-fit-list__item:nth-child(2) { transition-delay: 0.14s; }\n  .sp-fit-group.is-visible .sp-fit-list__item:nth-child(3) { transition-delay: 0.20s; }\n  .sp-fit-group.is-visible .sp-fit-list__item:nth-child(4) { transition-delay: 0.26s; }\n  .sp-fit-group.is-visible .sp-fit-list__item:nth-child(5) { transition-delay: 0.32s; }\n\n  .sp-fit-lazy {\n    opacity: 0;\n    filter: blur(10px);\n    transform: scale(1.02);\n    transition:\n      opacity 0.7s ease,\n      filter 0.7s ease,\n      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  .sp-fit-lazy.is-loaded {\n    opacity: 1;\n    filter: blur(0);\n    transform: scale(1);\n  }\n\n  @media (hover: hover) {\n    .sp-fit-group {\n      transition:\n        opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),\n        transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),\n        border-color 0.35s ease,\n        background 0.35s ease;\n    }\n\n    .sp-fit-group:hover {\n      border-color: rgba(171, 140, 82, 0.48);\n      background: rgba(255, 255, 255, 0.05);\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .sp-fit-animate,\n    .sp-fit-list__item,\n    .sp-fit-lazy {\n      opacity: 1 !important;\n      transform: none !important;\n      filter: none !important;\n      transition: none !important;\n    }\n  }\n\n  /* ============================================================\n     Responsive\n  ============================================================ */\n\n  @media (max-width: 900px) {\n    .sp-fit__layout {\n      grid-template-columns: 1fr;\n    }\n\n    .sp-fit-group.sp-fit-animate:nth-child(2) {\n      transition-delay: 0s;\n    }\n  }\n\n  @media (max-width: 767px) {\n    #sp-fit-section {\n      padding: 52px 16px;\n    }\n\n    .sp-fit__head {\n      margin-bottom: 34px;\n      text-align: left;\n    }\n\n    .sp-fit__eyebrow {\n      justify-content: flex-start;\n      margin-bottom: 16px;\n    }\n\n    .sp-fit__eyebrow::before {\n      display: none;\n    }\n\n    .sp-fit__eyebrow::after {\n      width: 30px;\n    }\n\n    .sp-fit__lead {\n      line-height: 1.9;\n    }\n\n    .sp-fit-group {\n      padding: 22px 18px;\n      border-radius: 20px;\n    }\n\n    .sp-fit-group__title {\n      margin-bottom: 20px;\n      padding-bottom: 16px;\n    }\n\n    .sp-fit-list {\n      gap: 12px;\n    }\n\n    .sp-fit-list__item {\n      gap: 11px;\n    }\n\n    .sp-fit-list__icon {\n      margin-top: 0.32em;\n    }\n  }\n</style>\n\n<section id=\"sp-fit-section\">\n  <div class=\"sp-fit__inner\">\n    <div class=\"sp-fit__head sp-fit-animate\">\n      <p class=\"sp-fit__eyebrow\">Fit / Not Fit</p>\n      <p class=\"sp-fit__lead\">正直にお伝えします。Standardプランは、すべての企業に向いているわけではありません。</p>\n      <p class=\"sp-fit__lead\">複雑な基幹連携や越境対応の有無によっては、上位プランが適している場合もあります。どのプランが最適かは、無料相談で客観的に整理できます。</p>\n    </div>\n\n    <div class=\"sp-fit__layout\">\n      <article class=\"sp-fit-group sp-fit-group--fit sp-fit-animate\">\n        <h3 class=\"sp-fit-group__title\">向いているブランド・企業</h3>\n        <ul class=\"sp-fit-list\">\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--check\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">今のECサイトに限界を感じ始めている</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--check\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">ブランド表現や運用に物足りなさがある</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--check\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">Shopifyへの本格移行を検討している</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--check\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">リピート施策やLTV改善の土台を整えたい</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--check\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">SNSの世界観とECサイトのギャップを解消したい</span>\n          </li>\n        </ul>\n      </article>\n\n      <article class=\"sp-fit-group sp-fit-group--not sp-fit-animate\">\n        <h3 class=\"sp-fit-group__title\">いまは向いていない企業</h3>\n        <ul class=\"sp-fit-list\">\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--x\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">まだ売る商品がなく、低予算でまず始めたい</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--x\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">年商10億円を大きく超え、複雑な基幹連携が前提</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--x\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">Shopify移行や運用基盤の整備は不要</span>\n          </li>\n          <li class=\"sp-fit-list__item\">\n            <span class=\"sp-fit-list__icon sp-fit-list__icon--x\" aria-hidden=\"true\"></span>\n            <span class=\"sp-fit-list__text\">デザインだけを少し変えたい</span>\n          </li>\n        </ul>\n      </article>\n    </div>\n  </div>\n</section>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const prefersReducedMotion = window.matchMedia(\"(prefers-reduced-motion: reduce)\").matches;\n\n    const revealTargets = document.querySelectorAll(\"#sp-fit-section .sp-fit-animate\");\n\n    function revealImmediately(elements) {\n      elements.forEach(function (el) {\n        el.classList.add(\"is-visible\");\n      });\n    }\n\n    if (\"IntersectionObserver\" in window && !prefersReducedMotion) {\n      const revealObserver = new IntersectionObserver(function (entries, observer) {\n        entries.forEach(function (entry) {\n          if (entry.isIntersecting) {\n            entry.target.classList.add(\"is-visible\");\n            observer.unobserve(entry.target);\n          }\n        });\n      }, {\n        threshold: 0.16,\n        rootMargin: \"0px 0px -8% 0px\"\n      });\n\n      revealTargets.forEach(function (target) {\n        revealObserver.observe(target);\n      });\n    } else {\n      revealImmediately(revealTargets);\n    }\n\n    const lazyImages = document.querySelectorAll(\"#sp-fit-section img.sp-fit-lazy[data-src]\");\n\n    function loadLazyImage(img) {\n      const src = img.getAttribute(\"data-src\");\n\n      if (!src) return;\n\n      img.addEventListener(\"load\", function () {\n        img.classList.add(\"is-loaded\");\n      }, { once: true });\n\n      img.src = src;\n      img.removeAttribute(\"data-src\");\n    }\n\n    if (\"IntersectionObserver\" in window) {\n      const lazyObserver = new IntersectionObserver(function (entries, observer) {\n        entries.forEach(function (entry) {\n          if (entry.isIntersecting) {\n            loadLazyImage(entry.target);\n            observer.unobserve(entry.target);\n          }\n        });\n      }, {\n        rootMargin: \"300px 0px\",\n        threshold: 0.01\n      });\n\n      lazyImages.forEach(function (img) {\n        lazyObserver.observe(img);\n      });\n    } else {\n      lazyImages.forEach(loadLazyImage);\n    }\n  });\n</script>",
