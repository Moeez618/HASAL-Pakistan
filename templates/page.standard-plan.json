7;\n  }\n\n  .sp-checklist li::before {\n    content: '';\n    position: absolute;\n    left: 18px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 22px;\n    height: 22px;\n    border-radius: 50%;\n    background: var(--BTN-PRIMARY-BG);\n  }\n\n  .sp-checklist li::after {\n    content: '';\n    position: absolute;\n    left: 25px;\n    top: 50%;\n    width: 5px;\n    height: 9px;\n    border: solid var(--BTN-PRIMARY-TEXT);\n    border-width: 0 2px 2px 0;\n    transform: translateY(-62%) rotate(45deg);\n  }\n\n  .sp-checklist--grid {\n    max-width: 860px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px;\n  }\n\n  .sp-checklist--grid li {\n    margin-bottom: 0;\n  }\n\n  .sp-note {\n    max-width: 860px;\n    margin: 20px auto 0;\n    color: var(--COLOR-TEXT-A80);\n    line-height: 1.8;\n    font-size: 12px;\n    text-align: center;\n  }\n\n  .sp-grid2 {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n  }\n\n  .sp-card {\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 12px;\n    padding: 28px;\n    background: var(--COLOR-TEXT-A5);\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-card h3 {\n    margin: 0 0 16px;\n    line-height: 1.5;\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-price {\n    display: block;\n    color: #AB8C52;\n    margin: 0 0 18px;\n  }\n\n  .sp-card ul {\n    margin: 0 0 18px;\n    padding-left: 1.2em;\n    line-height: 1.9;\n  }\n\n  .sp-card .sp-sub {\n    display: block;\n    margin: 18px 0 6px;\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-card p {\n    margin: 0 0 6px;\n    line-height: 1.8;\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-card p:not(.sp-sub):not(.sp-price) {\n    font-size: 12px;\n  }\n\n  .sp-card--feature {\n    position: relative;\n    overflow: hidden;\n    border-color: #AB8C52;\n    background-color: #0D0326;\n    isolation: isolate;\n  }\n\n  .sp-card--feature::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    z-index: -1;\n    background: linear-gradient(\n      180deg,\n      rgba(13, 3, 38, 0.55),\n      rgba(13, 3, 38, 0.78)\n    );\n    pointer-events: none;\n  }\n\n  .sp-card__bg {\n    position: absolute;\n    inset: 0;\n    z-index: -2;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center;\n    pointer-events: none;\n  }\n\n  .sp-card--feature h3 {\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-card--feature .sp-price,\n  .sp-card--feature .sp-price strong,\n  .sp-card--feature ul,\n  .sp-card--feature li {\n    color: #fff;\n  }\n\n  .sp-card--feature li::marker {\n    color: #fff;\n  }\n\n  .sp-flow {\n    max-width: 720px;\n    margin: 0 auto;\n  }\n\n  .sp-flow__item {\n    display: flex;\n    gap: 22px;\n    align-items: baseline;\n    padding: 24px 0;\n    border-top: 1px solid var(--COLOR-TEXT-A35);\n  }\n\n  .sp-flow__item:last-child {\n    border-bottom: 1px solid var(--COLOR-TEXT-A35);\n  }\n\n  .sp-flow__no {\n    flex: 0 0 auto;\n    min-width: 2ch;\n    color: #AB8C52;\n    line-height: 1.4;\n  }\n\n  .sp-flow__body {\n    flex: 1;\n  }\n\n  .sp-flow__title {\n    margin: 0 0 6px;\n    line-height: 1.5;\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-flow__desc {\n    margin: 0;\n    line-height: 1.8;\n    color: var(--COLOR-TEXT-A80);\n    font-size: 12px;\n  }\n\n  @media (max-width: 760px) {\n    .sp-sec {\n      padding: 48px 16px;\n    }\n\n    .sp-grid2 {\n      grid-template-columns: 1fr;\n    }\n\n    .sp-checklist--grid {\n      grid-template-columns: 1fr;\n    }\n\n    .sp-table th,\n    .sp-table td {\n      padding: 12px;\n    }\n\n    .sp-flow__item {\n      gap: 16px;\n    }\n  }\n</style>\n\n<section class=\"sp-sec\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Offer</p>\n      <h2 class=\"sp-title\">単なるリニューアルではなく、<br>ブランドの成長を支えるEC基盤づくりです。</h2>\n      <p class=\"sp-lead\">移行設計や公開前テストも含め、公開後の運用を見据えたEC基盤づくりを行います。<br>あとから費用が膨らまないよう、対応範囲や別途費用まで事前に整理してお伝えします。</p>\n    </div>\n\n    <div class=\"sp-grid2\">\n      <div class=\"sp-card sp-card--feature\">\n        <img\n          class=\"sp-card__bg\"\n          src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/ChatGPT_Image_2026_6_15_19_13_06.png?v=1781518396\"\n          alt=\"\"\n          loading=\"lazy\"\n          decoding=\"async\"\n          width=\"1200\"\n          height=\"1800\"\n          aria-hidden=\"true\"\n        >\n\n        <h3>Standardプラン</h3>\n        <p class=\"sp-price\"><strong>2,200,000円（税込）から</strong></p>\n        <ul>\n          <li>納期：約8〜12週間</li>\n          <li>商品ページ100点まで登録・移行対応</li>\n          <li>コレクション20点まで</li>\n          <li>主要ページ20ページまで</li>\n          <li>アプリ連携6点まで</li>\n          <li>打ち合わせ5回</li>\n          <li>修正対応3回まで</li>\n        </ul>\n        <a class=\"btn btn--solid btn--primary\" href=\"/pages/contact\"><span>移行範囲と概算費用を無料で確認する</span></a>\n      </div>\n\n      <div class=\"sp-card\">\n        <p class=\"sp-sub\"><strong>制作体制</strong></p>\n        <p>ディレクター1名、エンジニア2名を中心とした制作体制</p>\n\n        <p class=\"sp-sub\"><strong>お客様にご準備いただくもの</strong></p>\n        <p>キービジュアル、商品情報、画像素材、ドメイン、各ページ原稿</p>\n\n        <p class=\"sp-sub\"><strong>別途発生する費用</strong></p>\n        <p>Shopify月額、決済手数料、一部アプリ利用料、保守運用、追加開発、越境対応、外部・POS連携、大量URLの301リダイレクト設計・設定、詳細なSEO設計など</p>\n\n        <p class=\"sp-sub\"><strong>対象外</strong></p>\n        <p>Shopifyアプリそのものの独自開発</p>\n      </div>\n    </div>\n  </div>\n</section>",
