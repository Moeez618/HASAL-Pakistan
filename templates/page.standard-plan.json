      "name": "Brand Concept",
      "settings": {
        "code": "<style>\n  /* ============================================================\n     0. フェードイン・アニメーション用のスタイル (共通追加)\n  ============================================================ */\n  .js-fade-in {\n    opacity: 0;\n    transform: translateY(40px);\n    transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n  }\n\n  .js-fade-in.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* ============================================================\n     1. コンセプト設計セクション (背景: Color scheme 1 surface)\n  ============================================================ */\n  #se-concept-section {\n    width: 100%;\n    margin: 0;\n    padding: 0 40px 20px; /* 上の余白を削除 */\n    box-sizing: border-box;\n    overflow: hidden;\n    background-color: #0D0326;\n  }\n\n  #se-concept-section * { box-sizing: border-box; }\n\n  .se-container {\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  /* 見出し位置の微調整（余白削除に伴う調整） */\n  .se-heading-wrapper {\n    text-align: center;\n    margin-bottom: 60px;\n    max-width: 800px;\n    margin-left: auto;\n    margin-right: auto;\n    padding-top: 60px; /* コンテンツとしての適切な間隔は維持 */\n  }\n\n  .se-section-title {\n    margin-bottom: 20px;\n    position: relative;\n    display: inline-block;\n    font-size: var(--font-body-medium);\n    font-weight: 800;\n    color: var(--COLOR-TEXT);\n  }\n\n  .se-lead-text {\n    text-align: left;\n    font-size: var(--font-body-medium);\n    line-height: 1.8;\n    color: var(--COLOR-TEXT-A80);\n  }\n\n  .se-layout-wrapper {\n    display: flex;\n    flex-direction: column;\n    gap: 80px;\n  }\n\n  .se-card {\n    display: flex;\n    flex-direction: column;\n    position: relative;\n  }\n\n  .se-card-figure {\n    width: 100%;\n    position: relative;\n    overflow: hidden;\n    aspect-ratio: 16 / 9;\n    border-radius: 12px;\n  }\n\n  .se-card-figure img {\n    width: 100%;\n    height: 100%;\n    display: block;\n    object-fit: cover;\n  }\n\n  .se-card-body {\n    padding: 30px 0;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .se-card-header { margin-bottom: 16px; }\n  .se-card-title { margin: 0; font-size: var(--font-body-medium); font-weight: 700; color: var(--COLOR-TEXT); }\n  .se-card-title span.en-prefix {\n    display: block;\n    margin-bottom: 4px;\n    color: #AB8C52;\n    font-size: var(--font-body-medium);\n    text-transform: uppercase;\n  }\n\n  .se-card-desc { margin-bottom: 24px; font-size: var(--font-body-medium); color: var(--COLOR-TEXT-A80); font-weight: 500; }\n\n  .se-content-block { margin-bottom: 20px; }\n  \n  .se-label {\n    display: flex;\n    align-items: center;\n    margin-bottom: 10px;\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n  }\n\n  .se-label-hearing::before,\n  .se-label-reflect::before {\n    display: inline-flex;\n    justify-content: center;\n    align-items: center;\n    width: 28px;\n    height: 28px;\n    margin-right: 10px;\n    flex-shrink: 0;\n    font-weight: bold;\n    border-radius: 50%;\n  }\n\n  .se-label-hearing::before { content: 'Q'; background: transparent; color: var(--COLOR-TEXT-A80); border: 1.5px solid var(--COLOR-TEXT-A35); }\n  .se-label-reflect::before { content: 'A'; background: #AB8C52; color: var(--BTN-PRIMARY-TEXT); border: 1.5px solid #AB8C52; }\n  .se-label-hearing { color: var(--COLOR-TEXT); }\n  .se-label-reflect { color: #AB8C52; }\n\n  .se-text-box {\n    padding: 16px 20px;\n    background: var(--COLOR-TEXT-A5);\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 12px;\n    color: var(--COLOR-TEXT);\n    font-size: var(--font-body-medium);\n    line-height: 1.7;\n  }\n\n  .se-text-box.is-reflect {\n    background: rgba(171, 140, 82, 0.12);\n    border: 1px solid #AB8C52;\n    border-left: 4px solid #AB8C52;\n    color: var(--COLOR-TEXT);\n  }\n\n  .se-text-box ul { margin: 0; padding-left: 20px; }\n  .se-text-box li { margin-bottom: 6px; }\n\n  /* Concept Animation Styles (既存のスライドインアニメーションを保持) */\n  .se-card .se-card-figure,\n  .se-card .se-card-body {\n    opacity: 0;\n    transition: opacity 1.0s ease-out, transform 1.0s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .se-card .se-card-figure { transform: translateY(30px); }\n  .se-card .se-card-body { transform: translateY(30px); transition-delay: 0.2s; }\n\n  @media (min-width: 768px) {\n    .se-lead-text { text-align: center; }\n    .se-card { flex-direction: row; align-items: center; gap: 60px; }\n    .se-card-figure, .se-card-body { width: 50%; padding: 0; margin: 0; }\n    .se-card:nth-child(even) { flex-direction: row-reverse; }\n    \n    .se-card:nth-child(odd) .se-card-figure { transform: translateX(-60px); }\n    .se-card:nth-child(odd) .se-card-body { transform: translateX(60px); }\n    .se-card:nth-child(even) .se-card-figure { transform: translateX(60px); }\n    .se-card:nth-child(even) .se-card-body { transform: translateX(-60px); }\n  }\n\n  .se-card.is-visible .se-card-figure,\n  .se-card.is-visible .se-card-body {\n    opacity: 1;\n    transform: translate(0, 0);\n  }\n\n  /* ============================================================\n     2. 構築実績セクション (背景: Color scheme 1 accent background)\n  ============================================================ */\n  .solstar-testimonial {\n    padding: 40px 20px 0; /* 下の余白を削除 */\n    background-color: #0D0326;\n    color: var(--COLOR-TEXT);\n    box-sizing: border-box;\n  }\n\n  .solstar-testimonial-inner {\n    max-width: 1000px;\n    margin: 0 auto;\n    padding-bottom: 80px; /* カードの影を収めるための内側余白 */\n  }\n\n  .solstar-heading-wrapper {\n    text-align: center;\n    max-width: 800px;\n    margin: 0 auto 48px;\n  }\n\n  .solstar-heading {\n    font-size: var(--font-body-medium);\n    font-weight: 800;\n    color: var(--COLOR-TEXT);\n    margin-top: 0;\n    margin-bottom: 16px;\n  }\n\n  .solstar-sub-heading {\n    font-size: var(--font-body-medium);\n    color: var(--COLOR-TEXT-A80);\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .solstar-testimonial-card {\n    background: var(--COLOR-TEXT-A5);\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 12px;\n    padding: 40px;\n    box-shadow: 0 16px 40px var(--COLOR-TEXT-A5);\n    display: flex;\n    flex-direction: row;\n    gap: 40px;\n    height: 480px; \n    box-sizing: border-box;\n    overflow: hidden;\n  }\n\n  .solstar-col-img {\n    flex: 0 0 40%;\n    position: relative;\n    display: flex;\n    align-items: flex-start;\n    height: 100%;\n  }\n\n  .solstar-img-frame {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    border-radius: 12px;\n    overflow: hidden;\n    max-height: 100%; \n  }\n\n  .solstar-img-frame img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    transition: opacity 0.3s ease;\n  }\n\n  .solstar-col-text {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    text-align: left;\n    height: 100%;\n    padding-top: 10px;\n    box-sizing: border-box;\n  }\n\n  .solstar-label {\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    color: #AB8C52;\n    margin-bottom: 24px;\n    display: block;\n    flex-shrink: 0;\n  }\n\n  .solstar-content-body {\n    flex-grow: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-start;\n    overflow: hidden;\n  }\n\n  .solstar-quote-heading {\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    line-height: 1.4;\n    color: var(--COLOR-TEXT);\n    margin-bottom: 20px;\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .solstar-body-text {\n    font-size: var(--font-body-medium);\n    line-height: 1.7;\n    color: var(--COLOR-TEXT-A80);\n    display: -webkit-box;\n    -webkit-line-clamp: 4;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .solstar-divider {\n    width: 100%;\n    height: 1px;\n    background: var(--COLOR-TEXT-A35);\n    margin-bottom: 24px;\n    margin-top: 24px;\n    flex-shrink: 0;\n  }\n\n  .solstar-footer {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    flex-shrink: 0;\n  }\n\n  .solstar-author-name { font-size: var(--font-body-medium); font-weight: 700; color: var(--COLOR-TEXT); margin-bottom: 4px; }\n  .solstar-author-role { font-size: var(--font-body-medium); color: var(--COLOR-TEXT-A80); }\n\n  .solstar-nav-buttons { display: flex; gap: 12px; }\n  .solstar-btn-arrow {\n    width: 44px;\n    height: 44px;\n    border-radius: var(--btn-radius);\n    border: 1px solid var(--BTN-PRIMARY-BORDER);\n    background: var(--BTN-PRIMARY-BG);\n    color: var(--BTN-PRIMARY-TEXT);\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.2s ease;\n  }\n  .solstar-btn-arrow:hover { background: var(--BTN-PRIMARY-BG-BRIGHTER); border-color: var(--BTN-PRIMARY-BG-BRIGHTER); color: var(--BTN-PRIMARY-TEXT); }\n\n  .solstar-anim-fade { animation: solstarFadeIn 0.4s ease-out forwards; }\n  @keyframes solstarFadeIn {\n    from { opacity: 0; transform: translateY(5px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  @media (max-width: 768px) {\n    .solstar-testimonial { padding: 40px 20px 0; }\n    .solstar-heading { font-size: var(--font-body-medium); }\n    .solstar-testimonial-card { flex-direction: column; padding: 24px; height: auto; min-height: 550px; }\n    .solstar-col-img { width: 100%; height: auto; }\n    .solstar-quote-heading { font-size: var(--font-body-medium); }\n  }\n\n  /* Theme typography overrides */\n\n  #se-concept-section,\n  .solstar-testimonial {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .se-card-title span.en-prefix,\n  .solstar-label {\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n  .se-section-title,\n  .se-card-title,\n  .solstar-heading,\n  .solstar-quote-heading {\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n  .se-section-title,\n  .solstar-heading { font-size: var(--font-heading-large); }\n  .se-card-title,\n  .solstar-quote-heading { font-size: var(--font-heading-medium); }\n  .se-lead-text,\n  .solstar-sub-heading { font-size: var(--font-body-medium); }\n  .se-card-desc,\n  .se-label,\n  .se-text-box,\n  .solstar-body-text,\n  .solstar-author-name,\n  .solstar-author-role {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .se-card-desc,\n  .se-text-box,\n  .solstar-body-text { font-size: var(--font-body-small); }\n  .se-label,\n  .solstar-author-role { font-size: var(--font-body-x-small); }\n  /* End theme typography overrides */\n</style>\n\n<section id=\"se-concept-section\">\n  <div class=\"se-container\">\n    <div class=\"se-heading-wrapper js-fade-in\">\n      <h2 class=\"se-section-title\">ブランドの魅力を伝えるECコンセプト設計</h2>\n      <p class=\"se-lead-text\">\n        ECサイトは、単なる「商品を並べる場所」ではありません。私たちはECサイト構築の前に、お客様の中にすでにあるブランドの想いや価値を整理し、サイト上でどう表現するかというコンセプト定義を徹底的に行います。<br>\n        最短2〜4週間という短期間で、ブランドの魅力が正しく伝わり、ファンを育てていけるECサイトを立ち上げるために、最も重要で欠かせないプロセスです。\n      </p>\n    </div>\n\n    <div class=\"se-layout-wrapper\">\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Persona.png?v=1771391011\" alt=\"ECコンセプト設計：ペルソナ整理のイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">Who</span>誰の心を動かしたいのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">ターゲットの表面的な属性だけでなく、その奥にある「感情」や「価値観」を捉えます。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>その商品はどんな人の悩みを解決するのですか？</li>\n                <li>ターゲットとなる方の年齢層や、日常の過ごし方、ライフスタイルは？</li>\n                <li>その人は普段どのような価値に共感してブランドを選びますか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              属性だけでなく価値観まで掘り下げて定義。感性に合わせた言葉選び、ビジュアル、情報設計を通じて、ブランドらしさが直感的に伝わる体験をつくります。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Branding_Image_copy.webp?v=1771390960\" alt=\"ECコンセプト設計：選ばれる理由を言語化するイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">What</span>そのブランドは何故選ばれるのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">市場における立ち位置を整理し、他にはない「選ばれる理由」を言語化します。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>巨大モールではなく、あえて自社サイトで購入してもらう理由は？</li>\n                <li>競合商品と比較されたとき、あなたの商品が選ばれる理由は？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              市場での優位性を特定し、商品を手にしたお客様の未来（ベネフィット）を言語化。オリジナルテーマ「CREAM」の標準機能を活かし、迷わず購入できる体験を設計します。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Bag_Value.png?v=1771391059\" alt=\"ECコンセプト設計：ブランド価値を可視化するイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">Why</span>なぜそのブランドが必要なのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">ブランドに込めた「想い」を可視化し、共感によって選ばれるブランドへ導きます。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>なぜ、この商品を世に送り出そうと思ったのですか？</li>\n                <li>ブランドを通じて、どのような価値や理想の未来を実現したいですか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              創業ストーリーや想いを「ブランド紹介（About Us）」として形にし、信頼を獲得。価格競争に巻き込まれない、共感を軸にしたブランド基盤を構築します。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Store_design.png?v=1771391032\" alt=\"ECコンセプト設計：ブランドの世界観とUIデザインのイメージ\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">How</span>どう見え、どう感じられたいか？</h3>\n          </div>\n          <p class=\"se-card-desc\">一貫したトーンで、ひと目で「このブランドらしい」と感じられる体験をつくります。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>ブランドの世界観として、大切にしたい雰囲気や印象はありますか？</li>\n                <li>ブランドカラーや、取り入れたいデザイン・表現はありますか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              デザインシステムを活用し、配色・フォント・配置を統一。Shopify認定資格を持つプロによるUI/UX設計で、ユーザーへの印象を丁寧に設計し信頼感を高めます。\n            </div>\n          </div>\n        </div>\n      </article>\n    </div>\n  </div>\n</section>\n\n<div class=\"solstar-testimonial\">\n  <div class=\"solstar-testimonial-inner\">\n    <div class=\"solstar-heading-wrapper js-fade-in\">\n      <h2 class=\"solstar-heading\">ECサイト構築実績</h2>\n      <p class=\"solstar-sub-heading\">立ち上げ初期でも成果に繋がった事例を一部ご紹介致します。</p>\n    </div>\n\n    <div class=\"solstar-testimonial-card js-fade-in\">\n      <div class=\"solstar-col-img\">\n        <div class=\"solstar-img-frame\">\n          <img id=\"solstar-img\" src=\"\" alt=\"Shopify ECサイト構築のお客様事例イメージ\" loading=\"lazy\">\n        </div>\n      </div>\n      <div class=\"solstar-col-text\">\n        <span class=\"solstar-label\">お客様の声</span>\n        <div class=\"solstar-content-body\" id=\"solstar-anim-wrapper\">\n            <div class=\"solstar-quote-heading\" id=\"solstar-quote\"></div>\n            <div class=\"solstar-body-text\" id=\"solstar-body\"></div>\n        </div>\n        <div class=\"solstar-divider\"></div>\n        <div class=\"solstar-footer\">\n          <div class=\"solstar-author-info\">\n            <div class=\"solstar-author-name\" id=\"solstar-title\"></div>\n            <div class=\"solstar-author-role\" id=\"solstar-sub\"></div>\n          </div>\n          <div class=\"solstar-nav-buttons\">\n            <button type=\"button\" class=\"solstar-btn-arrow\" id=\"btn-prev\" aria-label=\"Previous\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg>\n            </button>\n            <button type=\"button\" class=\"solstar-btn-arrow\" id=\"btn-next\" aria-label=\"Next\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  /* Intersection Observer for Concept Section & Fade-in Animations */\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    const observer = new IntersectionObserver((entries, observer) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.15 }); // 15%表示されたら発火に調整\n\n    // 元々の左右スライド用カードを監視\n    document.querySelectorAll('.se-card').forEach(card => observer.observe(card));\n    // 今回追加した上部見出し・実績カードを監視\n    document.querySelectorAll('.js-fade-in').forEach(el => observer.observe(el));\n  });\n\n  /* Testimonial Data & Logic */\n  (function () {\n    const data = [\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_5.webp?v=1766473796\",\n        title: \"合同会社Rsworks\",\n        sub: \"キッチンブランド\",\n        body: \"ブランドの世界観と高級感を保ったECサイトを構築。キャンペーンではLINE登録単価30円、登録者2,306人を達成。\",\n        quote: \"洗練されたクリエイティブセンスで一目置くECサイトを構築していただき、とても満足しています。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_3.webp?v=1766473796\",\n        title: \"PAW MINT\",\n        sub: \"ペットブランド\",\n        body: \"ブランドの世界観をポップに表現したLPを制作。広告施策により2,000名以上のメルマガ登録獲得。\",\n        quote: \"可愛くポップなECサイトを作って頂きました。世界観の表現が素晴らしいです。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_2.webp?v=1766473796\",\n        title: \"株式会社EDGBLACK\",\n        sub: \"キッチンブランド\",\n        body: \"Shopify移行後、公開初月に27万円以上の売上を実現。\",\n        quote: \"とても丁寧かつ詳細に説明してくださったので、困ることは一切ありませんでした。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_1.webp?v=1766473795\",\n        title: \"株式会社ONETREE\",\n        sub: \"スニーカーブランド\",\n        body: \"公式ECサイトを約2か月で立ち上げ、公開初月に12万円以上の売上を達成されました。Shopifyを活用し、ブランドの認知拡大とファンづくりを進められています。\",\n        quote: \"調整にも柔軟に対応してもらえ、安心して任せられました。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_4.webp?v=1766473796\",\n        title: \"SANDY HAZE\",\n        sub: \"水着ブランド\",\n        body: \"英語圏向け越境ECを構築。商品撮影から広告運用まで対応し、3ヶ月で月商100万円を達成。\",\n        quote: \"They made our first e-commerce site look amazing.\"\n      }\n    ];\n\n    let index = 0;\n    const imgEl = document.getElementById(\"solstar-img\");\n    const quoteEl = document.getElementById(\"solstar-quote\");\n    const bodyEl = document.getElementById(\"solstar-body\");\n    const titleEl = document.getElementById(\"solstar-title\");\n    const subEl = document.getElementById(\"solstar-sub\");\n    const animWrapper = document.getElementById(\"solstar-anim-wrapper\");\n\n    function render(i) {\n      const d = data[i];\n      imgEl.style.opacity = 0;\n      animWrapper.classList.remove('solstar-anim-fade');\n      void animWrapper.offsetWidth; \n      animWrapper.classList.add('solstar-anim-fade');\n\n      setTimeout(() => {\n          imgEl.src = d.img;\n          imgEl.onload = () => { imgEl.style.opacity = 1; };\n          quoteEl.textContent = d.quote; \n          bodyEl.textContent = d.body;\n          titleEl.textContent = d.title;\n          subEl.textContent = d.sub;\n      }, 100);\n    }\n\n    document.getElementById(\"btn-next\").addEventListener(\"click\", () => {\n      index = (index + 1) % data.length;\n      render(index);\n    });\n\n    document.getElementById(\"btn-prev\").addEventListener(\"click\", () => {\n      index = (index - 1 + data.length) % data.length;\n      render(index);\n    });\n\n    render(index);\n  })();\n</script>\n<style>\n/* BRAND CONCEPT REFINED */\n#se-concept-section { padding: 72px 40px; }\n#se-concept-section .se-heading-wrapper { padding-top: 0; margin-bottom: 72px; }\n#se-concept-section .se-heading-wrapper::before { content: 'Brand Concept'; display: block; margin-bottom: 14px; color: #AB8C52; font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); text-transform: var(--FONT-UPPERCASE-SUBHEADING); }\n#se-concept-section .se-section-title { position: relative; }\n#se-concept-section .se-section-title::after { content: ''; display: block; width: 48px; height: 3px; margin: 20px auto 0; background: #AB8C52; border-radius: 2px; }\n#se-concept-section .se-lead-text { text-align: center; }\n#se-concept-section .se-layout-wrapper { gap: 72px; }\n#se-concept-section .se-card-figure { border: 1px solid var(--COLOR-TEXT-A35); box-shadow: 0 18px 44px rgba(0,0,0,0.30); }\n#se-concept-section .se-card-figure img { transition: transform 0.6s cubic-bezier(0.22,1,0.36,1); }\n#se-concept-section .se-card:hover .se-card-figure img { transform: scale(1.05); }\n#se-concept-section .se-card-title span.en-prefix { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; color: #AB8C52; font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); text-transform: var(--FONT-UPPERCASE-SUBHEADING); }\n#se-concept-section .se-card-title span.en-prefix::before { content: ''; display: inline-block; width: 28px; height: 2px; background: #AB8C52; flex: 0 0 auto; }\n#se-concept-section .se-card-desc { padding-bottom: 22px; margin-bottom: 24px; border-bottom: 1px solid var(--COLOR-TEXT-A35); }\n#se-concept-section .se-label-hearing { color: var(--COLOR-TEXT-A80); }\n#se-concept-section .se-label-reflect { color: #AB8C52; }\n@media (min-width: 768px) {\n  #se-concept-section .se-card { gap: 56px; align-items: center; }\n  #se-concept-section .se-card-body { padding: 8px 0; }\n}\n@media (max-width: 767px) {\n  #se-concept-section { padding: 48px 20px; }\n  #se-concept-section .se-heading-wrapper { margin-bottom: 40px; }\n  #se-concept-section .se-layout-wrapper { gap: 34px; }\n  #se-concept-section .se-card-body { padding: 14px 0; }\n  #se-concept-section .se-content-block { margin-bottom: 12px; }\n}\n</style>",
        "width": "wrapper--full",
        "color_scheme": "scheme-10",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "contents": {
      "type": "section-custom-code",
      "custom_css": [
        ".hero__subheading {color: #ab8c52;}"
      ],
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .sp-sec {\n    background: var(--COLOR-BG);\n    color: var(--COLOR-TEXT);\n    padding: 64px 20px;\n    font-size: 14px;\n    content-visibility: auto;\n    contain-intrinsic-size: 900px;\n  }\n\n  .sp-sec * {\n    box-sizing: border-box;\n  }\n\n  .sp-inner {\n    max-width: 1040px;\n    margin: 0 auto;\n  }\n\n  .sp-head {\n    max-width: 820px;\n    margin: 0 auto 36px;\n    text-align: center;\n  }\n\n  .sp-eyebrow {\n    display: block;\n    margin: 0 0 12px;\n    color: #AB8C52;\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n\n  .sp-title {\n    margin: 0 0 16px;\n    line-height: 1.4;\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-lead {\n    margin: 0;\n    line-height: 1.9;\n    color: var(--COLOR-TEXT-A80);\n    font-size: 14px;\n  }\n\n  .sp-scope-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 18px;\n    align-items: stretch;\n  }\n\n  .sp-scope-card {\n    position: relative;\n    display: grid;\n    grid-template-rows: auto 1fr auto;\n    min-height: 100%;\n    padding: 26px;\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 16px;\n    background: var(--COLOR-TEXT-A5);\n    color: var(--COLOR-TEXT);\n    overflow: hidden;\n  }\n\n  .sp-scope-card::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(135deg, rgba(171, 140, 82, 0.14), transparent 42%);\n    pointer-events: none;\n  }\n\n  .sp-scope-card::after {\n    content: '';\n    position: absolute;\n    left: 24px;\n    right: 24px;\n    top: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(171, 140, 82, 0.9), transparent);\n    opacity: 0;\n    transform: scaleX(0.4);\n    transform-origin: center;\n    transition: opacity 900ms ease, transform 900ms cubic-bezier(0.22, 1, 0.36, 1);\n    pointer-events: none;\n  }\n\n  .sp-sec.is-visible .sp-scope-card::after {\n    opacity: 1;\n    transform: scaleX(1);\n  }\n\n  .sp-scope-top {\n    position: relative;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin: 0 0 18px;\n  }\n\n  .sp-scope-no {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    flex: 0 0 auto;\n    width: 38px;\n    height: 38px;\n    border-radius: 50%;\n    background: var(--BTN-PRIMARY-BG);\n    color: var(--BTN-PRIMARY-TEXT);\n    font-size: 14px;\n    line-height: 1;\n  }\n\n  .sp-scope-title {\n    margin: 0;\n    line-height: 1.5;\n    color: var(--COLOR-TEXT);\n  }\n\n  .sp-scope-desc {\n    position: relative;\n    margin: 0 0 20px;\n    line-height: 1.9;\n    color: var(--COLOR-TEXT-A80);\n    font-size: 14px;\n  }\n\n  .sp-scope-points {\n    position: relative;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 8px;\n    margin: 0;\n    padding: 0;\n    list-style: none;\n  }\n\n  .sp-scope-points li {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 42px;\n    padding: 8px 11px;\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 999px;\n    background: var(--COLOR-BG);\n    color: var(--COLOR-TEXT);\n    font-size: 12px;\n    line-height: 1.45;\n    text-align: center;\n  }\n\n  .sp-scope-highlight {\n    color: #AB8C52;\n  }\n\n  .sp-scope-summary {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px;\n    margin: 22px 0 0;\n  }\n\n  .sp-scope-summary__item {\n    padding: 18px 16px;\n    border: 1px solid var(--COLOR-TEXT-A35);\n    border-radius: 14px;\n    background: var(--COLOR-TEXT-A5);\n    text-align: center;\n  }\n\n  .sp-scope-summary__num {\n    display: block;\n    margin: 0 0 6px;\n    color: #AB8C52;\n    font-weight: 700;\n    line-height: 1.2;\n  }\n\n  .sp-scope-summary__label {\n    display: block;\n    color: var(--COLOR-TEXT-A80);\n    font-size: 14px;\n    font-weight: 700;\n    line-height: 1.6;\n  }\n\n  .sp-note {\n    max-width: 860px;\n    margin: 20px auto 0;\n    color: var(--COLOR-TEXT-A80);\n    line-height: 1.8;\n    font-size: 14px;\n    text-align: center;\n  }\n\n  .sp-animate {\n    opacity: 0;\n    transform: translate3d(0, 22px, 0) scale(0.985);\n    filter: blur(8px);\n    transition:\n      opacity 780ms ease,\n      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),\n      filter 900ms ease;\n    will-change: opacity, transform, filter;\n  }\n\n  .sp-sec.is-visible .sp-animate {\n    opacity: 1;\n    transform: translate3d(0, 0, 0) scale(1);\n    filter: blur(0);\n  }\n\n  .sp-sec.is-visible .sp-head.sp-animate {\n    transition-delay: 80ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-card:nth-child(1) {\n    transition-delay: 160ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-card:nth-child(2) {\n    transition-delay: 230ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-card:nth-child(3) {\n    transition-delay: 300ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-card:nth-child(4) {\n    transition-delay: 370ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-card:nth-child(5) {\n    transition-delay: 440ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-card:nth-child(6) {\n    transition-delay: 510ms;\n  }\n\n  .sp-sec.is-visible .sp-scope-summary.sp-animate {\n    transition-delay: 620ms;\n  }\n\n  .sp-sec.is-visible .sp-note.sp-animate {\n    transition-delay: 720ms;\n  }\n\n  @media (hover: hover) {\n    .sp-scope-card {\n      transition:\n        border-color 300ms ease,\n        transform 300ms ease,\n        background 300ms ease;\n    }\n\n    .sp-scope-card:hover {\n      transform: translateY(-4px);\n      border-color: rgba(171, 140, 82, 0.7);\n      background: var(--COLOR-TEXT-A5);\n    }\n  }\n\n  @media (max-width: 980px) {\n    .sp-scope-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n\n    .sp-scope-summary {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 760px) {\n    .sp-sec {\n      padding: 48px 16px;\n      contain-intrinsic-size: 1200px;\n    }\n\n    .sp-head {\n      margin-bottom: 28px;\n      text-align: left;\n    }\n\n    .sp-scope-grid {\n      grid-template-columns: 1fr;\n      gap: 14px;\n    }\n\n    .sp-scope-card {\n      padding: 22px;\n      border-radius: 14px;\n    }\n\n    .sp-scope-points {\n      grid-template-columns: 1fr;\n    }\n\n    .sp-scope-summary {\n      grid-template-columns: 1fr 1fr;\n      gap: 10px;\n    }\n\n    .sp-scope-summary__item {\n      padding: 16px 12px;\n    }\n\n    .sp-sec.is-visible .sp-scope-card:nth-child(n),\n    .sp-sec.is-visible .sp-scope-summary.sp-animate,\n    .sp-sec.is-visible .sp-note.sp-animate {\n      transition-delay: 120ms;\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .sp-animate,\n    .sp-scope-card,\n    .sp-scope-card::after {\n      opacity: 1;\n      transform: none;\n      filter: none;\n      transition: none;\n      animation: none;\n    }\n  }\n</style>\n\n<section class=\"sp-sec\" data-sp-lazy-section>\n  <div class=\"sp-inner\">\n    <div class=\"sp-head sp-animate\">\n      <span class=\"sp-eyebrow\">Contents</span>\n      <h2 class=\"sp-title\">Shopify移行・リニューアルで対応する主な内容</h2>\n      <p class=\"sp-lead\">\n        デザイン制作だけでなく、Shopify移行や運用基盤づくりまで含むプランです。\n        主な内容は次のとおりです。\n      </p>\n    </div>\n\n    <div class=\"sp-scope-grid\">\n      <article class=\"sp-scope-card sp-animate\">\n        <div class=\"sp-scope-top\">\n          <span class=\"sp-scope-no\">01</span>\n          <h3 class=\"sp-scope-title\">要件整理</h3>\n        </div>\n        <p class=\"sp-scope-desc\">\n          ブランドの方向性・商品構成・購入導線・必要機能を整理。\n          Shopifyの基本設定もあわせて設計します。\n        </p>\n        <ul class=\"sp-scope-points\">\n          <li>ブランド方針</li>\n          <li>商品構成</li>\n          <li>購入導線</li>\n          <li>基本設定</li>\n        </ul>\n      </article>\n\n      <article class=\"sp-scope-card sp-animate\">\n        <div class=\"sp-scope-top\">\n          <span class=\"sp-scope-no\">02</span>\n          <h3 class=\"sp-scope-title\">デザイン調整</h3>\n        </div>\n        <p class=\"sp-scope-desc\">\n          ブランドの世界観に合わせて、ページ・テンプレート・ビジュアルを調整。\n          販売導線に必要な制作物も整えます。\n        </p>\n        <ul class=\"sp-scope-points\">\n          <li>ページ制作</li>\n          <li>複数テンプレート</li>\n          <li>デザイン調整</li>\n          <li>バナー制作</li>\n        </ul>\n      </article>\n\n      <article class=\"sp-scope-card sp-animate\">\n        <div class=\"sp-scope-top\">\n          <span class=\"sp-scope-no\">03</span>\n          <h3 class=\"sp-scope-title\">商品登録・移行</h3>\n        </div>\n        <p class=\"sp-scope-desc\">\n          商品名・価格・説明文・画像・在庫などを整理して移行。\n          回遊しやすいカテゴリー設計も行います。\n        </p>\n        <ul class=\"sp-scope-points\">\n          <li>商品100点まで</li>\n          <li>情報整理</li>\n          <li>画像整理</li>\n          <li>コレクション登録</li>\n        </ul>\n      </article>\n\n      <article class=\"sp-scope-card sp-animate\">\n        <div class=\"sp-scope-top\">\n          <span class=\"sp-scope-no\">04</span>\n          <h3 class=\"sp-scope-title\">ページ移行</h3>\n        </div>\n        <p class=\"sp-scope-desc\">\n          About、FAQ、送料、返品、特定商取引法に基づく表記など、\n          主要な固定ページを移行・整備します。\n        </p>\n        <ul class=\"sp-scope-points\">\n          <li>ブログ・News</li>\n          <li>About・FAQ</li>\n          <li>送料・返品</li>\n          <li>特商法表記</li>\n        </ul>\n      </article>\n\n      <article class=\"sp-scope-card sp-animate\">\n        <div class=\"sp-scope-top\">\n          <span class=\"sp-scope-no\">05</span>\n          <h3 class=\"sp-scope-title\">SEO対応</h3>\n        </div>\n        <p class=\"sp-scope-desc\">\n          主要URLの確認、リダイレクト方針の整理、計測タグ設定の基本確認を行い、\n          移行時の影響を抑えます。\n        </p>\n        <ul class=\"sp-scope-points\">\n          <li>主要URL確認</li>\n          <li>リダイレクト方針</li>\n          <li>計測タグ確認</li>\n          <li>GA4・GSC・Meta</li>\n        </ul>\n      </article>\n\n      <article class=\"sp-scope-card sp-animate\">\n        <div class=\"sp-scope-top\">\n          <span class=\"sp-scope-no\">06</span>\n          <h3 class=\"sp-scope-title\">アプリ連携</h3>\n        </div>\n        <p class=\"sp-scope-desc\">\n          レビュー、再入荷通知、LINE連携、カゴ落ち対策など、\n          本当に必要な機能を厳選して組み込みます。\n        </p>\n        <ul class=\"sp-scope-points\">\n          <li>アプリ6点まで</li>\n          <li>レビュー・再入荷</li>\n          <li>LINE・カゴ落ち</li>\n          <li>フォーム・配送分析</li>\n        </ul>\n      </article>\n    </div>\n\n    <div class=\"sp-scope-summary sp-animate\">\n      <div class=\"sp-scope-summary__item\">\n        <span class=\"sp-scope-summary__num\">6</span>\n        <span class=\"sp-scope-summary__label\">オリジナルページ</span>\n      </div>\n      <div class=\"sp-scope-summary__item\">\n        <span class=\"sp-scope-summary__num\">100</span>\n        <span class=\"sp-scope-summary__label\">商品ページ移行</span>\n      </div>\n      <div class=\"sp-scope-summary__item\">\n        <span class=\"sp-scope-summary__num\">20</span>\n        <span class=\"sp-scope-summary__label\">主要ページ・コレクション</span>\n      </div>\n      <div class=\"sp-scope-summary__item\">\n        <span class=\"sp-scope-summary__num\">6</span>\n        <span class=\"sp-scope-summary__label\">アプリ連携</span>\n      </div>\n    </div>\n\n    <p class=\"sp-note sp-animate\">\n      ※対応範囲はサイト規模・移行元の状態・必要機能によって調整します。<br>\n      大量URLのリダイレクト設定、独自アプリ開発、外部システム連携などは別途お見積もりとなります。\n    </p>\n  </div>\n</section>\n\n<script>\n  (() => {\n    const initScopeSections = () => {\n      const sections = document.querySelectorAll('[data-sp-lazy-section]:not([data-sp-lazy-ready])');\n\n      sections.forEach((section) => {\n        section.setAttribute('data-sp-lazy-ready', 'true');\n\n        const reveal = () => {\n          section.classList.add('is-visible');\n        };\n\n        if (!('IntersectionObserver' in window)) {\n          reveal();\n          return;\n        }\n\n        const observer = new IntersectionObserver(\n          (entries, currentObserver) => {\n            entries.forEach((entry) => {\n              if (!entry.isIntersecting) return;\n\n              reveal();\n              currentObserver.unobserve(entry.target);\n            });\n          },\n          {\n            root: null,\n            rootMargin: '120px 0px -8% 0px',\n            threshold: 0.12\n          }\n        );\n\n        observer.observe(section);\n      });\n    };\n\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', initScopeSections);\n    } else {\n      initScopeSections();\n    }\n\n    document.addEventListener('shopify:section:load', initScopeSections);\n  })();\n</script>",
