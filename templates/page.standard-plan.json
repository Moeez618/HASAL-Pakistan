      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .sp-sec { background: var(--COLOR-BG); color: var(--COLOR-TEXT); padding: 64px 20px; }\n  .sp-sec * { box-sizing: border-box; }\n  .sp-inner { max-width: 1040px; margin: 0 auto; }\n  .sp-head { max-width: 820px; margin: 0 auto 36px; text-align: center; }\n  .sp-eyebrow { display: block; margin: 0 0 12px; color: #AB8C52; font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); text-transform: var(--FONT-UPPERCASE-SUBHEADING); }\n  .sp-title { margin: 0 0 16px; line-height: 1.4; color: var(--COLOR-TEXT); }\n  .sp-lead { margin: 0; line-height: 1.9; color: var(--COLOR-TEXT-A80); }\n  .sp-table { width: 100%; border-collapse: collapse; border: 1px solid var(--COLOR-TEXT-A35); border-radius: 14px; overflow: hidden; background: var(--COLOR-TEXT-A5); }\n  .sp-table th { background: var(--BTN-PRIMARY-BG); color: var(--BTN-PRIMARY-TEXT); text-align: center; padding: 16px 20px; line-height: 1.6; }\n  .sp-table td { color: var(--COLOR-TEXT); text-align: left; font-size: 12px; padding: 16px 20px; line-height: 1.9; vertical-align: top; border-top: 1px solid var(--COLOR-TEXT-A35); }\n  .sp-table tbody tr:nth-child(even) td { background: var(--COLOR-TEXT-A5); }\n  .sp-checklist { max-width: 760px; margin: 0 auto; padding: 0; list-style: none; }\n  .sp-checklist li { position: relative; padding: 14px 18px 14px 54px; margin-bottom: 12px; border: 1px solid var(--COLOR-TEXT-A35); border-radius: 12px; background: var(--COLOR-TEXT-A5); color: var(--COLOR-TEXT); line-height: 1.7; }\n  .sp-checklist li::before { content: ''; position: absolute; left: 18px; top: 50%; transform: translateY(-50%); width: 22px; height: 22px; border-radius: 50%; background: var(--BTN-PRIMARY-BG); }\n  .sp-checklist li::after { content: ''; position: absolute; left: 25px; top: 50%; width: 5px; height: 9px; border: solid var(--BTN-PRIMARY-TEXT); border-width: 0 2px 2px 0; transform: translateY(-62%) rotate(45deg); }\n  .sp-checklist--grid { max-width: 860px; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }\n  .sp-checklist--grid li { margin-bottom: 0; }\n  .sp-note { max-width: 860px; margin: 20px auto 0; color: var(--COLOR-TEXT-A80); line-height: 1.8; font-size: 12px; text-align: center; }\n  .sp-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }\n  .sp-card { border: 1px solid var(--COLOR-TEXT-A35); border-radius: 12px; padding: 28px; background: var(--COLOR-TEXT-A5); color: var(--COLOR-TEXT); }\n  .sp-card h3 { margin: 0 0 16px; line-height: 1.5; color: var(--COLOR-TEXT); }\n  .sp-price { display: block; color: #AB8C52; margin: 0 0 18px; }\n  .sp-card ul { margin: 0 0 18px; padding-left: 1.2em; line-height: 1.9; }\n  .sp-card .sp-sub { display: block; margin: 18px 0 6px; color: var(--COLOR-TEXT); }\n  .sp-card p { margin: 0 0 6px; line-height: 1.8; color: var(--COLOR-TEXT); }\n  .sp-flow { max-width: 720px; margin: 0 auto; }\n  .sp-flow__item { display: flex; gap: 22px; align-items: baseline; padding: 24px 0; border-top: 1px solid var(--COLOR-TEXT-A35); }\n  .sp-flow__item:last-child { border-bottom: 1px solid var(--COLOR-TEXT-A35); }\n  .sp-flow__no { flex: 0 0 auto; min-width: 2ch; color: #AB8C52; line-height: 1.4; }\n  .sp-flow__body { flex: 1; }\n  .sp-flow__title { margin: 0 0 6px; line-height: 1.5; color: var(--COLOR-TEXT); }\n  .sp-flow__desc { margin: 0; line-height: 1.8; color: var(--COLOR-TEXT-A80); font-size: 12px; }\n  @media (max-width: 760px) { .sp-sec { padding: 48px 16px; } .sp-grid2 { grid-template-columns: 1fr; } .sp-checklist--grid { grid-template-columns: 1fr; } .sp-table th, .sp-table td { padding: 12px; } .sp-flow__item { gap: 16px; } }\n</style>\n<section class=\"sp-sec\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Free Consultation</p>\n      <h2 class=\"sp-title\">まずは無料相談で、<br>自社の課題を整理してみませんか。</h2>\n      <p class=\"sp-lead\"><strong>まだリニューアルするか決まっていない段階でも問題ありません。</strong><br>無料相談では、次のようなことを整理できます。</p>\n    </div>\n    <ul class=\"sp-checklist sp-checklist--grid\">\n      <li>現行ECサイトの課題診断</li>\n      <li>Shopify移行で注意すべきポイント</li>\n      <li>Standardプランで対応できる範囲</li>\n      <li>別途費用が出そうな項目</li>\n      <li>概算のお見積もり</li>\n      <li>移行スケジュールの目安</li>\n    </ul>\n    <p class=\"sp-note\">※ 無料の対象は、ヒアリング・課題診断・概算見積もりの提示までです（実際の構築作業は有料です）。</p>\n    <div style=\"text-align:center; margin-top: 28px;\">\n      <a class=\"btn btn--solid btn--primary\" href=\"/pages/contact\"><span>自社ECサイトの課題と移行範囲を、無料で整理する</span></a>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "faq": {
      "type": "section-accordion-group",
      "blocks": {
        "heading0": {
          "type": "heading",
          "settings": {
            "title": "よくある質問"
          }
        },
        "q_1": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "まだShopifyへ移行するか決まっていなくても相談できますか？",
            "content": "<p>はい。リニューアルを前提にしていない段階でもご相談いただけます。無料相談では、現行ECサイトの課題や、移行が必要かどうかの整理からお手伝いします。無理なご提案はいたしません。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_2": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "今のECサイトから商品データはすべて移行できますか？",
            "content": "<p>商品名・価格・説明文・画像・在庫などは、Shopifyで運用しやすい形で整理して移行します（商品ページ100点まで）。バリエーション数が多い場合や、顧客データ・注文履歴などは、既存サービスの仕様を確認のうえ、移行できるデータ・できないデータを無料相談で整理してお伝えします。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_3": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "SEO評価は引き継げますか？",
            "content": "<p>主要URLの確認やリダイレクト方針の整理など、検索流入への影響を抑える基本対応を工程に組み込みます。大量URLの301リダイレクト設計・設定や詳細なSEO設計は別途お見積もりとなります。なお、検索評価の維持を保証するものではありません。（301リダイレクトとは、旧URLにアクセスした人を新URLへ自動で案内し、検索評価の引き継ぎを目指す設定です。）</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_4": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "顧客データや注文履歴も移行できますか？",
            "content": "<p>顧客データ・注文履歴・レビュー・ポイント・会員ランクなどの移行は、既存サービスの仕様を確認したうえで、別途お見積もりとなる場合があります。詳細は無料相談で整理します。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_5": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "デザインだけの依頼はできますか？",
            "content": "<p>Standardプランは、デザイン制作だけでなく、Shopifyへの移行や運用基盤づくりまでを含むプランです。デザインだけを少し変えたい場合は、より適したご提案ができることがありますので、まずはご相談ください。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_6": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "公開後の運用サポートは含まれますか？",
            "content": "<p>本プランは「自分たちで運用しやすい状態に整えてお引き渡しするまで」が範囲です。公開後の保守運用サポートは、別途お見積もりとなります。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_7": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "Shopifyの月額費用やアプリ費用は別ですか？",
            "content": "<p>はい。Shopifyの月額利用料、決済手数料、一部アプリの利用料など、外部サービスの費用はお客様のご負担となります。事前に整理してお伝えします。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_8": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "Standardプランでは対応できないケースはありますか？",
            "content": "<p>越境対応（多言語・多通貨）、外部システム（在庫管理・店舗レジ・基幹システムなど）との連携、Shopifyアプリそのものの独自開発などは、別途お見積もりまたは対象外です。複雑な基幹連携が前提の場合は、上位プランが適していることもあります。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_9": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "納期はどれくらいですか？",
            "content": "<p>約8〜12週間が目安です。要件や、お客様側の素材手配のスピードによって変動します。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "q_10": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "相談時に何を準備すればいいですか？",
            "content": "<p>特別な準備は不要です。現行ECサイトの状況や、伸ばしたいカテゴリ、運用の負担感などをお聞かせいただければ、その場で課題や移行範囲を整理できます。お手元にあれば、商品情報や画像素材のイメージもご共有ください。</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        }
      },
