    "growth": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<!-- 実績ハイライト - SOLSTAR -->\n<div class=\"solstar-stats\">\n  <div class=\"solstar-stats__grid\">\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"100\"\n           data-decimals=\"0\"\n           data-suffix=\"億円以上\">\n        100億円以上\n      </div>\n      <div class=\"solstar-stats__label\">支援先ECサイトの年間売上規模</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"13\"\n           data-decimals=\"0\"\n           data-suffix=\"％\">\n        13％\n      </div>\n      <div class=\"solstar-stats__label\">表示速度改善率</div>\n    </div>\n\n    <div class=\"solstar-stats__item\">\n      <div class=\"solstar-stats__value\"\n           data-value=\"4.37\"\n           data-decimals=\"2\"\n           data-suffix=\"％\">\n        4.37％\n      </div>\n      <div class=\"solstar-stats__label\">新規顧客の購入CVR</div>\n    </div>\n  </div>\n</div>\n\n<style>\n  .solstar-stats {\n    max-width: 1080px;\n    margin: 0 auto;\n    padding: 48px 16px;\n    background-color: #0D0326;\n  }\n\n  .solstar-stats__grid {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 32px;\n  }\n\n  .solstar-stats__item {\n    text-align: center;\n    padding: 24px 16px;\n    opacity: 1;\n    transform: translateY(0);\n    transition:\n      opacity 0.6s ease-out,\n      transform 0.6s ease-out;\n  }\n\n  .solstar-stats.is-animated .solstar-stats__item:not(.is-visible) {\n    opacity: 0;\n    transform: translateY(24px);\n  }\n\n  .solstar-stats__item.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .solstar-stats__value {\n    font-weight: 700;\n    letter-spacing: 0;\n    font-size: clamp(40px, 4.2vw, 55px);\n    line-height: 1.1;\n    margin-bottom: 8px;\n    font-feature-settings: \"pnum\" on, \"lnum\" on;\n    color: #ffffff;\n    white-space: nowrap;\n    word-break: keep-all;\n  }\n\n  .solstar-stats__label {\n    font-size: 20px;\n    font-weight: 700;\n    line-height: 1.6;\n    letter-spacing: 0;\n    color: #9CA3AF;\n  }\n\n  @media (max-width: 767px) {\n    .solstar-stats {\n      padding: 32px 16px;\n    }\n\n    .solstar-stats__grid {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .solstar-stats__item {\n      padding: 20px 16px;\n    }\n\n    .solstar-stats__value {\n      font-size: clamp(38px, 12vw, 44px);\n    }\n\n    .solstar-stats__label {\n      font-size: 17px;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    function initSolstarStats() {\n      var sections = document.querySelectorAll('.solstar-stats');\n\n      if (!sections.length) return;\n\n      sections.forEach(function (section) {\n        if (section.dataset.solstarStatsInitialized === 'true') return;\n        section.dataset.solstarStatsInitialized = 'true';\n\n        var items = section.querySelectorAll('.solstar-stats__item');\n        var values = section.querySelectorAll('.solstar-stats__value');\n        var animated = false;\n\n        section.classList.add('is-animated');\n\n        function animateNumbers() {\n          if (animated) return;\n          animated = true;\n\n          values.forEach(function (el) {\n            var target = parseFloat(el.getAttribute('data-value') || '0');\n            var decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);\n            var suffix = el.getAttribute('data-suffix') || '';\n            var duration = 1500;\n            var start = null;\n\n            el.textContent = (0).toFixed(decimals) + suffix;\n\n            function step(timestamp) {\n              if (!start) start = timestamp;\n\n              var progress = Math.min((timestamp - start) / duration, 1);\n              var easedProgress = 1 - Math.pow(1 - progress, 3);\n              var current = target * easedProgress;\n\n              el.textContent = current.toFixed(decimals) + suffix;\n\n              if (progress < 1) {\n                window.requestAnimationFrame(step);\n              } else {\n                el.textContent = target.toFixed(decimals) + suffix;\n              }\n            }\n\n            window.requestAnimationFrame(step);\n          });\n        }\n\n        function revealItems() {\n          items.forEach(function (item, index) {\n            item.style.transitionDelay = (index * 0.12) + 's';\n            item.classList.add('is-visible');\n          });\n        }\n\n        function runAnimation() {\n          revealItems();\n          animateNumbers();\n        }\n\n        function isInViewport(el) {\n          var rect = el.getBoundingClientRect();\n          var windowHeight = window.innerHeight || document.documentElement.clientHeight;\n\n          return rect.top < windowHeight * 0.85 && rect.bottom > 0;\n        }\n\n        if ('IntersectionObserver' in window) {\n          var observer = new IntersectionObserver(function (entries) {\n            entries.forEach(function (entry) {\n              if (entry.isIntersecting) {\n                runAnimation();\n                observer.unobserve(section);\n              }\n            });\n          }, {\n            root: null,\n            threshold: 0.2\n          });\n\n          observer.observe(section);\n\n          setTimeout(function () {\n            if (!animated && isInViewport(section)) {\n              runAnimation();\n              observer.unobserve(section);\n            }\n          }, 300);\n        } else {\n          runAnimation();\n        }\n      });\n    }\n\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', initSolstarStats);\n    } else {\n      initSolstarStats();\n    }\n\n    window.addEventListener('load', initSolstarStats);\n\n    document.addEventListener('shopify:section:load', function () {\n      initSolstarStats();\n    });\n  })();\n</script>",
