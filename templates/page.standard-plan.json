        "code": "<style>\n  .sp-sec { background: var(--COLOR-BG); color: var(--COLOR-TEXT); padding: 64px 20px; }\n  .sp-sec * { box-sizing: border-box; }\n  .sp-inner { max-width: 1040px; margin: 0 auto; }\n  .sp-head { max-width: 820px; margin: 0 auto 44px; text-align: center; }\n  .sp-eyebrow { display: block; margin: 0 0 12px; color: #AB8C52; font-family: var(--FONT-STACK-SUBHEADING); font-style: var(--FONT-STYLE-SUBHEADING); font-weight: var(--FONT-WEIGHT-SUBHEADING); font-size: var(--font-subheading); letter-spacing: var(--LETTER-SPACING-SUBHEADING); text-transform: var(--FONT-UPPERCASE-SUBHEADING); }\n  .sp-title { margin: 0 0 16px; line-height: 1.4; color: var(--COLOR-TEXT); }\n  .sp-lead { margin: 0; line-height: 1.9; color: var(--COLOR-TEXT-A80); }\n  .sp-note { max-width: 860px; margin: 30px auto 0; color: var(--COLOR-TEXT-A80); line-height: 1.8; font-size: 12px; text-align: center; }\n  .bf-grid { display: grid; grid-template-columns: 1fr auto 1fr; grid-template-areas: \"bcard . acard\" \"bimg arr aimg\"; column-gap: 28px; row-gap: 16px; max-width: 920px; margin: 0 auto; align-items: stretch; }\n  .bf-col-before { grid-area: bcard; }\n  .bf-col-after { grid-area: acard; }\n  .bf-fig-before { grid-area: bimg; align-self: start; }\n  .bf-fig-after { grid-area: aimg; align-self: start; }\n  .bf-arrow { grid-area: arr; align-self: center; justify-self: center; display: flex; }\n  .bf-headcol { display: flex; flex-direction: column; }\n  .bf-colhead { margin: 0 0 16px; text-align: center; color: var(--COLOR-TEXT); font-size: 24px; font-weight: 700; line-height: 1.3; }\n  .bf-col-after .bf-colhead { color: #AB8C52; }\n  .bf-card { flex: 1; border-radius: 14px; padding: 24px; border: 1px solid var(--COLOR-TEXT-A35); background: var(--COLOR-TEXT-A5); }\n  .bf-card.is-after { border-color: #AB8C52; background: rgba(171, 140, 82, 0.10); }\n  .bf-card ul { margin: 0; padding: 0; list-style: none; }\n  .bf-card li { position: relative; margin: 0 0 12px; padding-left: 18px; color: var(--COLOR-TEXT); font-size: 12px; line-height: 1.8; }\n  .bf-card li:last-child { margin-bottom: 0; }\n  .bf-card li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 6px; height: 6px; border-radius: 50%; background: var(--COLOR-TEXT-A35); }\n  .bf-card.is-after li::before { background: #AB8C52; }\n  .bf-figure { margin: 0; border-radius: 14px; overflow: hidden; border: 1px solid var(--COLOR-TEXT-A35); }\n  .bf-figure img { display: block; width: 100%; aspect-ratio: 4 / 6; object-fit: cover; }\n  @media (max-width: 760px) { .sp-sec { padding: 48px 16px; } .bf-grid { grid-template-columns: 1fr; grid-template-areas: \"bcard\" \"bimg\" \"arr\" \"acard\" \"aimg\"; max-width: 380px; row-gap: 14px; } .bf-arrow { transform: rotate(90deg); margin: 2px 0; } }\n</style>\n<section class=\"sp-sec\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Benefit</p>\n      <h2 class=\"sp-title\">リニューアルで変わるのは、<br>見た目だけではありません。</h2>\n      <p class=\"sp-lead\">運用のしやすさや、リピート施策の進めやすさも変わります。<br>リニューアルのあと、現場の毎日がどう変わるかでお伝えします。</p>\n    </div>\n    <div class=\"bf-grid\">\n      <div class=\"bf-headcol bf-col-before\">\n        <p class=\"bf-colhead\">Before</p>\n        <div class=\"bf-card\">\n          <ul>\n            <li>新作発売前に商品登録や在庫調整で慌ただしい</li>\n            <li>特集やLOOKページの更新に手間がかかる</li>\n            <li>再入荷希望やカゴ落ちが機会損失になる</li>\n            <li>LINEやレビュー導線がバラバラ</li>\n            <li>データはあるが改善に使いづらい</li>\n            <li>新作発売時の売上に依存しやすい</li>\n          </ul>\n        </div>\n      </div>\n      <figure class=\"bf-figure bf-fig-before\"><img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/ChatGPT_Image_2026_6_15_15_43_06.png?v=1781505815\" alt=\"リニューアル前のECサイト運用イメージ\" loading=\"lazy\"></figure>\n      <div class=\"bf-arrow\" aria-hidden=\"true\"><svg width=\"46\" height=\"46\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#AB8C52\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M13 6l6 6-6 6\"/></svg></div>\n      <div class=\"bf-headcol bf-col-after\">\n        <p class=\"bf-colhead\">After</p>\n        <div class=\"bf-card is-after\">\n          <ul>\n            <li>商品登録や更新の手戻りが減り、準備しやすくなる</li>\n            <li>社内で更新しやすい構成になる</li>\n            <li>再購入・購入検討につなげやすくなる</li>\n            <li>購入後も顧客とつながりやすくなる</li>\n            <li>商品ページや導線の改善点を見つけやすくなる</li>\n            <li>リピート購入の土台を作りやすくなる</li>\n          </ul>\n        </div>\n      </div>\n      <figure class=\"bf-figure bf-fig-after\"><img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Cream_Image_1_copy.jpg?v=1781504981\" alt=\"リニューアル後のShopify ECサイト運用イメージ\" loading=\"lazy\"></figure>\n    </div>\n    <p class=\"sp-note\">※ 効果はブランドの規模・商材・運用体制によって異なり、特定の成果を保証するものではありません。</p>\n  </div>\n</section>",
