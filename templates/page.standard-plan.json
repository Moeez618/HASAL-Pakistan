=============\n     Text-focused Animation\n  ============================================================ */\n\n  .sp-core-animate {\n    opacity: 0;\n    transform: translateY(28px);\n    transition:\n      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),\n      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);\n    will-change: opacity, transform;\n  }\n\n  .sp-core-animate.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .sp-core-item:nth-child(2) {\n    transition-delay: 0.12s;\n  }\n\n  .sp-core-item:nth-child(3) {\n    transition-delay: 0.24s;\n  }\n\n  .sp-core-item__title,\n  .sp-core-item__text {\n    opacity: 0;\n    transform: translateY(18px);\n    transition:\n      opacity 0.76s cubic-bezier(0.22, 1, 0.36, 1),\n      transform 0.76s cubic-bezier(0.22, 1, 0.36, 1);\n    will-change: opacity, transform;\n  }\n\n  .sp-core-item.is-visible .sp-core-item__title,\n  .sp-core-item.is-visible .sp-core-item__text {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .sp-core-item.is-visible .sp-core-item__title {\n    transition-delay: 0.12s;\n  }\n\n  .sp-core-item.is-visible .sp-core-item__text {\n    transition-delay: 0.26s;\n  }\n\n  .sp-core__nav {\n    display: none;\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .sp-core-animate,\n    .sp-core-item__title,\n    .sp-core-item__text {\n      opacity: 1 !important;\n      transform: none !important;\n      transition: none !important;\n    }\n  }\n\n  /* ============================================================\n     Mobile Slider\n  ============================================================ */\n\n  @media (max-width: 767px) {\n    #sp-core-section {\n      padding: 44px 0 52px;\n    }\n\n    .sp-core__inner {\n      width: 100%;\n    }\n\n    .sp-core__viewport {\n      overflow: hidden;\n    }\n\n    .sp-core__track {\n      display: flex;\n      gap: 0;\n      overflow-x: auto;\n      scroll-snap-type: x mandatory;\n      scroll-behavior: smooth;\n      -webkit-overflow-scrolling: touch;\n      padding: 0 16px 8px;\n      scrollbar-width: none;\n    }\n\n    .sp-core__track::-webkit-scrollbar {\n      display: none;\n    }\n\n    .sp-core-item {\n      flex: 0 0 84%;\n      scroll-snap-align: start;\n      margin-right: 28px;\n    }\n\n    .sp-core-item:last-child {\n      margin-right: 16px;\n    }\n\n    .sp-core-item:nth-child(2),\n    .sp-core-item:nth-child(3) {\n      transition-delay: 0s;\n    }\n\n    .sp-core-item__body {\n      gap: 16px;\n    }\n\n    .sp-core-item__title {\n      min-height: 3.1em;\n    }\n\n    .sp-core-item__text {\n      max-width: 100%;\n    }\n\n    .sp-core__nav {\n      display: flex;\n      justify-content: center;\n      gap: 8px;\n      margin-top: 22px;\n      padding: 0 16px;\n    }\n\n    .sp-core__dot {\n      width: 7px;\n      height: 7px;\n      padding: 0;\n      border: 0;\n      border-radius: 999px;\n      background: var(--COLOR-TEXT-A35);\n      cursor: pointer;\n      transition:\n        width 0.25s ease,\n        background 0.25s ease;\n    }\n\n    .sp-core__dot.is-active {\n      width: 24px;\n      background: #AB8C52;\n    }\n  }\n</style>\n\n<section id=\"sp-core-section\">\n  <div class=\"sp-core__inner\">\n    <div class=\"sp-core__viewport\">\n      <div class=\"sp-core__track\" id=\"sp-core-track\">\n        <article class=\"sp-core-item sp-core-animate\">\n          <div class=\"sp-core-item__body\">\n            <h3 class=\"sp-core-item__title\">ブランド表現</h3>\n            <p class=\"sp-core-item__text\">ブランドの世界観を、ECサイトでも崩さない。</p>\n          </div>\n        </article>\n\n        <article class=\"sp-core-item sp-core-animate\">\n          <div class=\"sp-core-item__body\">\n            <h3 class=\"sp-core-item__title\">移行設計</h3>\n            <p class=\"sp-core-item__text\">検索流入や運用への影響を見据える。</p>\n          </div>\n        </article>\n\n        <article class=\"sp-core-item sp-core-animate\">\n          <div class=\"sp-core-item__body\">\n            <h3 class=\"sp-core-item__title\">リピートと運用</h3>\n            <p class=\"sp-core-item__text\">自分たちで育てられるECサイトにする。</p>\n          </div>\n        </article>\n      </div>\n\n      <div class=\"sp-core__nav\" aria-label=\"スライダー操作\">\n        <button type=\"button\" class=\"sp-core__dot is-active\" aria-label=\"1枚目を表示\"></button>\n        <button type=\"button\" class=\"sp-core__dot\" aria-label=\"2枚目を表示\"></button>\n        <button type=\"button\" class=\"sp-core__dot\" aria-label=\"3枚目を表示\"></button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const section = document.getElementById(\"sp-core-section\");\n    const track = document.getElementById(\"sp-core-track\");\n    const items = section.querySelectorAll(\".sp-core-animate\");\n    const dots = section.querySelectorAll(\".sp-core__dot\");\n    const prefersReducedMotion = window.matchMedia(\"(prefers-reduced-motion: reduce)\").matches;\n\n    function revealImmediately(elements) {\n      elements.forEach(function (el) {\n        el.classList.add(\"is-visible\");\n      });\n    }\n\n    if (\"IntersectionObserver\" in window && !prefersReducedMotion) {\n      const observer = new IntersectionObserver(function (entries, observer) {\n        entries.forEach(function (entry) {\n          if (entry.isIntersecting) {\n            entry.target.classList.add(\"is-visible\");\n            observer.unobserve(entry.target);\n          }\n        });\n      }, {\n        threshold: 0.18,\n        rootMargin: \"0px 0px -8% 0px\"\n      });\n\n      items.forEach(function (item) {\n        observer.observe(item);\n      });\n    } else {\n      revealImmediately(items);\n    }\n\n    function updateDots() {\n      if (!dots.length) return;\n\n      const trackRect = track.getBoundingClientRect();\n      let activeIndex = 0;\n      let closestDistance = Infinity;\n\n      items.forEach(function (item, index) {\n        const itemRect = item.getBoundingClientRect();\n        const distance = Math.abs(itemRect.left - trackRect.left);\n\n        if (distance < closestDistance) {\n          closestDistance = distance;\n          activeIndex = index;\n        }\n      });\n\n      dots.forEach(function (dot, index) {\n        dot.classList.toggle(\"is-active\", index === activeIndex);\n      });\n    }\n\n    dots.forEach(function (dot, index) {\n      dot.addEventListener(\"click\", function () {\n        items[index].scrollIntoView({\n          behavior: prefersReducedMotion ? \"auto\" : \"smooth\",\n          block: \"nearest\",\n          inline: \"start\"\n        });\n      });\n    });\n\n    if (track) {\n      track.addEventListener(\"scroll\", function () {\n        window.requestAnimationFrame(updateDots);\n      }, { passive: true });\n\n      window.addEventListener(\"resize\", updateDots);\n      updateDots();\n    }\n  });\n</script>",
