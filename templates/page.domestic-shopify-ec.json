    "section_custom_code_jyWnnr": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .solstar-pricing {\n    background: var(--COLOR-BG);\n    color: var(--COLOR-TEXT);\n    padding: 72px 20px;\n  }\n  .solstar-pricing * { box-sizing: border-box; }\n  .solstar-pricing__inner { max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr); gap: 22px; align-items: stretch; }\n  .solstar-pricing__summary,\n  .solstar-pricing__detail { border: 1px solid var(--COLOR-BORDER-LIGHT); border-radius: 12px; background: var(--COLOR-BG-ACCENT-LIGHTEN); }\n  .solstar-pricing__summary { padding: 34px; display: flex; flex-direction: column; justify-content: space-between; gap: 28px; background: linear-gradient(rgba(0, 0, 0, 0.56), rgba(0, 0, 0, 0.68)), url('https://cdn.shopify.com/s/files/1/0704/2642/7614/files/ChatGPT_Image_2026_6_2_14_24_01.png?v=1780377857') center / cover no-repeat; color: var(--COLOR-BG-ACCENT-LIGHTEN); }\n  .solstar-pricing__eyebrow { margin: 0 0 14px; color: var(--COLOR-BG-ACCENT); font-size: var(--font-body-medium); font-weight: 700; letter-spacing: var(--LETTER-SPACING-BODY); text-transform: uppercase; }\n  .solstar-pricing__summary h2 { margin: 0 0 16px; color: var(--COLOR-BG-ACCENT-LIGHTEN); font-size: var(--font-body-medium); line-height: 1.28; letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-pricing__price { margin: 0; font-size: var(--font-body-medium); font-weight: 800; line-height: 1; }\n  .solstar-pricing__price span { font-size: var(--font-body-medium); font-weight: 600; color: var(--COLOR-BG-ACCENT); }\n  .solstar-pricing__lead { margin: 14px 0 0; color: var(--COLOR-BG-ACCENT); line-height: 1.85; }\n  .solstar-pricing__button { display: inline-flex; align-items: center; justify-content: center; width: fit-content; min-height: 48px; padding: 14px 26px; border-radius: var(--btn-radius); border: 1px solid #AB8C52; background: #AB8C52; color: #FFFFFF; font-weight: 700; text-decoration: none; }\n  .solstar-pricing__button:hover { background: #967A45; border-color: #967A45; color: #FFFFFF; }\n  .solstar-pricing__detail { padding: 30px; }\n  .solstar-pricing__detail h3 { margin: 0 0 18px; font-size: var(--font-body-medium); letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-pricing__list { margin: 0 0 26px; padding-left: 1.4em; display: grid; gap: 12px; }\n  .solstar-pricing__list li { color: var(--COLOR-TEXT-DARK); line-height: 1.75; }\n  .solstar-pricing__exclude { margin-top: 22px; padding-top: 22px; border-top: 1px solid var(--COLOR-BORDER-LIGHT); }\n  .solstar-pricing__note { margin: 0 0 10px; color: var(--COLOR-TEXT-A80); font-size: var(--font-body-medium); line-height: 1.8; }\n  @media (max-width: 860px) { .solstar-pricing__inner { grid-template-columns: 1fr; } }\n  @media (max-width: 640px) {\n    .solstar-pricing { padding: 52px 16px; }\n    .solstar-pricing__summary, .solstar-pricing__detail { padding: 24px 20px; }\n    .solstar-pricing__button { width: 100%; }\n  }\n\n  /* Theme typography overrides */\n\n  .solstar-pricing {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .solstar-pricing__eyebrow {\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n  .solstar-pricing__summary h2,\n  .solstar-pricing__price,\n  .solstar-pricing__detail h3 {\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n  .solstar-pricing__summary h2,\n  .solstar-pricing__price { font-size: var(--font-heading-large); }\n  .solstar-pricing__detail h3 { font-size: var(--font-heading-small); }\n  .solstar-pricing__price span,\n  .solstar-pricing__lead,\n  .solstar-pricing__list li,\n  .solstar-pricing__note { letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-pricing__price span,\n  .solstar-pricing__note { font-size: var(--font-body-small); }\n  .solstar-pricing__button {\n    font-family: var(--BTN-FONT-STACK);\n    font-size: var(--BTN-FONT-SIZE);\n    letter-spacing: var(--BTN-LETTER-SPACING);\n  }\n  /* End theme typography overrides */\n</style>\n<section class=\"solstar-pricing\">\n  <div class=\"solstar-pricing__inner\">\n    <div class=\"solstar-pricing__summary\">\n      <div>\n        <p class=\"solstar-pricing__eyebrow\">Price</p>\n        <h2>料金とご契約内容</h2>\n        <p class=\"solstar-pricing__price\">BASICプラン 1,100,000円<span>（税込）〜</span></p>\n        <p class=\"solstar-pricing__lead\">※標準の制作範囲を含む最低価格です。制作範囲内であれば追加費用は発生しません。</p>\n      </div>\n      <a class=\"solstar-pricing__button\" href=\"/pages/contact\">まずは無料で相談する</a>\n    </div>\n    <div class=\"solstar-pricing__detail\">\n      <h3><strong>ご契約に含まれる内容</strong></h3>\n      <ol class=\"solstar-pricing__list\">\n        <li>自社開発テーマ「Cream」を無料利用可能（テーマ購入費0円）</li>\n        <li>納品物の著作権は、お支払い完了後にお客様に帰属します</li>\n        <li>お引き渡しから6ヶ月以内、当社の納品物に起因する不具合へ対応（納品後にお客様側で追加・変更された内容や、第三者アプリの導入による不具合は対象外）</li>\n        <li>ご納得いただけるまで無償で修正対応</li>\n      </ol>\n      <div class=\"solstar-pricing__exclude\">\n        <h3><strong>料金に含まれないもの</strong></h3>\n        <ul class=\"solstar-pricing__list\">\n          <li>Shopifyの月額利用料</li>\n          <li>各種アプリの利用料（連携作業は本プランに含まれますが、アプリ自体の利用料はお客様負担となります）</li>\n          <li>有料テーマの購入費 ※無料の「Cream」をご利用いただけるため、テーマ購入費はかかりません</li>\n          <li>納品後の保守・運用（別途サービスとして承っています）</li>\n        </ul>\n      </div>\n      <p class=\"solstar-pricing__note\"><strong>この価格に含まれる制作範囲：</strong>商品登録20点／カテゴリ6点／アプリ連携3点／オリジナルページ制作3ページ／体制：ディレクター1名＋エンジニア1名／納期：約4〜8週間</p>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_custom_code_WCNGtK": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .solstar-fit {\n    background: var(--COLOR-BG);\n    color: var(--COLOR-TEXT);\n    padding: 68px 20px 54px;\n  }\n  .solstar-fit * { box-sizing: border-box; }\n  .solstar-fit__inner { max-width: 1040px; margin: 0 auto; }\n  .solstar-fit__head { max-width: 720px; margin: 0 auto 30px; text-align: center; }\n  .solstar-fit__eyebrow { margin: 0 0 12px; color: var(--COLOR-ACCENT); font-size: var(--font-body-medium); font-weight: 700; letter-spacing: var(--LETTER-SPACING-BODY); text-transform: uppercase; }\n  .solstar-fit__title { margin: 0; font-size: var(--font-body-medium); line-height: 1.4; letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-fit__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }\n  .solstar-fit__panel { border: 1px solid var(--COLOR-BORDER-LIGHT); border-radius: 12px; background: var(--COLOR-BG-ACCENT-LIGHTEN); padding: 26px; }\n  .solstar-fit__panel.is-muted { background: var(--COLOR-BG-ACCENT); }\n  .solstar-fit__panel h3 { margin: 0 0 18px; font-size: var(--font-body-medium); letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-fit__panel p { margin: 0 0 14px; color: var(--COLOR-TEXT-DARK); line-height: 1.75; }\n  .solstar-fit__panel p:last-child { margin-bottom: 0; }\n  .solstar-fit__panel.is-muted p { color: var(--COLOR-TEXT-A80); }\n  @media (max-width: 760px) {\n    .solstar-fit { padding: 52px 16px 42px; }\n    .solstar-fit__grid { grid-template-columns: 1fr; }\n    .solstar-fit__panel { padding: 22px 20px; }\n  }\n\n  /* Theme typography overrides */\n\n  .solstar-fit {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .solstar-fit__eyebrow {\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n  .solstar-fit__title,\n  .solstar-fit__panel h3 {\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n  .solstar-fit__title { font-size: var(--font-heading-large); }\n  .solstar-fit__panel h3 { font-size: var(--font-heading-small); }\n  .solstar-fit__panel p { font-size: var(--font-body-medium); letter-spacing: var(--LETTER-SPACING-BODY); }\n  /* End theme typography overrides */\n</style>\n<section class=\"solstar-fit\">\n  <div class=\"solstar-fit__inner\">\n    <div class=\"solstar-fit__head\">\n      <p class=\"solstar-fit__eyebrow\">Fit</p>\n      <h2 class=\"solstar-fit__title\">向いている方／向いていない方</h2>\n    </div>\n    <div class=\"solstar-fit__grid\">\n      <div class=\"solstar-fit__panel\">\n        <h3><strong>向いている方</strong></h3>\n        <p>少数SKU（商品点数の少ない）で、ブランドの世界観を育てながら運用したい方</p>\n        <p>モールやSNS中心の販売から、自社ECサイトへ移行したい方&nbsp;</p>\n        <p>はじめての自社ECサイト立ち上げで、何から決めればよいか分からない方</p>\n        <p>制作だけでなく、コンセプト設計から相談したい方</p>\n        <p>納品後も自社で更新・運用しやすいECサイトをつくりたい方 </p>\n      </div>\n      <div class=\"solstar-fit__panel is-muted\">\n        <h3><strong>向いていない方</strong></h3>\n        <p>ブランド設計や運用のしやすさよりも、制作費の安さを最優先したい方</p>\n        <p>すでに社内にECサイトの設計・運用体制があり、外部パートナーを必要としていない方</p>\n        <p>商品登録20点を大きく超える大規模な商品登録を前提としている方</p>\n      </div>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_custom_code_RcTXxd": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .solstar-compare {\n    --sf-bg: var(--COLOR-BG);\n    --sf-brand: var(--COLOR-ACCENT);\n    --sf-brand-deep: var(--COLOR-TEXT-DARK);\n    --sf-ink: var(--COLOR-TEXT);\n    --sf-sub: var(--COLOR-TEXT-A80);\n    --sf-line: var(--COLOR-BORDER-LIGHT);\n    --sf-chip: var(--COLOR-BG-ACCENT);       /* SOLSTAR列の強調トーン */\n    background: var(--sf-bg);\n    color: var(--sf-ink);\n    max-width: 960px;\n    margin: 0 auto;\n    padding: 40px 16px 56px;\n    box-sizing: border-box;\n  }\n  .solstar-compare * { box-sizing: border-box; }\n\n  .solstar-compare__head {\n    text-align: center;\n    margin: 0 0 24px;\n  }\n  .solstar-compare__eyebrow {\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n    text-transform: uppercase;\n    color: var(--sf-brand);\n    margin: 0 0 14px;\n  }\n  .solstar-compare__title {\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    letter-spacing: var(--LETTER-SPACING-BODY);\n    line-height: 1.5;\n    margin: 0 0 16px;\n  }\n  .solstar-compare__note {\n    font-size: var(--font-body-medium);\n    color: var(--sf-sub);\n    line-height: 1.8;\n    max-width: 680px;\n    margin: 0 auto;\n    text-align: left;\n  }\n\n  /* テーブル本体（外枠なし・罫線はすべて1px） */\n  .solstar-compare__table {\n    width: 100%;\n    border-collapse: separate;\n    border-spacing: 0;\n    table-layout: fixed;\n    border-radius: 12px;\n    overflow: hidden;\n  }\n  .solstar-compare__table th,\n  .solstar-compare__table td {\n    text-align: left;\n    vertical-align: top;\n    padding: 18px 22px;\n    font-size: var(--font-body-medium);\n    line-height: 1.7;\n    word-break: break-word;\n  }\n  /* 列幅を均等に統一 */\n  .solstar-compare__table .is-problem,\n  .solstar-compare__table .is-solution {\n    width: 50%;\n  }\n  /* ヘッダー（中央寄せ・下線1px） */\n  .solstar-compare__table thead th {\n    text-align: center;\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    letter-spacing: var(--LETTER-SPACING-BODY);\n    color: var(--sf-sub);\n    border-bottom: 1px solid var(--sf-line);\n  }\n\n  /* 行区切り（横罫線1px） */\n  .solstar-compare__table tbody td {\n    border-bottom: 1px solid var(--sf-line);\n  }\n  .solstar-compare__table tbody tr:last-child td {\n    border-bottom: none;\n  }\n\n  /* よくある不満（左）＝白 */\n  .solstar-compare__table .is-problem {\n    color: var(--sf-ink);\n    background: var(--COLOR-BG-ACCENT-LIGHTEN);\n  }\n\n  /* SOLSTARの進め方（右）＝背景トーンと文字で強調（線はすべて1px） */\n  .solstar-compare__table .is-solution {\n    background: var(--sf-chip);\n    border-left: 1px solid var(--sf-line);\n  }\n  .solstar-compare__table thead .is-solution {\n    color: var(--sf-brand-deep);\n  }\n  .solstar-compare__table tbody .is-solution {\n    color: var(--sf-brand-deep);\n    font-weight: 600;\n  }\n  .solstar-compare__check {\n    color: var(--sf-brand);\n    font-weight: 700;\n    margin-right: 9px;\n  }\n\n  /* ===== モバイル（積み重ねカード） ===== */\n  @media (max-width: 600px) {\n    .solstar-compare { padding: 32px 16px 48px; }\n    .solstar-compare__title { font-size: var(--font-body-medium); }\n\n    .solstar-compare__table { table-layout: auto; }\n    .solstar-compare__table,\n    .solstar-compare__table tbody,\n    .solstar-compare__table tr,\n    .solstar-compare__table td {\n      display: block;\n      width: 100%;\n    }\n    .solstar-compare__table thead { display: none; }\n\n    .solstar-compare__table tbody tr {\n      border: none;\n      border-radius: 12px;\n      overflow: hidden;\n      margin-bottom: 14px;\n    }\n    .solstar-compare__table tbody tr:last-child {\n      margin-bottom: 0;\n    }\n    .solstar-compare__table td {\n      border-bottom: none !important;\n      padding: 16px 18px;\n    }\n    .solstar-compare__table .is-problem,\n    .solstar-compare__table .is-solution {\n      width: 100% !important;\n    }\n    .solstar-compare__table .is-problem::before {\n      content: \"よくある不満\";\n      display: block;\n      font-size: var(--font-body-medium);\n      letter-spacing: var(--LETTER-SPACING-BODY);\n      color: var(--sf-sub);\n      margin-bottom: 6px;\n    }\n    .solstar-compare__table tbody .is-solution {\n      border-left: none;\n      border-top: 1px solid var(--sf-line);\n    }\n    .solstar-compare__table .is-solution::before {\n      content: \"SOLSTARの進め方\";\n      display: block;\n      font-size: var(--font-body-medium);\n      letter-spacing: var(--LETTER-SPACING-BODY);\n      color: var(--sf-brand);\n      font-weight: 700;\n      margin-bottom: 6px;\n    }\n  }\n\n  /* Theme typography overrides */\n\n  .solstar-compare {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .solstar-compare__eyebrow,\n  .solstar-compare__check,\n  .solstar-compare__table .is-problem::before,\n  .solstar-compare__table .is-solution::before {\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n  .solstar-compare__title,\n  .solstar-compare__table thead th {\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n  .solstar-compare__title { font-size: var(--font-heading-medium); }\n  .solstar-compare__table thead th { font-size: var(--font-heading-x-small); }\n  .solstar-compare__note,\n  .solstar-compare__table th,\n  .solstar-compare__table td { font-size: var(--font-body-medium); letter-spacing: var(--LETTER-SPACING-BODY); }\n  /* End theme typography overrides */\n</style>\n\n<section class=\"solstar-compare\">\n  <div class=\"solstar-compare__head\">\n    <p class=\"solstar-compare__eyebrow\">Comparison</p>\n    <h2 class=\"solstar-compare__title\">ECサイト制作でよくある不満と、SOLSTARの進め方</h2>\n    <p class=\"solstar-compare__note\">※左はECサイト運用に関する調査で挙げられる代表的な不満、右はSOLSTARがそれを防ぐために大切にしていることです。他社を評価するものではありません。</p>\n  </div>\n\n  <table class=\"solstar-compare__table\">\n    <thead>\n      <tr>\n        <th class=\"is-problem\">よくある不満（調査より）</th>\n        <th class=\"is-solution\">SOLSTARの進め方</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td class=\"is-problem\">意図やニュアンスが伝わらない</td>\n        <td class=\"is-solution\"><span class=\"solstar-compare__check\">✓</span>ブランドのコンセプト設計と仕様確認を書面で行い、認識のズレを防ぎます</td>\n      </tr>\n      <tr>\n        <td class=\"is-problem\">専門用語が多く判断できない</td>\n        <td class=\"is-solution\"><span class=\"solstar-compare__check\">✓</span>専門用語はできるだけ使わず、分かりやすくご説明します</td>\n      </tr>\n      <tr>\n        <td class=\"is-problem\">着手後に費用が膨らむ</td>\n        <td class=\"is-solution\"><span class=\"solstar-compare__check\">✓</span>制作範囲と費用を事前に明確にし、範囲内なら追加費用は発生しません</td>\n      </tr>\n      <tr>\n        <td class=\"is-problem\">作って終わりで、社内で運用できない</td>\n        <td class=\"is-solution\"><span class=\"solstar-compare__check\">✓</span>納品後も自社で更新・運用しやすい形で設計・構築します</td>\n      </tr>\n      <tr>\n        <td class=\"is-problem\">納品後のサポート範囲が曖昧</td>\n        <td class=\"is-solution\"><span class=\"solstar-compare__check\">✓</span>不具合対応の範囲と期間を事前に明示します</td>\n      </tr>\n      <tr>\n        <td class=\"is-problem\">有料テーマの購入費が別途かかる</td>\n        <td class=\"is-solution\"><span class=\"solstar-compare__check\">✓</span>自社開発テーマ「Cream」を無料で利用できます（テーマ購入費0円）</td>\n      </tr>\n    </tbody>\n  </table>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_accordion_group_faq_domestic": {
      "type": "section-accordion-group",
      "blocks": {
        "faq_subheading_intro": {
          "type": "subheading",
          "settings": {
            "title": "FAQ"
          }
        },
        "faq_heading_intro": {
          "type": "heading",
          "settings": {
            "title": "「依頼して大丈夫かな？」その不安に、先にお答えします。"
          }
        },
        "faq_intro_01": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "丸投げになりませんか？",
            "content": "<p>「一緒に決める」進め方です。制作内容や仕様は書面で確認しながら進めるため、認識のズレが起きにくくなっています。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_intro_02": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "納品後、自社で運用できますか？",
            "content": "<p>本プランは、「自分たちで運用できる状態」までの設計・構築を前提としています。更新や運用を見据えた設計を行い、操作や更新方法の引き継ぎも行います。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_intro_03": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "しつこく営業されませんか？",
            "content": "<p>まずはヒアリングから。相談段階で契約の義務や費用は発生しません。無理な営業も一切行いません。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_shopify_01": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "まだ検討段階ですが、相談だけでも大丈夫ですか？",
            "content": "<p>もちろんです。まずはヒアリングで状況やお悩みをお聞かせください。Shopifyでできることや進め方を分かりやすくご説明します。ご相談だけでも歓迎です。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_shopify_02": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "金額は1,100,000円（税込）で確定ですか？",
            "content": "<p>標準範囲（商品登録20点／カテゴリ6点／アプリ連携3点／オリジナルページ制作3ページ）を含む最低価格です。制作範囲内であれば追加費用は発生しません。追加のご要望については、仕様確認の段階で書面にてお見積もりをご提示します。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_shopify_03": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "料金以外に何がかかりますか？",
            "content": "<p>Shopifyの月額利用料と各種アプリ利用料、有料テーマの購入費はお客様負担となります。ただし自社開発テーマ「Cream」をご利用いただく場合は、テーマ購入費はかかりません。納品後の保守・運用は、別途サービスとして承っています。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_shopify_04": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "納期と体制を教えてください。",
            "content": "<p>納期は約4〜8週間です。ディレクター1名、エンジニア1名の体制で対応します。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_shopify_05": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "納品物の著作権はどうなりますか？",
            "content": "<p>お支払い完了後、納品物の著作権はお客様に帰属します。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "faq_shopify_06": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "納品後に不具合が発生した場合は？",
            "content": "<p>お引き渡しから6ヶ月以内、当社の納品物に起因する不具合に対応します。また、ご確認時に修正が必要な箇所があれば、ご納得いただけるまで無償で対応します。</p><p>※納品後にお客様側で追加・変更された内容や、第三者アプリの導入に起因する不具合は対象外となります。</p>",
            "show_icon": false,
            "icon_name": "icon-chat",
            "icon_size": 20,
            "icon_color": ""
          }
        }
      },
