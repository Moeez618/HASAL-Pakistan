    "section_custom_code_QUFQdQ": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<section class=\"sol-concept\">\n  <div class=\"sol-concept__inner\">\n    <div class=\"sol-concept__header\">\n      <p class=\"sol-concept__label\">Concept</p>\n\n      <h2 class=\"sol-concept__title\">\n        ブランドらしさを伝え、運用しやすいECサイトをShopifyで構築\n      </h2>\n    </div>\n\n    <div class=\"sol-concept__grid\">\n      <div class=\"sol-concept__card\">\n        <h3 class=\"sol-concept__card-title\">\n          作りたいものと、出来上がるもののズレを防ぐ\n        </h3>\n\n        <p class=\"sol-concept__text\">\n          ECサイト制作でいちばん多い失敗は、作りたいものと出来上がるものがずれてしまうこと。私たちはブランドのコンセプト設計と制作内容のすり合わせを丁寧に行い、この食い違いを防ぎます。\n        </p>\n      </div>\n\n      <div class=\"sol-concept__card\">\n        <h3 class=\"sol-concept__card-title\">\n          コンセプト設計から品質確認まで一貫して担当\n        </h3>\n\n        <p class=\"sol-concept__text\">\n          SOLSTARは、ブランドの価値を整理するコンセプト設計から始め、認識をそろえながら、設計・構築・品質確認までを一貫して担当します。\n        </p>\n      </div>\n\n      <div class=\"sol-concept__card\">\n        <h3 class=\"sol-concept__card-title\">\n          分散した販売を、ブランドが伝わる自社ECサイトへ\n        </h3>\n\n        <p class=\"sol-concept__text\">\n          楽天・Amazon・Instagramなどに分散した販売を、ブランドの魅力が伝わる自社ECサイトへ。その設計をご支援します。\n        </p>\n      </div>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_custom_code_MWjcTp": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .solstar-benefits {\n    background: var(--COLOR-BG);\n    color: var(--COLOR-TEXT);\n    padding: 72px 20px;\n  }\n  .solstar-benefits * { box-sizing: border-box; }\n  .solstar-benefits__inner { max-width: 1120px; margin: 0 auto; }\n  .solstar-benefits__head { max-width: 760px; margin: 0 0 34px; }\n  .solstar-benefits__eyebrow {\n    margin: 0 0 12px;\n    color: var(--COLOR-ACCENT);\n    font-size: var(--font-body-medium);\n    font-weight: 700;\n    letter-spacing: var(--LETTER-SPACING-BODY);\n    text-transform: uppercase;\n  }\n  .solstar-benefits__title { margin: 0; font-size: var(--font-body-medium); line-height: 1.35; letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-benefits__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }\n  .solstar-benefits__card {\n    min-height: 178px;\n    padding: 24px;\n    border: 1px solid var(--COLOR-BORDER-LIGHT);\n    border-radius: 12px;\n    background: var(--COLOR-BG-ACCENT-LIGHTEN);\n  }\n  .solstar-benefits__num { display: block; margin-bottom: 28px; color: var(--COLOR-ACCENT); font-size: var(--font-body-medium); font-weight: 700; letter-spacing: var(--LETTER-SPACING-BODY); }\n  .solstar-benefits__card p { margin: 0; color: var(--COLOR-TEXT); font-size: var(--font-body-medium); font-weight: 700; line-height: 1.75; }\n  .solstar-benefits__note {\n    max-width: 860px;\n    margin: 18px 0 0;\n    color: var(--COLOR-TEXT-A80);\n    font-size: var(--font-body-medium);\n    line-height: 1.8;\n  }\n  @media (max-width: 900px) { .solstar-benefits__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }\n  @media (max-width: 640px) {\n    .solstar-benefits { padding: 52px 16px; }\n    .solstar-benefits__grid { grid-template-columns: 1fr; }\n    .solstar-benefits__card { min-height: auto; padding: 20px; }\n  }\n\n  /* Theme typography overrides */\n\n  .solstar-benefits {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    font-weight: var(--FONT-WEIGHT-BODY);\n    font-size: var(--font-body-medium);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  .solstar-benefits__eyebrow,\n  .solstar-benefits__num {\n    font-family: var(--FONT-STACK-SUBHEADING);\n    font-style: var(--FONT-STYLE-SUBHEADING);\n    font-weight: var(--FONT-WEIGHT-SUBHEADING);\n    font-size: var(--font-subheading);\n    letter-spacing: var(--LETTER-SPACING-SUBHEADING);\n    text-transform: var(--FONT-UPPERCASE-SUBHEADING);\n  }\n  .solstar-benefits__title {\n    font-family: var(--FONT-STACK-HEADING);\n    font-style: var(--FONT-STYLE-HEADING);\n    font-weight: var(--FONT-WEIGHT-HEADING);\n    font-size: var(--font-heading-large);\n    letter-spacing: var(--LETTER-SPACING-HEADING);\n    text-transform: var(--FONT-UPPERCASE-HEADING);\n  }\n  .solstar-benefits__card p,\n  .solstar-benefits__note {\n    font-family: var(--FONT-STACK-BODY);\n    font-style: var(--FONT-STYLE-BODY);\n    letter-spacing: var(--LETTER-SPACING-BODY);\n  }\n  /* End theme typography overrides */\n</style>\n<section class=\"solstar-benefits\">\n  <div class=\"solstar-benefits__inner\">\n    <div class=\"solstar-benefits__head\">\n      <p class=\"solstar-benefits__eyebrow\">What you get</p>\n      <h2 class=\"solstar-benefits__title\">ブランドを「自分たちで運用できる形」に。</h2>\n    </div>\n    <div class=\"solstar-benefits__grid\">\n      <article class=\"solstar-benefits__card\"><span class=\"solstar-benefits__num\">01</span><p>ブランドの想い・差別化・世界観を言語化するコンセプト設計から始めるため、ブランドの魅力が伝わるECサイトに</p></article>\n      <article class=\"solstar-benefits__card\"><span class=\"solstar-benefits__num\">02</span><p>モールやSNSに分散した販売を自社ECサイトに集約し、一貫した発信・運用ができる形に</p></article>\n      <article class=\"solstar-benefits__card\"><span class=\"solstar-benefits__num\">03</span><p>コンセプト設計から構築・確認までを一貫して担当するため、認識のズレが起きにくい</p></article>\n      <article class=\"solstar-benefits__card\"><span class=\"solstar-benefits__num\">04</span><p>専門知識がなくても、「何を決めればいいか」「次に何が起きるか」が分かる</p></article>\n      <article class=\"solstar-benefits__card\"><span class=\"solstar-benefits__num\">05</span><p>「丸投げ」ではなく「一緒に決める」進め方だから、納品後も自社で更新・運用しやすい</p></article>\n      <article class=\"solstar-benefits__card\"><span class=\"solstar-benefits__num\">06</span><p>自社開発テーマ「Cream」を無料利用可能（テーマ購入費0円）</p></article>\n    </div>\n    <p class=\"solstar-benefits__note\">お引き渡しから6ヶ月以内は、当社が制作した部分に起因する不具合に無償で対応（納品後にお客様側で加えた変更や、別途追加したアプリによる不具合は対象外です）</p>\n    <p class=\"solstar-benefits__note solstar-benefits__note--small\">※本プランの範囲は「自社で運用できる状態までの設計・構築」です。納品後の保守・運用は、別途サービスとして承っています。</p>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
