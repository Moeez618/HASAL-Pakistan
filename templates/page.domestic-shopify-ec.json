    "section_custom_code_YCJ9UU": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<section class=\"sp-sec\">\n  <div class=\"sp-inner\">\n    <div class=\"sp-head\">\n      <p class=\"sp-eyebrow\">Process</p>\n      <h2 class=\"sp-title\">無料相談から公開までの流れ</h2>\n      <p class=\"sp-lead\">Basicプランは、商品数が少なく短期間で立ち上げたい方向けのプランです。約6〜8週間を目安に、必要な設定を整理しながら公開まで進めます。</p>\n    </div>\n    <div class=\"sp-flow\">\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>01</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">無料相談・立ち上げ方針の整理</h3><p class=\"sp-flow__desc\">商品数、販売開始時期、必要なページ、運用体制を確認します。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>02</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">制作範囲・お見積もり確認</h3><p class=\"sp-flow__desc\">商品登録10点、コレクション登録3点、アプリ連携6点、進捗オンラインMTG3回を軸に範囲を整理します。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>03</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">テーマ選定・ストア基本設定</h3><p class=\"sp-flow__desc\">無料・有料テーマの選定、ストア情報、配送、決済、通知、販売チャネルなどの基本設定を進めます。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>04</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">商品・コレクション・アプリ設定</h3><p class=\"sp-flow__desc\">商品登録、コレクション登録、必要なShopifyアプリ連携を行い、運用しやすい状態に整えます。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>05</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">公開前チェック・修正対応</h3><p class=\"sp-flow__desc\">表示確認、スマートフォン確認、購入導線の確認、必要な修正を行います。</p></div></div>\n      <div class=\"sp-flow__item\"><div class=\"sp-flow__no\"><strong>06</strong></div><div class=\"sp-flow__body\"><h3 class=\"sp-flow__title\">公開・引き渡し</h3><p class=\"sp-flow__desc\">短期間でローンチできるよう、公開後に自社で更新しやすい状態でお渡しします。</p></div></div>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
