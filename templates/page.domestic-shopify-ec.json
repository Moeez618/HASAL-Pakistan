        },
        "text_yTngM7": {
          "type": "text",
          "settings": {
            "text": "<p>いきなり契約やお見積もりではありません。他社と比較検討中の段階でも歓迎です。事例を見ながらのご相談も可能です。</p>",
            "text_font_size": "body-x-small",
            "padding_bottom": 16
          }
