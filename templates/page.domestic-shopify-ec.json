    "section_custom_code_YCJ9UU": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  .solstar-flow {\n    --sf-bg: #fcfbf9;             /* 背景色 */\n    --sf-brand: #665035;          /* ブランドカラー（サイトのtheme-color） */\n    --sf-brand-deep: #4f3d27;     /* ホバー・濃色 */\n    --sf-ink: #221c14;            /* 本文 */\n    --sf-sub: #8a7c6a;            /* 補足テキスト */\n    --sf-line: #e8e0d3;           /* 罫線・ボーダー */\n    --sf-chip: #f1ebe0;           /* タグ背景 */\n    --sf-card: #ffffff;           /* アイコン地色 */\n    --sf-node: 48px;              /* アイコンサイズ（モバイル基準） */\n    --sf-gap: 96px;               /* アイコン間隔（モバイル縦） */\n    background: var(--sf-bg);\n    color: var(--sf-ink);\n    max-width: 820px;\n    margin: 0 auto;\n    padding: 44px 16px;\n    box-sizing: border-box;\n  }\n  .solstar-flow * { box-sizing: border-box; }\n\n  .solstar-flow__head {\n    text-align: center;\n    margin: 0 0 40px;\n  }\n  .solstar-flow__eyebrow {\n    font-size: 12px;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    color: var(--sf-brand);\n    margin: 0 0 14px;\n  }\n  .solstar-flow__title {\n    font-size: 24px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    line-height: 1.3;\n    margin: 0;\n  }\n  .solstar-flow__title::after {\n    content: \"\";\n    display: block;\n    width: 40px;\n    height: 2px;\n    background: var(--sf-brand);\n    margin: 18px auto 0;\n  }\n\n  .solstar-flow__list {\n    list-style: none;\n    margin: 0;\n    padding: 0;\n  }\n\n  /* ===== 基本（モバイル：縦並び） ===== */\n  .solstar-flow__item {\n    position: relative;\n    min-height: var(--sf-gap);\n    padding-left: calc(var(--sf-node) + 18px);\n  }\n  .solstar-flow__item:last-child {\n    min-height: var(--sf-node);\n  }\n  /* つなぎ線（縦） */\n  .solstar-flow__item::before {\n    content: \"\";\n    position: absolute;\n    left: calc(var(--sf-node) / 2);\n    top: var(--sf-node);\n    bottom: 0;\n    width: 1px;\n    transform: translateX(-50%);\n    background: var(--sf-line);\n    z-index: 0;\n  }\n  .solstar-flow__item:last-child::before { display: none; }\n\n  /* 番号アイコン */\n  .solstar-flow__node {\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: var(--sf-node);\n    height: var(--sf-node);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    border: 1px solid var(--sf-line);\n    border-radius: 50%;\n    background: var(--sf-card);\n    z-index: 1;\n    transition: border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;\n  }\n  .solstar-flow__step-label {\n    font-size: 8px;\n    letter-spacing: 0.18em;\n    color: var(--sf-sub);\n    line-height: 1;\n    margin-bottom: 2px;\n    transition: color 0.25s ease;\n  }\n  .solstar-flow__num {\n    font-size: 17px;\n    font-weight: 700;\n    line-height: 1;\n    color: var(--sf-brand);\n    transition: color 0.25s ease;\n  }\n  .solstar-flow__item:hover .solstar-flow__node {\n    background: var(--sf-brand);\n    border-color: var(--sf-brand);\n  }\n  .solstar-flow__item:hover .solstar-flow__num,\n  .solstar-flow__item:hover .solstar-flow__step-label {\n    color: #ffffff;\n  }\n\n  .solstar-flow__body { padding-top: 11px; }\n  .solstar-flow__name {\n    font-size: 16.5px;\n    font-weight: 700;\n    line-height: 1.6;\n    margin: 0;\n    letter-spacing: 0.02em;\n  }\n  .solstar-flow__note {\n    font-size: 13.5px;\n    color: var(--sf-sub);\n    line-height: 1.8;\n    margin: 6px 0 0;\n  }\n  .solstar-flow__tag {\n    display: inline-block;\n    font-size: 12.5px;\n    letter-spacing: 0.08em;\n    color: var(--sf-brand);\n    background: var(--sf-chip);\n    border-radius: 4px;\n    padding: 4px 10px;\n    margin-top: 9px;\n  }\n\n  /* ===== PC（横並びステッパー：横幅拡大・間隔拡張） ===== */\n  @media (min-width: 601px) {\n    .solstar-flow {\n      max-width: 1240px;\n      padding: 72px 40px;\n      --sf-node: 60px;\n    }\n    .solstar-flow__head { margin-bottom: 64px; }\n    .solstar-flow__title { font-size: 32px; }\n\n    .solstar-flow__list {\n      display: flex;\n      align-items: flex-start;\n    }\n    .solstar-flow__item {\n      flex: 1 1 0;\n      min-height: 0;\n      padding: 0 10px;\n      text-align: center;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n    .solstar-flow__node {\n      position: relative;\n      left: auto;\n      top: auto;\n      margin: 0 auto 22px;\n    }\n    .solstar-flow__num { font-size: 20px; }\n\n    .solstar-flow__item::before {\n      top: calc(var(--sf-node) / 2);\n      left: 50%;\n      right: auto;\n      bottom: auto;\n      width: 100%;\n      height: 1px;\n      transform: translateY(-50%);\n    }\n    .solstar-flow__item:last-child::before { display: none; }\n\n    .solstar-flow__item:hover .solstar-flow__node {\n      box-shadow: 0 6px 18px rgba(102, 80, 53, 0.16);\n    }\n\n    .solstar-flow__body { padding-top: 0; max-width: 180px; }\n    .solstar-flow__name { font-size: 15px; line-height: 1.55; }\n    .solstar-flow__note { font-size: 12px; line-height: 1.7; margin-top: 8px; }\n    .solstar-flow__tag { font-size: 11px; padding: 3px 9px; margin-top: 10px; }\n  }\n\n  /* ===== スクロール連動の遅延表示＋ステップごとの浮き上がり ===== */\n  @keyframes sf-rise {\n    from { opacity: 0; transform: translateY(28px); }\n    to   { opacity: 1; transform: translateY(0); }\n  }\n\n  /* スクロール駆動アニメーション対応ブラウザのみ適用（非対応時は通常表示） */\n  @supports (animation-timeline: view()) {\n    @media (prefers-reduced-motion: no-preference) {\n      /* セクションを基準にタイムラインを定義 */\n      .solstar-flow { view-timeline-name: --sf-reveal; view-timeline-axis: block; }\n\n      .solstar-flow__item {\n        opacity: 0;\n        animation: sf-rise both;\n        animation-timeline: --sf-reveal;\n        /* セクションが視界を覆う進行度に合わせて順次表示 */\n        animation-range: cover 0% cover 18%;\n      }\n      .solstar-flow__item:nth-child(1) { animation-range: cover 0%  cover 18%; }\n      .solstar-flow__item:nth-child(2) { animation-range: cover 6%  cover 24%; }\n      .solstar-flow__item:nth-child(3) { animation-range: cover 12% cover 30%; }\n      .solstar-flow__item:nth-child(4) { animation-range: cover 18% cover 36%; }\n      .solstar-flow__item:nth-child(5) { animation-range: cover 24% cover 42%; }\n      .solstar-flow__item:nth-child(6) { animation-range: cover 30% cover 48%; }\n      .solstar-flow__item:nth-child(7) { animation-range: cover 36% cover 54%; }\n      .solstar-flow__item:nth-child(8) { animation-range: cover 42% cover 60%; }\n      .solstar-flow__item:nth-child(9) { animation-range: cover 48% cover 66%; }\n    }\n  }\n</style>\n\n<section class=\"solstar-flow\">\n  <div class=\"solstar-flow__head\">\n    <p class=\"solstar-flow__eyebrow\">Our Process</p>\n    <h2 class=\"solstar-flow__title\">進め方</h2>\n  </div>\n\n  <ol class=\"solstar-flow__list\">\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">01</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">ヒアリング</p>\n        <p class=\"solstar-flow__note\">相談だけでもOK</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">02</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">概算のお見積もりをご提示</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">03</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">ブランドのコンセプト設計</p>\n        <span class=\"solstar-flow__tag\">Who / What / Why / How</span>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">04</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">制作内容・仕様の確認</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">05</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">正式なお見積もりをご提示</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">06</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">デザイン・構築</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">07</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">ご確認・修正対応</p>\n        <p class=\"solstar-flow__note\">ご納得いただけるまで無償で修正します</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">08</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">納品</p>\n      </div>\n    </li>\n    <li class=\"solstar-flow__item\">\n      <div class=\"solstar-flow__node\"><span class=\"solstar-flow__step-label\">STEP</span><span class=\"solstar-flow__num\">09</span></div>\n      <div class=\"solstar-flow__body\">\n        <p class=\"solstar-flow__name\">アフターサポート</p>\n        <p class=\"solstar-flow__note\">お引き渡しから6ヶ月以内、当社の納品物に起因する不具合に対応</p>\n      </div>\n    </li>\n  </ol>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
