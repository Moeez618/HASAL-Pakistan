    "section_custom_code_yebmBH": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<style>\n  /* ============================================================\n     0. フェードイン・アニメーション用のスタイル (共通追加)\n  ============================================================ */\n  .js-fade-in {\n    opacity: 0;\n    transform: translateY(40px);\n    transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n  }\n\n  .js-fade-in.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* ============================================================\n     1. コンセプト設計セクション (背景: 白 #ffffff)\n  ============================================================ */\n  #se-concept-section {\n    width: 100%;\n    margin: 0;\n    padding: 0 40px 20px; /* 上の余白を削除 */\n    box-sizing: border-box;\n    overflow: hidden;\n    background-color: #ffffff;\n  }\n\n  #se-concept-section * { box-sizing: border-box; }\n\n  .se-container {\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  /* 見出し位置の微調整（余白削除に伴う調整） */\n  .se-heading-wrapper {\n    text-align: center;\n    margin-bottom: 60px;\n    max-width: 800px;\n    margin-left: auto;\n    margin-right: auto;\n    padding-top: 60px; /* コンテンツとしての適切な間隔は維持 */\n  }\n\n  .se-section-title {\n    margin-bottom: 20px;\n    position: relative;\n    display: inline-block;\n    font-size: 32px;\n    font-weight: 800;\n    color: #000;\n  }\n\n  .se-lead-text {\n    text-align: left;\n    font-size: 16px;\n    line-height: 1.8;\n    color: #555;\n  }\n\n  .se-layout-wrapper {\n    display: flex;\n    flex-direction: column;\n    gap: 80px;\n  }\n\n  .se-card {\n    display: flex;\n    flex-direction: column;\n    position: relative;\n  }\n\n  .se-card-figure {\n    width: 100%;\n    position: relative;\n    overflow: hidden;\n    aspect-ratio: 16 / 9;\n    border-radius: 12px;\n  }\n\n  .se-card-figure img {\n    width: 100%;\n    height: 100%;\n    display: block;\n    object-fit: cover;\n  }\n\n  .se-card-body {\n    padding: 30px 0;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .se-card-header { margin-bottom: 16px; }\n  .se-card-title { margin: 0; font-size: 24px; font-weight: 700; color: #222; }\n  .se-card-title span.en-prefix {\n    display: block;\n    margin-bottom: 4px;\n    color: #004bbd;\n    font-size: 14px;\n    text-transform: uppercase;\n  }\n\n  .se-card-desc { margin-bottom: 24px; font-size: 15px; color: #666; font-weight: 500; }\n\n  .se-content-block { margin-bottom: 20px; }\n  \n  .se-label {\n    display: flex;\n    align-items: center;\n    margin-bottom: 10px;\n    font-size: 13px;\n    font-weight: 700;\n  }\n\n  .se-label-hearing::before,\n  .se-label-reflect::before {\n    display: inline-flex;\n    justify-content: center;\n    align-items: center;\n    width: 28px;\n    height: 28px;\n    margin-right: 10px;\n    flex-shrink: 0;\n    font-weight: bold;\n    border-radius: 50%;\n  }\n\n  .se-label-hearing::before { content: 'Q'; background: #f4f4f4; color: #333; }\n  .se-label-reflect::before { content: 'A'; background: #004bbd; color: #fff; }\n\n  .se-text-box {\n    padding: 16px 20px;\n    background: #f9f9f9;\n    border-radius: 8px;\n    color: #333;\n    font-size: 14px;\n    line-height: 1.7;\n  }\n\n  .se-text-box.is-reflect {\n    background: #e1effe;\n    color: #0c3668;\n  }\n\n  .se-text-box ul { margin: 0; padding-left: 20px; }\n  .se-text-box li { margin-bottom: 6px; }\n\n  /* Concept Animation Styles (既存のスライドインアニメーションを保持) */\n  .se-card .se-card-figure,\n  .se-card .se-card-body {\n    opacity: 0;\n    transition: opacity 1.0s ease-out, transform 1.0s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .se-card .se-card-figure { transform: translateY(30px); }\n  .se-card .se-card-body { transform: translateY(30px); transition-delay: 0.2s; }\n\n  @media (min-width: 768px) {\n    .se-lead-text { text-align: center; }\n    .se-card { flex-direction: row; align-items: center; gap: 60px; }\n    .se-card-figure, .se-card-body { width: 50%; padding: 0; margin: 0; }\n    .se-card:nth-child(even) { flex-direction: row-reverse; }\n    \n    .se-card:nth-child(odd) .se-card-figure { transform: translateX(-60px); }\n    .se-card:nth-child(odd) .se-card-body { transform: translateX(60px); }\n    .se-card:nth-child(even) .se-card-figure { transform: translateX(60px); }\n    .se-card:nth-child(even) .se-card-body { transform: translateX(-60px); }\n  }\n\n  .se-card.is-visible .se-card-figure,\n  .se-card.is-visible .se-card-body {\n    opacity: 1;\n    transform: translate(0, 0);\n  }\n\n  /* ============================================================\n     2. 構築実績セクション (背景: グレー #ececf0)\n  ============================================================ */\n  .solstar-testimonial {\n    padding: 40px 20px 0; /* 下の余白を削除 */\n    background-color: #ececf0;\n    color: #333;\n    box-sizing: border-box;\n  }\n\n  .solstar-testimonial-inner {\n    max-width: 1000px;\n    margin: 0 auto;\n    padding-bottom: 80px; /* カードの影を収めるための内側余白 */\n  }\n\n  .solstar-heading-wrapper {\n    text-align: center;\n    max-width: 800px;\n    margin: 0 auto 48px;\n  }\n\n  .solstar-heading {\n    font-size: 32px;\n    font-weight: 800;\n    color: #000;\n    margin-top: 0;\n    margin-bottom: 16px;\n  }\n\n  .solstar-sub-heading {\n    font-size: 16px;\n    color: #555;\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .solstar-testimonial-card {\n    background: #ffffff;\n    border: 1px solid #ddd;\n    border-radius: 24px;\n    padding: 40px;\n    box-shadow: 0 16px 40px rgba(0,0,0,0.05);\n    display: flex;\n    flex-direction: row;\n    gap: 40px;\n    height: 480px; \n    box-sizing: border-box;\n    overflow: hidden;\n  }\n\n  .solstar-col-img {\n    flex: 0 0 40%;\n    position: relative;\n    display: flex;\n    align-items: flex-start;\n    height: 100%;\n  }\n\n  .solstar-img-frame {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    border-radius: 16px;\n    overflow: hidden;\n    max-height: 100%; \n  }\n\n  .solstar-img-frame img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    transition: opacity 0.3s ease;\n  }\n\n  .solstar-col-text {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    text-align: left;\n    height: 100%;\n    padding-top: 10px;\n    box-sizing: border-box;\n  }\n\n  .solstar-label {\n    font-size: 13px;\n    font-weight: 700;\n    color: #004bbd;\n    margin-bottom: 24px;\n    display: block;\n    flex-shrink: 0;\n  }\n\n  .solstar-content-body {\n    flex-grow: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-start;\n    overflow: hidden;\n  }\n\n  .solstar-quote-heading {\n    font-size: 24px;\n    font-weight: 700;\n    line-height: 1.4;\n    color: #222;\n    margin-bottom: 20px;\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .solstar-body-text {\n    font-size: 15px;\n    line-height: 1.7;\n    color: #555;\n    display: -webkit-box;\n    -webkit-line-clamp: 4;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .solstar-divider {\n    width: 100%;\n    height: 1px;\n    background: #eee;\n    margin-bottom: 24px;\n    margin-top: 24px;\n    flex-shrink: 0;\n  }\n\n  .solstar-footer {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    flex-shrink: 0;\n  }\n\n  .solstar-author-name { font-size: 16px; font-weight: 700; color: #333; margin-bottom: 4px; }\n  .solstar-author-role { font-size: 13px; color: #666; }\n\n  .solstar-nav-buttons { display: flex; gap: 12px; }\n  .solstar-btn-arrow {\n    width: 44px;\n    height: 44px;\n    border-radius: 50%;\n    border: 1px solid #ccc;\n    background: #fff;\n    color: #333;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.2s ease;\n  }\n  .solstar-btn-arrow:hover { background: #004bbd; border-color: #004bbd; color: #ffffff; }\n\n  .solstar-anim-fade { animation: solstarFadeIn 0.4s ease-out forwards; }\n  @keyframes solstarFadeIn {\n    from { opacity: 0; transform: translateY(5px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  @media (max-width: 768px) {\n    .solstar-testimonial { padding: 40px 20px 0; }\n    .solstar-heading { font-size: 24px; }\n    .solstar-testimonial-card { flex-direction: column; padding: 24px; height: auto; min-height: 550px; }\n    .solstar-col-img { width: 100%; height: auto; }\n    .solstar-quote-heading { font-size: 20px; }\n  }\n</style>\n\n<section id=\"se-concept-section\">\n  <div class=\"se-container\">\n    <div class=\"se-heading-wrapper js-fade-in\">\n      <h2 class=\"se-section-title\">ブランドの魅力を伝えるECコンセプト設計</h2>\n      <p class=\"se-lead-text\">\n        ECサイトは、単なる「商品を並べる場所」ではありません。私たちはECサイト構築の前に、お客様の中にすでにあるブランドの想いや価値を整理し、サイト上でどう表現するかというコンセプト定義を徹底的に行います。<br>\n        最短2〜4週間という短期間で、ブランドの魅力が正しく伝わり、ファンを育てていけるECサイトを立ち上げるために、最も重要で欠かせないプロセスです。\n      </p>\n    </div>\n\n    <div class=\"se-layout-wrapper\">\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Persona.png?v=1771391011\" alt=\"Persona Image\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">Who</span>誰の心を動かしたいのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">ターゲットの表面的な属性だけでなく、その奥にある「感情」や「価値観」を捉えます。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>その商品はどんな人の悩みを解決するのですか？</li>\n                <li>ターゲットとなる方の年齢層や、日常の過ごし方、ライフスタイルは？</li>\n                <li>その人は普段どのような価値に共感してブランドを選びますか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              属性だけでなく価値観まで掘り下げて定義。感性に合わせた言葉選び、ビジュアル、情報設計を通じて、ブランドらしさが直感的に伝わる体験をつくります。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Branding_Image_copy.webp?v=1771390960\" alt=\"Why Branding Image\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">What</span>そのブランドは何故選ばれるのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">市場における立ち位置を整理し、他にはない「選ばれる理由」を言語化します。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>巨大モールではなく、あえて自社サイトで購入してもらう理由は？</li>\n                <li>競合商品と比較されたとき、あなたの商品が選ばれる理由は？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              市場での優位性を特定し、商品を手にしたお客様の未来（ベネフィット）を言語化。オリジナルテーマ「CREAM」の標準機能を活かし、迷わず購入できる体験を設計します。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Bag_Value.png?v=1771391059\" alt=\"Value Image\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">Why</span>なぜそのブランドが必要なのか？</h3>\n          </div>\n          <p class=\"se-card-desc\">ブランドに込めた「想い」を可視化し、共感によって選ばれるブランドへ導きます。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>なぜ、この商品を世に送り出そうと思ったのですか？</li>\n                <li>ブランドを通じて、どのような価値や理想の未来を実現したいですか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              創業ストーリーや想いを「ブランド紹介（About Us）」として形にし、信頼を獲得。価格競争に巻き込まれない、共感を軸にしたブランド基盤を構築します。\n            </div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"se-card\">\n        <div class=\"se-card-figure\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Store_design.png?v=1771391032\" alt=\"Store Design Image\" loading=\"lazy\">\n        </div>\n        <div class=\"se-card-body\">\n          <div class=\"se-card-header\">\n            <h3 class=\"se-card-title\"><span class=\"en-prefix\">How</span>どう見え、どう感じられたいか？</h3>\n          </div>\n          <p class=\"se-card-desc\">一貫したトーンで、ひと目で「このブランドらしい」と感じられる体験をつくります。</p>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-hearing\">ヒアリング</div>\n            <div class=\"se-text-box\">\n              <ul>\n                <li>ブランドの世界観として、大切にしたい雰囲気や印象はありますか？</li>\n                <li>ブランドカラーや、取り入れたいデザイン・表現はありますか？</li>\n              </ul>\n            </div>\n          </div>\n          <div class=\"se-content-block\">\n            <div class=\"se-label se-label-reflect\">サイトへの反映</div>\n            <div class=\"se-text-box is-reflect\">\n              デザインシステムを活用し、配色・フォント・配置を統一。Shopify認定資格を持つプロによるUI/UX設計で、ユーザーへの印象を丁寧に設計し信頼感を高めます。\n            </div>\n          </div>\n        </div>\n      </article>\n    </div>\n  </div>\n</section>\n\n<div class=\"solstar-testimonial\">\n  <div class=\"solstar-testimonial-inner\">\n    <div class=\"solstar-heading-wrapper js-fade-in\">\n      <h2 class=\"solstar-heading\">ECサイト構築実績</h2>\n      <p class=\"solstar-sub-heading\">立ち上げ初期でも成果に繋がった事例を一部ご紹介致します。</p>\n    </div>\n\n    <div class=\"solstar-testimonial-card js-fade-in\">\n      <div class=\"solstar-col-img\">\n        <div class=\"solstar-img-frame\">\n          <img id=\"solstar-img\" src=\"\" alt=\"Client Image\" loading=\"lazy\">\n        </div>\n      </div>\n      <div class=\"solstar-col-text\">\n        <span class=\"solstar-label\">お客様の声</span>\n        <div class=\"solstar-content-body\" id=\"solstar-anim-wrapper\">\n            <div class=\"solstar-quote-heading\" id=\"solstar-quote\"></div>\n            <div class=\"solstar-body-text\" id=\"solstar-body\"></div>\n        </div>\n        <div class=\"solstar-divider\"></div>\n        <div class=\"solstar-footer\">\n          <div class=\"solstar-author-info\">\n            <div class=\"solstar-author-name\" id=\"solstar-title\"></div>\n            <div class=\"solstar-author-role\" id=\"solstar-sub\"></div>\n          </div>\n          <div class=\"solstar-nav-buttons\">\n            <button type=\"button\" class=\"solstar-btn-arrow\" id=\"btn-prev\" aria-label=\"Previous\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg>\n            </button>\n            <button type=\"button\" class=\"solstar-btn-arrow\" id=\"btn-next\" aria-label=\"Next\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  /* Intersection Observer for Concept Section & Fade-in Animations */\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    const observer = new IntersectionObserver((entries, observer) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.15 }); // 15%表示されたら発火に調整\n\n    // 元々の左右スライド用カードを監視\n    document.querySelectorAll('.se-card').forEach(card => observer.observe(card));\n    // 今回追加した上部見出し・実績カードを監視\n    document.querySelectorAll('.js-fade-in').forEach(el => observer.observe(el));\n  });\n\n  /* Testimonial Data & Logic */\n  (function () {\n    const data = [\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_5.webp?v=1766473796\",\n        title: \"合同会社Rsworks\",\n        sub: \"キッチンブランド\",\n        body: \"ブランドの世界観と高級感を保ったECサイトを構築。キャンペーンではLINE登録単価30円、登録者2,306人を達成。\",\n        quote: \"洗練されたクリエイティブセンスで一目置くECサイトを構築していただき、とても満足しています。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_3.webp?v=1766473796\",\n        title: \"PAW MINT\",\n        sub: \"ペットブランド\",\n        body: \"ブランドの世界観をポップに表現したLPを制作。広告施策により2,000名以上のメルマガ登録獲得。\",\n        quote: \"可愛くポップなECサイトを作って頂きました。世界観の表現が素晴らしいです。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_2.webp?v=1766473796\",\n        title: \"株式会社EDGBLACK\",\n        sub: \"キッチンブランド\",\n        body: \"Shopify移行後、公開初月に27万円以上の売上を実現。\",\n        quote: \"とても丁寧かつ詳細に説明してくださったので、困ることは一切ありませんでした。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_1.webp?v=1766473795\",\n        title: \"株式会社ONETREE\",\n        sub: \"スニーカーブランド\",\n        body: \"公式ECサイトを約2か月で立ち上げ、公開初月に12万円以上の売上を達成されました。Shopifyを活用し、ブランドの認知拡大とファンづくりを進められています。\",\n        quote: \"調整にも柔軟に対応してもらえ、安心して任せられました。\"\n      },\n      {\n        img: \"https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Testimonials_4.webp?v=1766473796\",\n        title: \"SANDY HAZE\",\n        sub: \"水着ブランド\",\n        body: \"英語圏向け越境ECを構築。商品撮影から広告運用まで対応し、3ヶ月で月商100万円を達成。\",\n        quote: \"They made our first e-commerce site look amazing.\"\n      }\n    ];\n\n    let index = 0;\n    const imgEl = document.getElementById(\"solstar-img\");\n    const quoteEl = document.getElementById(\"solstar-quote\");\n    const bodyEl = document.getElementById(\"solstar-body\");\n    const titleEl = document.getElementById(\"solstar-title\");\n    const subEl = document.getElementById(\"solstar-sub\");\n    const animWrapper = document.getElementById(\"solstar-anim-wrapper\");\n\n    function render(i) {\n      const d = data[i];\n      imgEl.style.opacity = 0;\n      animWrapper.classList.remove('solstar-anim-fade');\n      void animWrapper.offsetWidth; \n      animWrapper.classList.add('solstar-anim-fade');\n\n      setTimeout(() => {\n          imgEl.src = d.img;\n          imgEl.onload = () => { imgEl.style.opacity = 1; };\n          quoteEl.textContent = d.quote; \n          bodyEl.textContent = d.body;\n          titleEl.textContent = d.title;\n          subEl.textContent = d.sub;\n      }, 100);\n    }\n\n    document.getElementById(\"btn-next\").addEventListener(\"click\", () => {\n      index = (index + 1) % data.length;\n      render(index);\n    });\n\n    document.getElementById(\"btn-prev\").addEventListener(\"click\", () => {\n      index = (index - 1 + data.length) % data.length;\n      render(index);\n    });\n\n    render(index);\n  })();\n</script>",
        "width": "wrapper--full",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
