    "section_custom_code_tzzkFE": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "{{ 'basic-plan.css' | asset_url | stylesheet_tag }}\n<section class=\"sol-problem\">\n  <div class=\"sol-problem__inner\">\n    <div class=\"sol-problem__layout\">\n      <div class=\"sol-problem__header\">\n        <p class=\"sol-problem__label\">Problem</p>\n\n        <h2 class=\"sol-problem__title\">\n          ECサイト制作で、こんな心当たりはありませんか？\n        </h2>\n\n        <p class=\"sol-problem__lead\">\n          見た目だけでなく、認識のずれ・進行の不安・公開後の運用まで。ECサイト制作では、事前に整理すべき課題があります。\n        </p>\n      </div>\n\n      <div class=\"sol-problem__content\">\n        <ul class=\"sol-problem__list\">\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                販売チャネルが分散し、ブランドの魅力や世界観がうまく伝わらない\n              </p>\n          </li>\n\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                制作会社に依頼したのに、思っていたものと違うものが出来上がったことがある\n              </p>\n          </li>\n\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                過去の制作で、意図が伝わらない・返信が遅い・追加費用がかさむ、といったことに苦労した\n              </p>\n          </li>\n\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                要望は伝えたのに、期待した提案が返ってこなかった\n              </p>\n          </li>\n\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                専門用語ばかりで判断できない／今さら修正をお願いしづらい\n              </p>\n          </li>\n\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                作った後、社内に運用ノウハウや人手が足りず、続けられるか不安\n              </p>\n          </li>\n\n          <li class=\"sol-problem__item\">\n              <span class=\"sol-problem__number\" aria-hidden=\"true\"></span>\n              <p class=\"sol-problem__text\">\n                価格だけで選んでしまい、結局つくり直しになるのではないかと不安\n              </p>\n          </li>\n        </ul>\n\n        <p class=\"sol-problem__note\">\n          ECサイト制作で大切なのは、見た目だけではありません。ブランドの意図を正しく共有し、公開後の運用まで見据えて設計することが重要です。\n        </p>\n      </div>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "section_custom_code_zRTjpe": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<section class=\"sol-approach\">\n  <div class=\"sol-approach__inner\">\n    <div class=\"sol-approach__layout\">\n      <div class=\"sol-approach__header\">\n        <p class=\"sol-approach__label\">Approach</p>\n\n        <h2 class=\"sol-approach__title\">\n          「伝わらない」をなくすために、私たちがしていること。\n        </h2>\n\n        <p class=\"sol-approach__lead\">\n          ECサイト制作では、見た目の完成度だけでなく、制作前の認識合わせと進行中のコミュニケーションが重要です。\n        </p>\n      </div>\n\n      <div class=\"sol-approach__content\">\n        <div class=\"sol-approach__insight\">\n          <h3 class=\"sol-approach__stat\">\n            約9割が、Web制作の外注で「失敗した経験がある」と回答\n          </h3>\n\n          <p class=\"sol-approach__text\">\n            Web制作を外注した企業の約9割が「失敗した経験がある」と回答しています。\n          </p>\n\n          <p class=\"sol-approach__text\">\n            その大半は、発注側のイメージや意図が、制作側に正しく伝わらないことに起因するといわれています。\n          </p>\n        </div>\n\n        <p class=\"sol-approach__subhead\">\n          だから私たちは、次のことを徹底しています。\n        </p>\n\n        <ol class=\"sol-approach__steps\">\n          <li class=\"sol-approach__step\">\n            <span class=\"sol-approach__number\" aria-hidden=\"true\"></span>\n            <p class=\"sol-approach__step-text\">\n              つくり始める前に、ブランドのコンセプト（誰に・何を・なぜ・どんな世界観で）を言語化し、プロジェクト全体の軸をそろえます。\n            </p>\n          </li>\n\n          <li class=\"sol-approach__step\">\n            <span class=\"sol-approach__number\" aria-hidden=\"true\"></span>\n            <p class=\"sol-approach__step-text\">\n              作る内容や進め方を書面で整理・確認し、認識のズレを防ぎます。\n            </p>\n          </li>\n\n          <li class=\"sol-approach__step\">\n            <span class=\"sol-approach__number\" aria-hidden=\"true\"></span>\n            <p class=\"sol-approach__step-text\">\n              専門用語はできるだけ使わず、判断に必要なことを分かりやすくご説明します。「聞きづらい」「修正を頼みづらい」をつくりません。\n            </p>\n          </li>\n\n          <li class=\"sol-approach__step\">\n            <span class=\"sol-approach__number\" aria-hidden=\"true\"></span>\n            <p class=\"sol-approach__step-text\">\n              コンセプト設計から構築・確認までを一貫して担当し、伝言による意図のズレを減らします。\n            </p>\n          </li>\n\n          <li class=\"sol-approach__step\">\n            <span class=\"sol-approach__number\" aria-hidden=\"true\"></span>\n            <p class=\"sol-approach__step-text\">\n              「作って終わり」にしないために、設計段階から「育てられるECサイト」を一緒に考えます。\n            </p>\n          </li>\n        </ol>\n      </div>\n    </div>\n  </div>\n</section>",
        "width": "wrapper--full",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
