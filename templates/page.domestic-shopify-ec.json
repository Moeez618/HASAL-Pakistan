    "section_reviews_Cfcb3N": {
      "type": "section-reviews",
      "blocks": {
        "review_f8k9mU": {
          "type": "review",
          "settings": {
            "title": "Paw Mint",
            "subheading": "ペットショップ",
            "review_content": "<p>商品企画、商品撮影、ECサイト構築、デジタルマーケティングと多岐に渡り支援をさせて頂きました。可愛いくオシャレなデザインにこだわったECサイトです。</p>",
            "featured_image": "shopify://shop_images/Testimonial_1_copy.png",
            "bio_image": "shopify://shop_images/Paw_Mint_Logo.png",
            "review_url": ""
          }
        },
        "review_6LGbjA": {
          "type": "review",
          "settings": {
            "title": "Sandy Haze",
            "subheading": "水着ショップ",
            "review_content": "<p>アメリカ発の水着専門ショップの越境ECサイト構築の支援をさせて頂きました。販促アプリを実装しCVR向上を強化しました。</p>",
            "featured_image": "shopify://shop_images/Testimonial_2_copy.png",
            "bio_image": "shopify://shop_images/Sandy_Haze.png",
            "review_url": ""
          }
        },
        "review_yRA7MM": {
          "type": "review",
          "settings": {
            "title": "Multi Paradox",
            "subheading": "セレクトショップ",
            "review_content": "<p>多機能な有料テーマを使用し、アプリを多用せずパフォーマンスにこだわりました。ハイブランドのECサイトのようにシンプルかつ見えやすい商品詳細画面が特徴です。</p>",
            "featured_image": "shopify://shop_images/Testimonial_4_copy.png",
            "bio_image": "shopify://shop_images/Multi_Paradox.png",
            "review_url": ""
          }
        },
        "review_fYHPcp": {
          "type": "review",
          "settings": {
            "title": "Shun Smith",
            "subheading": "アクセサリーショップ",
            "review_content": "<p>商品企画、モデル撮影、ECサイト構築の支援をさせて頂きました。白と黒を基調とした高級感溢れるレイアウトが特徴です。</p>",
            "featured_image": "shopify://shop_images/Testimonial_3_copy.png",
            "bio_image": "shopify://shop_images/Shun_Smith_1747169c-6276-4114-808b-e819b346b61e.png",
            "review_url": ""
          }
        }
      },
