    "section_custom_code_cream_pdp_overview": {
      "type": "section-custom-code",
      "name": "Cream product overview",
      "settings": {
        "code": "<style>.cream-overview{background:var(--COLOR-BG);color:var(--COLOR-TEXT);padding:84px 24px}.cream-overview__inner{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:minmax(0,.95fr) minmax(320px,1.05fr);gap:46px;align-items:center}.cream-overview__copy{text-align:left}.cream-overview .hero__subheading{color:var(--BTN-PRIMARY-BG);margin:0 0 16px;text-align:left}.cream-overview h2{margin:0;color:var(--COLOR-TEXT);text-align:left}.cream-overview__lead{margin:18px 0 0;line-height:1.9;color:var(--COLOR-TEXT);max-width:720px;text-align:left}.cream-overview__media{position:relative;overflow:hidden;background:var(--COLOR-BG);box-shadow:none}.cream-overview__media img{display:block;width:100%;height:auto}.cream-overview__stats{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:24px;margin:28px auto 0;text-align:center}.cream-overview__stat{background:var(--COLOR-BG);padding:0;text-align:center;opacity:1;transform:translateY(0);transition:opacity .6s ease-out,transform .6s ease-out}.cream-overview__stats.is-animated .cream-overview__stat:not(.is-visible){opacity:0;transform:translateY(24px)}.cream-overview__stat strong{display:block;font-size:clamp(40px,4.2vw,55px);font-weight:700;line-height:1.1;color:var(--COLOR-TEXT);font-feature-settings:'pnum' on,'lnum' on}.cream-overview__stat span{display:block;margin-top:8px;color:var(--COLOR-TEXT);font-weight:700;line-height:1.6;text-align:center}@media(max-width:899px){.cream-overview{padding:62px 16px}.cream-overview__inner{grid-template-columns:1fr}.cream-overview__copy{text-align:center}.cream-overview .hero__subheading{text-align:center}.cream-overview h2{text-align:center}.cream-overview__lead{margin:18px auto 0;text-align:center}.cream-overview__stats{grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}.cream-overview__stat strong{font-size:clamp(28px,9vw,40px)}.cream-overview__stat span{font-size:12px;line-height:1.45;word-break:keep-all}}</style><section class='cream-overview' id='cream-overview'><div class='cream-overview__inner'><div class='cream-overview__copy'><p class='cream-overview__eyebrow hero__subheading'>Overview</p><h2 class='heading-large'>日本のEC運用に必要な導線を、最初から整えたShopifyテーマ。</h2><p class='cream-overview__lead'>Creamは、SOLSTARが独自開発したShopifyテーマです。ECサイトの立ち上げから運用、集客導線、購入体験の改善までを見据えて設計しています。</p></div><div><div class='cream-overview__media'><img src='https://cdn.shopify.com/s/files/1/0704/2642/7614/files/Solstar_x_Customer_Result_Image_Fixed_copy.webp?v=1771409441' alt='CREAM by SOLSTAR storefront preview' loading='lazy'></div><div class='cream-overview__stats' aria-label='Cream included counts'><div class='cream-overview__stat'><strong class='cream-overview__count' data-value='69'>69</strong><span>セクション機能</span></div><div class='cream-overview__stat'><strong class='cream-overview__count' data-value='101'>101</strong><span>ブロック機能</span></div><div class='cream-overview__stat'><strong class='cream-overview__count' data-value='15'>15</strong><span>テーマ設定カテゴリ</span></div></div></div></div></section><script>(function(){function initCreamStats(){var sections=document.querySelectorAll('.cream-overview__stats');if(!sections.length)return;sections.forEach(function(section){if(section.dataset.creamStatsInitialized==='true')return;section.dataset.creamStatsInitialized='true';var items=section.querySelectorAll('.cream-overview__stat');var values=section.querySelectorAll('.cream-overview__count');var animated=false;section.classList.add('is-animated');function animateNumbers(){if(animated)return;animated=true;values.forEach(function(el){var target=parseFloat(el.getAttribute('data-value')||'0');var duration=1500;var start=null;el.textContent='0';function step(timestamp){if(!start)start=timestamp;var progress=Math.min((timestamp-start)/duration,1);var eased=1-Math.pow(1-progress,3);var current=Math.round(target*eased);el.textContent=String(current);if(progress<1){window.requestAnimationFrame(step)}else{el.textContent=String(target)}}window.requestAnimationFrame(step)})}function revealItems(){items.forEach(function(item,index){item.style.transitionDelay=(index*.12)+'s';item.classList.add('is-visible')})}function runAnimation(){revealItems();animateNumbers()}function isInViewport(el){var rect=el.getBoundingClientRect();var windowHeight=window.innerHeight||document.documentElement.clientHeight;return rect.top<windowHeight*.85&&rect.bottom>0}if('IntersectionObserver'in window){var observer=new IntersectionObserver(function(entries){entries.forEach(function(entry){if(entry.isIntersecting){runAnimation();observer.unobserve(section)}})},{root:null,threshold:.2});observer.observe(section);setTimeout(function(){if(!animated&&isInViewport(section)){runAnimation();observer.unobserve(section)}},300)}else{runAnimation()}})}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initCreamStats)}else{initCreamStats()}window.addEventListener('load',initCreamStats);document.addEventListener('shopify:section:load',initCreamStats)})();</script>",
