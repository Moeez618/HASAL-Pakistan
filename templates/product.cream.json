    "section_custom_code_cream_pdp_highlights": {
      "type": "section-custom-code",
      "name": "Cream product highlights",
      "settings": {
        "code": "<style>.cream-highlights{background:var(--COLOR-BG);color:var(--COLOR-TEXT);padding:82px 24px}.cream-highlights__inner{max-width:1240px;margin:0 auto}.cream-highlights__head{max-width:760px;margin:0 auto 36px;text-align:center}.cream-highlights .hero__subheading{color:var(--BTN-PRIMARY-BG);margin:0 0 16px;text-align:center}.cream-highlights h2{margin:0;color:var(--COLOR-TEXT);text-align:center}.cream-highlights__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:32px}.cream-highlights__card{background:var(--COLOR-BG);padding:0;min-height:0;display:flex;flex-direction:column}.cream-highlights__num{color:var(--COLOR-LINK);margin-bottom:18px}.cream-highlights__card h3{margin:0 0 12px;line-height:1.32;color:var(--COLOR-TEXT)}.cream-highlights__card p{margin:0;color:var(--COLOR-TEXT);line-height:1.8}@media(max-width:899px){.cream-highlights{padding:62px 0}.cream-highlights__head{padding:0 16px}.cream-highlights__grid{display:flex;gap:22px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding:0 16px 4px}.cream-highlights__card{flex:0 0 min(82vw,340px);scroll-snap-align:start}.cream-highlights__grid::-webkit-scrollbar{display:none}}</style><section class='cream-highlights'><div class='cream-highlights__inner'><div class='cream-highlights__head'><p class='cream-highlights__eyebrow hero__subheading'>Why Cream</p><h2 class='heading-large'>ブランドの魅力を、購入につなげる。</h2></div><div class='cream-highlights__grid'><article class='cream-highlights__card'><div class='cream-highlights__num'>01</div><h3>購入につながる導線をテーマ標準で用意</h3><p>追従カート、カートドロワー、送料無料進捗、アップセル、商品一覧からすぐにカート追加できる導線など、購入へ進むための接点を整えやすくします。</p></article><article class='cream-highlights__card'><div class='cream-highlights__num'>02</div><h3>商品訴求と回遊性を強化</h3><p>商品タブ、アコーディオン、レビュー、関連商品、最近見た商品、検索、フィルターなど、商品選びを支える機能をまとめて使えます。</p></article><article class='cream-highlights__card'><div class='cream-highlights__num'>03</div><h3>日本市場の運用に合わせやすい</h3><p>日本語表示、税込補足、LINE導線、モバイルメニューなど、日本のEC運用で求められやすい表示・導線を整えやすくしています。言語・通貨セレクターにも対応しているため、将来的な越境販売の準備にも活用できます。</p></article></div></div></section>",
        "width": "wrapper--full",
