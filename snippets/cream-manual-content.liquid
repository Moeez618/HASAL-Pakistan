{% doc %}
  Renders the Cream by Solstar operation manual as a dictionary-style document:
  hero (lede + version + in-page search), quick-access cards, hierarchical TOC
  (sticky sidebar on desktop, disclosure drawer on mobile), document-format body
  (no per-feature cards), and an advanced/internal section at the bottom.

  Content is fully server-rendered; JavaScript only adds enhancements
  (search, TOC scrollspy, copy-link buttons, drawer auto-close).
  All CSS/JS is scoped under .cmv3 so other pages are unaffected.

  @example
  {% render 'cream-manual-content' %}
{% enddoc %}

<style>
  @media (prefers-reduced-motion: no-preference) {
    html:has(.cmv3) {
      scroll-behavior: smooth;
    }
  }

  .cmv3 {
    --cmv3-text: #212121;
    --cmv3-muted: #5f5b54;
    --cmv3-faint: #8a857c;
    --cmv3-hair: #e8e4dc;
    --cmv3-panel: #f6f4ef;
    --cmv3-accent: #8a6a35;
    --cmv3-accent-bg: #f6f1e7;
    --cmv3-gold: #ab8c52;
    color: var(--cmv3-text);
    font-size: 1.5rem;
    line-height: 1.9;
    margin: 0 auto;
    max-width: 1160px;
    padding: 0 0 72px;
  }

  .cmv3 *,
  .cmv3 *::before,
  .cmv3 *::after {
    box-sizing: border-box;
  }

  .cmv3 h2,
  .cmv3 h3,
  .cmv3 h4,
  .cmv3 p,
  .cmv3 ul,
  .cmv3 ol,
  .cmv3 dl,
  .cmv3 table {
    margin: 0;
  }

  .cmv3 a {
    color: var(--cmv3-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .cmv3 a:hover {
    color: var(--cmv3-text);
  }

  /* Navigation-style links: no underline (must outrank .cmv3 a) */
  .cmv3 .cmv3-quick__card,
  .cmv3 .cmv3-toc__cat,
  .cmv3 .cmv3-toc ul a,
  .cmv3 .cmv3-toc-m ul a,
  .cmv3 .cmv3-search__results a,
  .cmv3 .cmv3-support__btn {
    text-decoration: none;
  }

  .cmv3 .cmv3-toc__cat {
    color: var(--cmv3-text);
  }

  .cmv3 .cmv3-support__btn,
  .cmv3 .cmv3-support__btn:hover {
    color: #fff;
  }

  .cmv3 code {
    background: var(--cmv3-panel);
    border: 1px solid var(--cmv3-hair);
    border-radius: 5px;
    color: var(--cmv3-text);
    font-size: 0.9em;
    padding: 0.05em 0.35em;
    word-break: break-all;
  }

  .cmv3 [id] {
    scroll-margin-top: 110px;
  }

  /* ===== Hero ===== */

  .cmv3-hero {
    border-bottom: 1px solid var(--cmv3-hair);
    display: grid;
    gap: 12px;
    justify-items: center;
    padding: 8px 0 32px;
    text-align: center;
  }

  .cmv3-hero__lede {
    color: var(--cmv3-muted);
    max-width: 620px;
  }

  .cmv3-hero__version {
    color: var(--cmv3-faint);
    font-size: 1.3rem;
  }

  .cmv3-search {
    margin-top: 6px;
    max-width: 560px;
    position: relative;
    width: 100%;
  }

  .cmv3-search input {
    background: #fff;
    border: 1px solid var(--cmv3-hair);
    border-radius: 999px;
    color: var(--cmv3-text);
    font-size: 1.5rem;
    line-height: 1.4;
    padding: 12px 20px;
    width: 100%;
  }

  .cmv3-search input:focus {
    border-color: var(--cmv3-gold);
    outline: 2px solid var(--cmv3-accent-bg);
  }

  .cmv3-search__results {
    background: #fff;
    border: 1px solid var(--cmv3-hair);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(33, 33, 33, 0.08);
    display: grid;
    left: 0;
    list-style: none;
    margin: 6px 0 0;
    max-height: 320px;
    overflow: auto;
    padding: 6px;
    position: absolute;
    right: 0;
    text-align: left;
    top: 100%;
    z-index: 30;
  }

  .cmv3-search__results[hidden] {
    display: none;
  }

  .cmv3-search__results a {
    border-radius: 8px;
    color: var(--cmv3-text);
    display: block;
    padding: 8px 12px;
    text-decoration: none;
  }

  .cmv3-search__results a:hover,
  .cmv3-search__results a:focus {
    background: var(--cmv3-accent-bg);
  }

  .cmv3-search__results a small {
    color: var(--cmv3-faint);
    display: block;
    font-size: 1.2rem;
  }

  .cmv3-search__empty {
    color: var(--cmv3-faint);
    font-size: 1.3rem;
    padding: 8px 12px;
  }

  /* ===== Quick access ===== */

  .cmv3-quick {
    display: grid;
    gap: 14px;
    padding: 28px 0 32px;
  }

  .cmv3-quick h2 {
    font-size: 1.4rem;
    color: var(--cmv3-faint);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .cmv3-quick__grid {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(3, 1fr);
  }

  .cmv3-quick__card {
    align-items: center;
    border: 1px solid var(--cmv3-hair);
    border-radius: 12px;
    column-gap: 12px;
    display: grid;
    grid-template-columns: 1fr auto;
    padding: 14px 18px;
    text-decoration: none;
  }

  .cmv3-quick__card:hover {
    background: var(--cmv3-accent-bg);
    border-color: var(--cmv3-gold);
  }

  .cmv3-quick__t {
    color: var(--cmv3-text);
    font-weight: 600;
    line-height: 1.5;
  }

  .cmv3-quick__s {
    color: var(--cmv3-faint);
    font-size: 1.2rem;
    grid-column: 1;
  }

  .cmv3-quick__arrow {
    color: var(--cmv3-accent);
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  /* ===== Layout ===== */

  .cmv3-layout {
    align-items: start;
    display: grid;
    gap: clamp(28px, 4vw, 56px);
    grid-template-columns: 248px minmax(0, 1fr);
    padding-top: 8px;
  }

  .cmv3-body {
    display: grid;
    gap: 8px;
    max-width: 760px;
    min-width: 0;
  }

  .cmv3-cat,
  .cmv3-item {
    min-width: 0;
  }

  /* ===== TOC (shared styles) ===== */

  .cmv3-toc,
  .cmv3-toc-m {
    font-size: 1.35rem;
    line-height: 1.6;
  }

  .cmv3-toc {
    border-right: 1px solid var(--cmv3-hair);
    max-height: calc(100vh - 120px);
    overflow: auto;
    overscroll-behavior: contain;
    padding: 8px 16px 24px 2px;
    position: sticky;
    top: 96px;
  }

  .cmv3-toc details {
    border-bottom: 1px solid var(--cmv3-hair);
    padding: 2px 0;
  }

  .cmv3-toc summary,
  .cmv3-toc__cat {
    align-items: baseline;
    color: var(--cmv3-text);
    cursor: pointer;
    display: flex;
    font-weight: 600;
    gap: 8px;
    list-style: none;
    min-height: 40px;
    align-items: center;
    padding: 4px 6px;
    text-decoration: none;
  }

  .cmv3-toc summary::-webkit-details-marker {
    display: none;
  }

  .cmv3-toc summary::after {
    border-bottom: 1.5px solid var(--cmv3-faint);
    border-right: 1.5px solid var(--cmv3-faint);
    content: '';
    height: 7px;
    margin-left: auto;
    transform: rotate(45deg);
    transition: transform 0.15s ease;
    width: 7px;
  }

  .cmv3-toc details[open] > summary::after {
    transform: rotate(225deg);
  }

  .cmv3-no {
    color: var(--cmv3-gold);
    font-size: 0.85em;
    font-variant-numeric: tabular-nums;
  }

  .cmv3-toc ul,
  .cmv3-toc-m ul {
    display: grid;
    list-style: none;
    margin: 0;
    padding: 0 0 8px;
  }

  .cmv3-toc ul a,
  .cmv3-toc-m ul a {
    border-left: 2px solid transparent;
    color: var(--cmv3-muted);
    display: block;
    padding: 6px 6px 6px 22px;
    text-decoration: none;
  }

  .cmv3-toc ul a:hover {
    color: var(--cmv3-text);
  }

  .cmv3-toc ul a.is-active {
    border-left-color: var(--cmv3-gold);
    color: var(--cmv3-accent);
    font-weight: 600;
  }

  /* ===== Mobile TOC drawer ===== */

  .cmv3-toc-m {
    display: none;
  }

  /* ===== Body: categories & items ===== */

  .cmv3-cat {
    border-top: 2px solid var(--cmv3-text);
    margin-top: 40px;
    padding-top: 20px;
  }

  .cmv3-cat:first-child {
    border-top: 0;
    margin-top: 0;
  }

  .cmv3-cat > h2 {
    align-items: baseline;
    display: flex;
    font-size: 2.2rem;
    gap: 12px;
    line-height: 1.35;
  }

  .cmv3-lead {
    color: var(--cmv3-muted);
    padding-top: 10px;
  }

  .cmv3-cat > h3 {
    font-size: 1.6rem;
    padding-top: 22px;
  }

  .cmv3-cat > h3 + p,
  .cmv3-cat > h3 + ul {
    padding-top: 6px;
  }

  .cmv3-item {
    border-top: 1px solid var(--cmv3-hair);
    display: grid;
    gap: 10px;
    margin-top: 26px;
    padding-top: 22px;
  }

  .cmv3-item > h3 {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    font-size: 1.8rem;
    gap: 10px;
    line-height: 1.4;
  }

  .cmv3-item > h4 {
    font-size: 1.5rem;
    padding-top: 8px;
  }

  .cmv3-item > p,
  .cmv3-item li {
    color: var(--cmv3-muted);
  }

  .cmv3-item > p:first-of-type {
    color: var(--cmv3-text);
  }

  .cmv3-badge {
    background: var(--cmv3-panel);
    border: 1px solid var(--cmv3-hair);
    border-radius: 999px;
    color: var(--cmv3-muted);
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.6;
    padding: 1px 10px;
    white-space: nowrap;
  }

  .cmv3-place {
    background: var(--cmv3-panel);
    border-radius: 8px;
    color: var(--cmv3-muted);
    font-size: 1.35rem;
    padding: 6px 12px;
    width: fit-content;
  }

  .cmv3-place span {
    color: var(--cmv3-faint);
    font-size: 1.2rem;
    margin-right: 10px;
  }

  .cmv3-cap {
    color: var(--cmv3-faint);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .cmv3-settings ul {
    columns: 2;
    column-gap: 32px;
    padding: 4px 0 0 20px;
  }

  .cmv3-settings li {
    break-inside: avoid;
    padding: 1px 0;
  }

  .cmv3-settings ul li::marker,
  .cmv3-item ul li::marker {
    color: var(--cmv3-gold);
  }

  .cmv3-steps ol,
  .cmv3-item ol {
    display: grid;
    gap: 4px;
    padding: 4px 0 0 22px;
  }

  .cmv3-steps li::marker,
  .cmv3-item ol li::marker {
    color: var(--cmv3-accent);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  .cmv3-item > ul {
    display: grid;
    gap: 4px;
    padding-left: 20px;
  }

  .cmv3-blocks .cmv3-cap {
    margin-right: 10px;
  }

  .cmv3-blocks {
    color: var(--cmv3-muted);
  }

  /* ===== Callouts ===== */

  .cmv3-note {
    border-left: 3px solid var(--cmv3-hair);
    border-radius: 0 8px 8px 0;
    color: var(--cmv3-muted);
    font-size: 1.4rem;
    padding: 8px 14px;
  }

  .cmv3-note strong {
    font-weight: 700;
  }

  .cmv3-note--warn {
    background: #faf3e4;
    border-left-color: #c39441;
  }

  .cmv3-note--warn strong {
    color: #8a5f1d;
  }

  .cmv3-note--hint {
    background: #eef3ef;
    border-left-color: #6f9880;
  }

  .cmv3-note--hint strong {
    color: #44634f;
  }

  .cmv3-note--ext {
    background: #edf2f6;
    border-left-color: #7592a7;
  }

  .cmv3-note--ext strong {
    color: #47637a;
  }

  .cmv3-note--spec,
  .cmv3-note--internal {
    background: var(--cmv3-panel);
    border-left-color: #b6b0a5;
  }

  .cmv3-note--spec strong,
  .cmv3-note--internal strong {
    color: var(--cmv3-muted);
  }

  /* ===== Tables ===== */

  .cmv3-tablewrap {
    margin-top: 6px;
    overflow-x: auto;
  }

  .cmv3-tablewrap table {
    border-collapse: collapse;
    font-size: 1.35rem;
    min-width: 540px;
    width: 100%;
  }

  .cmv3-tablewrap th {
    border-bottom: 2px solid var(--cmv3-text);
    color: var(--cmv3-text);
    font-weight: 600;
    padding: 8px 14px 8px 0;
    text-align: left;
    white-space: nowrap;
  }

  .cmv3-tablewrap td {
    border-bottom: 1px solid var(--cmv3-hair);
    color: var(--cmv3-muted);
    padding: 8px 14px 8px 0;
    vertical-align: top;
  }

  /* ===== Copy-link button (added by JS) ===== */

  .cmv3-copy {
    background: none;
    border: 0;
    border-radius: 6px;
    color: var(--cmv3-faint);
    cursor: pointer;
    font-size: 1.3rem;
    line-height: 1;
    min-height: 32px;
    min-width: 32px;
    opacity: 0.6;
    padding: 4px;
  }

  .cmv3-copy:hover,
  .cmv3-copy:focus {
    background: var(--cmv3-accent-bg);
    color: var(--cmv3-accent);
    opacity: 1;
  }

  .cmv3-copy.is-copied {
    color: var(--cmv3-accent);
    opacity: 1;
  }

  /* ===== Support CTA ===== */

  .cmv3-support {
    border: 1px solid var(--cmv3-hair);
    border-radius: 14px;
    display: grid;
    gap: 8px;
    justify-items: start;
    margin-top: 48px;
    padding: 24px 28px;
  }

  .cmv3-support h2 {
    font-size: 1.7rem;
  }

  .cmv3-support p {
    color: var(--cmv3-muted);
  }

  .cmv3-support__btn {
    background: var(--cmv3-accent);
    border-radius: 999px;
    color: #fff;
    display: inline-block;
    font-weight: 600;
    margin-top: 6px;
    min-height: 44px;
    padding: 10px 26px;
    text-decoration: none;
  }

  .cmv3-support__btn:hover {
    background: var(--cmv3-text);
    color: #fff;
  }

  /* ===== Responsive ===== */

  @media (max-width: 1023px) {
    .cmv3-layout {
      grid-template-columns: 208px minmax(0, 1fr);
    }
  }

  @media (max-width: 899px) {
    .cmv3-toc {
      display: none;
    }

    .cmv3-layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .cmv3-quick__grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .cmv3-toc-m {
      background: #fff;
      border: 1px solid var(--cmv3-hair);
      border-radius: 12px;
      display: block;
      margin-top: 20px;
      padding: 0 14px;
      position: sticky;
      top: 76px;
      z-index: 20;
    }

    .cmv3-toc-m > summary {
      align-items: center;
      color: var(--cmv3-text);
      cursor: pointer;
      display: flex;
      font-weight: 600;
      justify-content: space-between;
      list-style: none;
      min-height: 46px;
    }

    .cmv3-toc-m > summary::-webkit-details-marker {
      display: none;
    }

    .cmv3-toc-m > summary::after {
      border-bottom: 1.5px solid var(--cmv3-faint);
      border-right: 1.5px solid var(--cmv3-faint);
      content: '';
      height: 7px;
      transform: rotate(45deg);
      width: 7px;
    }

    .cmv3-toc-m[open] > summary::after {
      transform: rotate(225deg);
    }

    .cmv3-toc-m__inner {
      border-top: 1px solid var(--cmv3-hair);
      max-height: 60vh;
      overflow: auto;
      overscroll-behavior: contain;
      padding: 8px 0 12px;
    }

    .cmv3-toc-m details {
      border-bottom: 1px solid var(--cmv3-hair);
    }

    .cmv3-toc-m summary,
    .cmv3-toc-m .cmv3-toc__cat {
      align-items: center;
      color: var(--cmv3-text);
      cursor: pointer;
      display: flex;
      font-weight: 600;
      gap: 8px;
      list-style: none;
      min-height: 44px;
      padding: 4px 6px;
      text-decoration: none;
    }

    .cmv3-toc-m summary::-webkit-details-marker {
      display: none;
    }

    .cmv3-toc-m ul a {
      min-height: 40px;
      display: flex;
      align-items: center;
    }

    .cmv3-settings ul {
      columns: 1;
    }

    .cmv3-cat > h2 {
      font-size: 1.9rem;
    }

    .cmv3-item > h3 {
      font-size: 1.65rem;
    }
  }
</style>

