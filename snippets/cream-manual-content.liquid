{% doc %}
  Renders the Cream by Solstar operation manual as static, server-rendered HTML.
  Content mirrors the Cream repository manual (v4.1.0) in full.
  Styling relies only on Broadcast color-scheme CSS variables so the look
  follows the color scheme assigned to the hosting Custom code section.

  @example
  {% render 'cream-manual-content' %}
{% enddoc %}

<style>
  @media (prefers-reduced-motion: no-preference) {
    html:has(.cream-manual) {
      scroll-behavior: smooth;
    }
  }

  .cream-manual {
    --cm-border: var(--border-light, rgba(128, 128, 128, 0.25));
    --cm-panel: var(--text-a5, rgba(128, 128, 128, 0.06));
    --cm-muted: var(--text-a80, currentColor);
    color: var(--text);
    display: grid;
    gap: clamp(28px, 5vw, 48px);
    line-height: 1.85;
    margin: 0 auto;
    max-width: 1120px;
    padding: 8px 0 72px;
  }

  .cream-manual *,
  .cream-manual *::before,
  .cream-manual *::after {
    box-sizing: border-box;
  }

  .cream-manual h2,
  .cream-manual h3,
  .cream-manual h4,
  .cream-manual h5,
  .cream-manual p,
  .cream-manual dl,
  .cream-manual dd,
  .cream-manual ul {
    margin: 0;
  }

  .cream-manual code {
    background: var(--cm-panel);
    border: 1px solid var(--cm-border);
    border-radius: 6px;
    color: var(--text);
    font-size: 0.9em;
    padding: 0.1em 0.4em;
    word-break: break-all;
  }

  /* ===== Intro ===== */

  .cm-intro {
    border: 1px solid var(--cm-border);
    border-radius: 24px;
    display: grid;
    gap: 18px;
    padding: clamp(24px, 4.5vw, 48px);
  }

  .cm-intro__eyebrow {
    color: var(--cm-muted);
    font-size: 1.2rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .cm-intro__title {
    font-size: clamp(2.6rem, 5vw, 5.2rem);
    line-height: 1.1;
  }

  .cm-intro__lede {
    color: var(--cm-muted);
    max-width: 780px;
  }

  /* ===== Layout: sticky TOC + content ===== */

  .cm-layout {
    align-items: start;
    display: grid;
    gap: clamp(24px, 4vw, 48px);
    grid-template-columns: minmax(220px, 0.27fr) minmax(0, 1fr);
  }

  .cm-toc {
    border: 1px solid var(--cm-border);
    border-radius: 18px;
    max-height: calc(100vh - 130px);
    overflow: auto;
    overscroll-behavior: contain;
    padding: 16px;
    position: sticky;
    top: 100px;
  }

  .cm-toc summary {
    color: var(--cm-muted);
    cursor: pointer;
    font-size: 1.2rem;
    letter-spacing: 0.12em;
    list-style: none;
    text-transform: uppercase;
  }

  .cm-toc summary::-webkit-details-marker {
    display: none;
  }

  .cm-toc summary::after {
    content: ' +';
  }

  .cm-toc details[open] summary::after {
    content: ' −';
  }

  .cm-toc__links {
    display: grid;
    gap: 2px;
    padding-top: 10px;
  }

  .cm-toc__link {
    border-radius: 10px;
    color: var(--text);
    display: block;
    font-size: 1.4rem;
    padding: 6px 10px;
    text-decoration: none;
  }

  .cm-toc__link:hover {
    background: var(--cm-panel);
    color: var(--text);
  }

  .cm-toc__link--sub {
    color: var(--cm-muted);
    font-size: 1.3rem;
    margin-left: 14px;
  }

  /* ===== Chapters ===== */

  .cm-content {
    display: grid;
    gap: clamp(36px, 6vw, 64px);
  }

  .cm-chapter {
    display: grid;
    gap: 22px;
  }

  .cm-chapter__head {
    align-items: baseline;
    border-bottom: 1px solid var(--cm-border);
    display: flex;
    gap: 14px;
    padding-bottom: 14px;
  }

  .cm-chapter__no {
    color: var(--BTN-PRIMARY-BG, var(--accent));
    font-size: 1.4rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.1em;
  }

  .cm-chapter__head h2 {
    font-size: clamp(2rem, 3.4vw, 3.2rem);
    line-height: 1.25;
  }

  .cm-chapter__body {
    display: grid;
    gap: 18px;
  }

  /* ===== Groups (section catalog categories) ===== */

  .cm-group {
    display: grid;
    gap: 14px;
  }

  .cm-group__title {
    color: var(--cm-muted);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    padding-top: 8px;
  }

  .cm-group__cards {
    display: grid;
    gap: 14px;
  }

  /* ===== Cards ===== */

  .cm-card {
    background: var(--cm-panel);
    border: 1px solid var(--cm-border);
    border-radius: 16px;
    display: grid;
    gap: 12px;
    padding: clamp(16px, 3vw, 26px);
  }

  .cm-card__title {
    font-size: 1.7rem;
    line-height: 1.4;
  }

  .cm-card--nested {
    background: none;
    border-left: 3px solid var(--BTN-PRIMARY-BG, var(--accent));
    border-radius: 0 16px 16px 0;
    margin-left: clamp(8px, 2vw, 22px);
  }

  .cm-card__tag {
    border: 1px solid var(--cm-border);
    border-radius: 999px;
    color: var(--cm-muted);
    display: inline-block;
    font-size: 1.1rem;
    letter-spacing: 0.08em;
    line-height: 1.6;
    margin-right: 10px;
    padding: 1px 10px;
    vertical-align: 0.15em;
  }

  /* ===== Labeled rows ===== */

  .cm-rows {
    display: grid;
    gap: 8px;
  }

  .cm-chapter__body > .cm-rows,
  .cm-chapter__body > .cm-list {
    background: var(--cm-panel);
    border: 1px solid var(--cm-border);
    border-radius: 16px;
    padding: clamp(16px, 3vw, 26px);
  }

  .cm-row {
    display: grid;
    gap: 2px 14px;
    grid-template-columns: minmax(64px, max-content) 1fr;
  }

  .cm-row dt {
    padding-top: 0.1em;
  }

  .cm-row dd {
    color: var(--cm-muted);
  }

  .cm-label {
    align-self: start;
    border: 1px solid var(--cm-border);
    border-radius: 999px;
    color: var(--text);
    display: inline-block;
    font-size: 1.15rem;
    justify-self: start;
    line-height: 1.7;
    padding: 2px 12px;
    text-align: center;
    white-space: nowrap;
    width: fit-content;
  }

  .cm-label--lead {
    background: var(--BTN-PRIMARY-BG, var(--accent));
    border-color: var(--BTN-PRIMARY-BG, var(--accent));
    color: var(--BTN-PRIMARY-TEXT, var(--COLOR-BG));
  }

  .cm-label--muted {
    border-style: dashed;
    color: var(--cm-muted);
  }

  .cm-label--warn {
    border-color: var(--BTN-PRIMARY-BG, var(--accent));
    color: var(--BTN-PRIMARY-BG, var(--accent));
    font-weight: 600;
  }

  .cm-rows--files .cm-label {
    border-radius: 8px;
    white-space: normal;
    word-break: break-all;
  }

  .cm-rows--files .cm-row {
    grid-template-columns: minmax(150px, max-content) 1fr;
  }

  .cm-list {
    display: grid;
    gap: 8px;
    padding-left: 20px;
  }

  .cm-list li {
    color: var(--cm-muted);
  }

  .cm-list .cm-label {
    margin-right: 4px;
  }

  /* anchor offset for sticky header */
  .cream-manual [id^='cm-'] {
    scroll-margin-top: 120px;
  }

  @media (max-width: 899px) {
    .cm-layout {
      grid-template-columns: 1fr;
    }

    .cm-toc {
      max-height: none;
      position: static;
    }

    .cm-row {
      grid-template-columns: 1fr;
    }

    .cm-row dd {
      padding-left: 2px;
    }

    .cm-rows--files .cm-row {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 900px) {
    .cm-toc summary {
      pointer-events: none;
    }

    .cm-toc summary::after {
      content: '';
    }
  }
</style>

<div class="cream-manual">
<header class="cm-intro">
<p class="cm-intro__eyebrow">Operation manual</p>
<h2 class="cm-intro__title">Cream by Solstar マニュアル</h2>
<p class="cm-intro__lede">本書は Shopify テーマ「Cream by Solstar」の現行実装をもとに、機能概要と編集ポイントを整理した運用マニュアルです。</p>
<dl class="cm-rows">
<div class="cm-row">
<dt class="cm-label">確認基準</dt>
<dd>
<code>config/settings_schema.json</code> / <code>templates/</code> / <code>sections/</code> / <code>blocks/</code>
</dd>
</div>
<div class="cm-row">
<dt class="cm-label">対象バージョン</dt>
<dd>
<code>4.1.0</code>
</dd>
</div>
<div class="cm-row">
<dt class="cm-label cm-label--muted">補足</dt>
<dd>Shopify テーマエディタで調整する内容を中心にまとめています。<code>_</code> で始まる内部ブロックやレンダリング用セクションは、通常運用では直接編集しません。</dd>
</div>
</dl>
</header>

  <div class="cm-layout">
