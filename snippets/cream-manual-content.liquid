</div>

<script>
(() => {
  const root = document.querySelector('.cmv3');
  if (!root || root.dataset.initialized === 'true') return;
  root.dataset.initialized = 'true';

  /* ---------- In-page search ---------- */
  const searchBox = root.querySelector('[data-cmv3-search]');
  const input = searchBox && searchBox.querySelector('input');
  const results = searchBox && searchBox.querySelector('.cmv3-search__results');
  const tocLinks = [...root.querySelectorAll('a[data-toc]')];
  const mobileToc = root.querySelector('.cmv3-toc-m');
  const escapeSelector = (value) => (window.CSS && typeof window.CSS.escape === 'function' ? window.CSS.escape(value) : value.replace(/([^a-zA-Z0-9_-])/g, '\\$1'));

  const navigateToId = (id) => {
    if (!id) return;
    const target = root.querySelector(`#${escapeSelector(id)}`);
    if (!target) return;
    history.replaceState(null, '', `#${id}`);
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (mobileToc) mobileToc.removeAttribute('open');
  };

  tocLinks.forEach((link) => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href') || '';
      if (!href.startsWith('#')) return;
      e.preventDefault();
      navigateToId(href.slice(1));
    });
  });

  if (input && results) {
    const index = [];
    root.querySelectorAll('.cmv3-cat').forEach((cat) => {
      const catTitle = cat.querySelector('h2').textContent.trim().replace(/^\d+\s*/, '');
      const catTitleLower = catTitle.toLowerCase();
      index.push({
        id: cat.id,
        kind: 'category',
        title: catTitle,
        titleLower: catTitleLower,
        sub: 'カテゴリ',
        subLower: 'カテゴリ',
        text: catTitleLower
      });
      cat.querySelectorAll('.cmv3-item').forEach((item) => {
        const title = item.querySelector('h3').textContent.trim();
        const titleLower = title.toLowerCase();
        const keywords = (item.dataset.kw || '').toLowerCase();
        const place = item.querySelector('.cmv3-place');
        const settings = item.querySelector('.cmv3-settings');
        const subLower = catTitleLower;
        const text = [title, keywords, place ? place.textContent : '', settings ? settings.textContent : '']
          .join(' ')
          .toLowerCase();
        index.push({
          id: item.id,
          kind: 'item',
          title,
          titleLower,
          sub: catTitle,
          subLower,
          text
        });
      });
    });

    input.setAttribute('role', 'combobox');
    input.setAttribute('aria-expanded', 'false');
    input.setAttribute('aria-controls', 'cmv3-search-results');
    results.id = 'cmv3-search-results';

    const close = () => {
      results.hidden = true;
      input.setAttribute('aria-expanded', 'false');
    };

    const escapeHtml = (value) => value.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));

    const getScore = (entry, query, terms) => {
      let score = entry.kind === 'item' ? 20 : 0;
      if (entry.titleLower === query) score += 120;
      if (entry.titleLower.startsWith(query)) score += 70;
      if (entry.titleLower.includes(query)) score += 35;
      terms.forEach((term) => {
        if (entry.titleLower.includes(term)) score += 24;
        if (entry.subLower.includes(term)) score += 8;
        if (entry.text.includes(term)) score += 4;
      });
      return score;
    };

    const render = (query) => {
      const q = query.trim().toLowerCase();
      if (!q) {
        close();
        return;
      }
      const terms = q.split(/\s+/);
      const hits = index
        .filter((entry) => terms.every((term) => entry.text.includes(term)))
        .map((entry) => ({ ...entry, score: getScore(entry, q, terms) }))
        .sort((a, b) => b.score - a.score || (a.kind === b.kind ? a.title.length - b.title.length : a.kind === 'item' ? -1 : 1))
        .slice(0, 8);
      results.innerHTML = hits.length
        ? hits
            .map(
              (e) =>
                `<li><a href="#${e.id}">${escapeHtml(e.title)}<small>${escapeHtml(e.sub)}</small></a></li>`
            )
            .join('')
        : '<li class="cmv3-search__empty">該当する項目が見つかりませんでした</li>';
      results.hidden = false;
      input.setAttribute('aria-expanded', 'true');
    };

    input.addEventListener('input', () => render(input.value));
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        input.value = '';
        close();
      } else if (e.key === 'ArrowDown') {
        const first = results.querySelector('a');
        if (first) {
          e.preventDefault();
          first.focus();
        }
      } else if (e.key === 'Enter') {
        const first = results.querySelector('a');
        if (first) {
          e.preventDefault();
          first.click();
        }
      }
    });
    results.addEventListener('keydown', (e) => {
      const links = [...results.querySelectorAll('a')];
      const i = links.indexOf(document.activeElement);
      if (e.key === 'ArrowDown' && i < links.length - 1) {
        e.preventDefault();
        links[i + 1].focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (i > 0) links[i - 1].focus();
        else input.focus();
      } else if (e.key === 'Escape') {
        close();
        input.focus();
      }
    });
    results.addEventListener('click', (e) => {
      const link = e.target.closest('a');
      if (!link) return;
      e.preventDefault();
      navigateToId(link.getAttribute('href').slice(1));
      close();
    });
    document.addEventListener('click', (e) => {
      if (!searchBox.contains(e.target)) close();
    });
  }

  /* ---------- Copy-link buttons ---------- */
  const copySvg =
    '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/></svg>';
  root.querySelectorAll('.cmv3-cat > h2, .cmv3-item > h3').forEach((heading) => {
    const target = heading.closest('[id]');
    if (!target || !navigator.clipboard) return;
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'cmv3-copy';
    btn.innerHTML = copySvg;
    btn.setAttribute('aria-label', 'この項目へのリンクをコピー');
    btn.addEventListener('click', () => {
      const url = `${location.origin}${location.pathname}#${target.id}`;
      navigator.clipboard.writeText(url).then(() => {
        btn.classList.add('is-copied');
        btn.innerHTML = '✓';
        btn.setAttribute('aria-label', 'リンクをコピーしました');
        setTimeout(() => {
          btn.classList.remove('is-copied');
          btn.innerHTML = copySvg;
          btn.setAttribute('aria-label', 'この項目へのリンクをコピー');
        }, 1600);
      });
    });
    heading.appendChild(btn);
  });

  /* ---------- TOC: initial state, scrollspy, drawer auto-close ---------- */
  const desktopToc = root.querySelector('.cmv3-toc');

  if (desktopToc) {
    const first = desktopToc.querySelector('details');
    if (first) first.open = true;

    const links = new Map();
    desktopToc.querySelectorAll('a[data-toc]').forEach((a) => {
      links.set(a.getAttribute('href').slice(1), a);
    });

    let active = null;
    const setActive = (id) => {
      const link = links.get(id);
      if (!link || link === active) return;
      if (active) active.classList.remove('is-active');
      active = link;
      link.classList.add('is-active');
      const details = link.closest('details');
      if (details) details.open = true;
      const box = desktopToc.getBoundingClientRect();
      const item = link.getBoundingClientRect();
      if (item.top < box.top + 40 || item.bottom > box.bottom - 40) {
        link.scrollIntoView({ block: 'center' });
      }
    };

    const targets = [...root.querySelectorAll('.cmv3-cat, .cmv3-item')];
    const visible = new Set();
    const pick = () => {
      let best = null;
      let bestTop = -Infinity;
      visible.forEach((el) => {
        const top = el.getBoundingClientRect().top;
        if (top <= 140 && top > bestTop) {
          best = el;
          bestTop = top;
        }
      });
      if (!best) {
        let minTop = Infinity;
        visible.forEach((el) => {
          const top = el.getBoundingClientRect().top;
          if (top < minTop) {
            minTop = top;
            best = el;
          }
        });
      }
      if (best) setActive(best.id);
    };
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => (e.isIntersecting ? visible.add(e.target) : visible.delete(e.target)));
        pick();
      },
      { rootMargin: '-96px 0px -55% 0px', threshold: 0 }
    );
    targets.forEach((t) => io.observe(t));
  }
})();
</script>
