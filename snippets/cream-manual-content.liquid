<script>
  (() => {
    const root = document.querySelector('[data-cream-manual]');
    if (!root || root.dataset.initialized === 'true') return;

    root.dataset.initialized = 'true';

    const source = root.querySelector('[data-cream-manual-source]');
    const content = root.querySelector('[data-cream-manual-content]');
    const toc = root.querySelector('[data-cream-manual-toc]');
    const markdown = source ? source.textContent.trim() : '';

    const escapeHtml = (value) =>
      value.replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char]));

    const inline = (value) =>
      escapeHtml(value).replace(/`([^`]+)`/g, '<code>$1</code>');

    const slugify = (value, index) =>
      `cream-manual-${index}-${value
        .toLowerCase()
        .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
        .replace(/^-+|-+$/g, '') || 'section'}`;

    let html = '';
    let listOpen = false;
    let headingIndex = 0;
    const tocLinks = [];

    const closeList = () => {
      if (!listOpen) return;
      html += '</ul>';
      listOpen = false;
    };

    markdown.split(/\r?\n/).forEach((rawLine) => {
      const line = rawLine.trim();

      if (!line) {
        closeList();
        return;
      }

      const heading = line.match(/^(#{1,5})\s+(.+)$/);
      if (heading) {
        closeList();
        const level = heading[1].length;
        const text = heading[2];
        const id = slugify(text, headingIndex++);
        const tag = `h${level}`;
        html += `<${tag} id="${id}">${inline(text)}</${tag}>`;

        if (level === 2 || level === 3) {
          tocLinks.push({ id, text, level });
        }
        return;
      }

      if (line.startsWith('- ')) {
        if (!listOpen) {
          html += '<ul>';
          listOpen = true;
        }
        html += `<li>${inline(line.slice(2))}</li>`;
        return;
      }

      closeList();
      html += `<p>${inline(line)}</p>`;
    });

    closeList();
    content.innerHTML = html;

    toc.insertAdjacentHTML(
      'beforeend',
      tocLinks.map((link) =>
        `<a href="#${link.id}" style="margin-left:${link.level === 3 ? '12px' : '0'}">${inline(link.text)}</a>`
      ).join('')
    );
  })();
</script>
