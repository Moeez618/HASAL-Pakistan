{% doc %}
Renders an accessible audio player for a blog article.

@param {string} audio_url - The URL of the article audio file.

@example
{% render 'article-audio-player', audio_url: article.metafields.custom.audio_url.value %}
{% enddoc %}

<article-audio-player class="article-audio-player">
  <h2 class="article-audio-player__heading h4">{{ 'blogs.audio.heading' | t }}</h2>

  <audio data-audio preload="metadata" src="{{ audio_url | escape }}"></audio>

  <div class="article-audio-player__controls">
    <button
      type="button"
      class="article-audio-player__button"
      data-play
      data-play-label="{{ 'blogs.audio.play' | t | escape }}"
      data-pause-label="{{ 'blogs.audio.pause' | t | escape }}"
      aria-pressed="false"
    >
      <span data-play-text>{{ 'blogs.audio.play' | t }}</span>
    </button>

    <button type="button" class="article-audio-player__button" data-stop>
      {{ 'blogs.audio.stop' | t }}
    </button>

    <label class="article-audio-player__volume">
      <span>{{ 'blogs.audio.volume' | t }}</span>
      <input type="range" min="0" max="1" step="0.05" value="1" data-volume>
    </label>
  </div>

  <div class="article-audio-player__timeline">
    <input
      type="range"
      class="article-audio-player__progress"
      min="0"
      max="0"
      step="0.1"
      value="0"
      data-progress
      aria-label="{{ 'blogs.audio.seek' | t | escape }}"
      disabled
    >
    <output class="article-audio-player__time" data-time>
      <span data-current-time>0:00</span>
      <span aria-hidden="true"> / </span>
      <span data-duration>0:00</span>
    </output>
  </div>

  <p class="article-audio-player__error" data-error role="alert" hidden>
    {{ 'blogs.audio.error' | t }}
  </p>
</article-audio-player>

{% stylesheet %}
  .article-audio-player {
    display: grid;
    gap: 16px;
    margin: 0 0 32px;
    padding: 24px;
    border: 1px solid var(--border);
    background: var(--text-a5);
  }

  .article-audio-player__heading {
    margin: 0;
  }

  .article-audio-player__controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .article-audio-player__button {
    min-width: 104px;
    min-height: 44px;
    padding: 10px 16px;
    border: 1px solid var(--text);
    border-radius: var(--BUTTON-RADIUS, 0);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
  }

  .article-audio-player__button:hover {
    background: var(--text);
    color: var(--bg);
  }

  .article-audio-player__button:focus-visible,
  .article-audio-player input[type='range']:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
  }

  .article-audio-player__volume {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 44px;
  }

  .article-audio-player__volume input {
    width: 120px;
    accent-color: var(--text);
  }

  .article-audio-player__timeline {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
  }

  .article-audio-player__progress {
    width: 100%;
    accent-color: var(--text);
  }

  .article-audio-player__time {
    min-width: 92px;
    color: var(--text-a80);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  .article-audio-player__error {
    margin: 0;
    color: var(--text);
  }

  @media only screen and (max-width: 749px) {
    .article-audio-player {
      padding: 20px 16px;
    }

    .article-audio-player__button {
      flex: 1 1 0;
    }

    .article-audio-player__volume {
      justify-content: space-between;
      width: 100%;
    }

    .article-audio-player__volume input {
      flex: 1;
      width: auto;
    }

    .article-audio-player__timeline {
      grid-template-columns: 1fr;
    }

    .article-audio-player__time {
      text-align: left;
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('article-audio-player')) {
    customElements.define(
      'article-audio-player',
      class ArticleAudioPlayer extends HTMLElement {
        connectedCallback() {
          this.audio = this.querySelector('[data-audio]');
          this.playButton = this.querySelector('[data-play]');
          this.playText = this.querySelector('[data-play-text]');
          this.stopButton = this.querySelector('[data-stop]');
          this.volume = this.querySelector('[data-volume]');
          this.progress = this.querySelector('[data-progress]');
          this.currentTime = this.querySelector('[data-current-time]');
          this.duration = this.querySelector('[data-duration]');
          this.error = this.querySelector('[data-error]');

          this.playButton.addEventListener('click', () => this.togglePlayback());
          this.stopButton.addEventListener('click', () => this.stopPlayback());
          this.volume.addEventListener('input', () => {
            this.audio.volume = Number(this.volume.value);
          });
          this.progress.addEventListener('input', () => {
            this.audio.currentTime = Number(this.progress.value);
          });
          this.audio.addEventListener('loadedmetadata', () => this.setDuration());
          this.audio.addEventListener('durationchange', () => this.setDuration());
          this.audio.addEventListener('timeupdate', () => this.updateTime());
          this.audio.addEventListener('play', () => this.setPlaying(true));
          this.audio.addEventListener('pause', () => this.setPlaying(false));
          this.audio.addEventListener('ended', () => this.stopPlayback());
          this.audio.addEventListener('error', () => {
            this.error.hidden = false;
            this.playButton.disabled = true;
            this.stopButton.disabled = true;
            this.progress.disabled = true;
          });

          if (this.audio.readyState >= 1) this.setDuration();
        }

        async togglePlayback() {
          if (this.audio.paused) {
            try {
              await this.audio.play();
            } catch (error) {
              this.error.hidden = false;
            }
          } else {
            this.audio.pause();
          }
        }

        stopPlayback() {
          this.audio.pause();
          this.audio.currentTime = 0;
          this.updateTime();
        }

        setDuration() {
          if (!Number.isFinite(this.audio.duration)) return;

          this.progress.max = this.audio.duration;
          this.progress.disabled = false;
          this.duration.textContent = this.formatTime(this.audio.duration);
        }

        updateTime() {
          this.progress.value = this.audio.currentTime;
          this.currentTime.textContent = this.formatTime(this.audio.currentTime);
        }

        setPlaying(isPlaying) {
          this.playButton.setAttribute('aria-pressed', String(isPlaying));
          this.playText.textContent = isPlaying
            ? this.playButton.dataset.pauseLabel
            : this.playButton.dataset.playLabel;
        }

        formatTime(seconds) {
          if (!Number.isFinite(seconds)) return '0:00';

          const minutes = Math.floor(seconds / 60);
          const remainingSeconds = Math.floor(seconds % 60)
            .toString()
            .padStart(2, '0');

          return `${minutes}:${remainingSeconds}`;
        }
      }
    );
  }
{% endjavascript %}
