{% doc %}
Renders an accessible audio player for a blog article.

@param {string} audio_url - The URL of the article audio file.

@example
{% render 'article-audio-player', audio_url: article.metafields.custom.audio_link.value %}
{% enddoc %}

<article-audio-player-native class="article-audio-player">
  <h2 class="article-audio-player__heading h4">{{ 'blogs.audio.heading' | t }}</h2>

  <audio
    class="article-audio-player__native"
    data-audio
    controls
    playsinline
    preload="metadata"
    src="{{ audio_url | escape }}"
  ></audio>

  <button type="button" class="article-audio-player__stop" data-stop>
    {{ 'blogs.audio.stop' | t }}
  </button>

</article-audio-player-native>

{% stylesheet %}
  .article-audio-player {
    display: grid;
    gap: 16px;
    margin: 0 0 32px;
    padding: 24px;
    border: 1px solid var(--border);
    background: var(--text-a5);
  }

  .article-audio-player__heading {
    margin: 0;
  }

  .article-audio-player__native {
    width: 100%;
  }

  .article-audio-player__stop {
    width: fit-content;
    min-width: 104px;
    min-height: 44px;
    padding: 10px 16px;
    border: 1px solid var(--text);
    border-radius: var(--BUTTON-RADIUS, 0);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
  }

  .article-audio-player__stop:hover {
    background: var(--text);
    color: var(--bg);
  }

  .article-audio-player__stop:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
  }

  @media only screen and (max-width: 749px) {
    .article-audio-player {
      padding: 20px 16px;
    }

    .article-audio-player__stop {
      width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('article-audio-player-native')) {
    customElements.define(
      'article-audio-player-native',
      class ArticleAudioPlayer extends HTMLElement {
        connectedCallback() {
          if (this.isInitialized) return;

          this.isInitialized = true;
          this.audio = this.querySelector('[data-audio]');
          this.stopButton = this.querySelector('[data-stop]');
          this.handleStop = () => this.stopPlayback();

          this.stopButton.addEventListener('click', this.handleStop);
        }

        disconnectedCallback() {
          this.stopButton.removeEventListener('click', this.handleStop);
          this.isInitialized = false;
        }

        stopPlayback() {
          this.audio.pause();

          if (this.audio.readyState > 0) {
            this.audio.currentTime = 0;
          } else {
            this.audio.load();
          }
        }
      }
    );
  }
{% endjavascript %}
