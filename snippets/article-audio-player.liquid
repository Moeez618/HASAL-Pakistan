{% doc %}
Renders an accessible audio player for a blog article.

@param {string} audio_url - The URL of the article audio file.

@example
{% render 'article-audio-player', audio_url: article.metafields.custom.audio_link.value %}
{% enddoc %}

<article-audio-player class="article-audio-player" data-design-mode="{{ request.design_mode }}">
  <h2 class="article-audio-player__heading h4">{{ 'blogs.audio.heading' | t }}</h2>

  <audio
    class="article-audio-player__native"
    data-audio
    controls
    playsinline
    preload="metadata"
    src="{{ audio_url | escape }}"
  ></audio>

  <button type="button" class="article-audio-player__stop" data-stop>
    {{ 'blogs.audio.stop' | t }}
  </button>

  <p class="article-audio-player__error" data-error role="alert" hidden>
    {{ 'blogs.audio.error' | t }}
  </p>
</article-audio-player>

{% stylesheet %}
  .article-audio-player {
    display: grid;
    gap: 16px;
    margin: 0 0 32px;
    padding: 24px;
    border: 1px solid var(--border);
    background: var(--text-a5);
  }

  .article-audio-player__heading {
    margin: 0;
  }

  .article-audio-player__native {
    width: 100%;
  }

  .article-audio-player__stop {
    width: fit-content;
    min-width: 104px;
    min-height: 44px;
    padding: 10px 16px;
    border: 1px solid var(--text);
    border-radius: var(--BUTTON-RADIUS, 0);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
  }

  .article-audio-player__stop:hover {
    background: var(--text);
    color: var(--bg);
  }

  .article-audio-player__stop:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
  }

  .article-audio-player__stop:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .article-audio-player__error {
    margin: 0;
    color: var(--text);
  }

  @media only screen and (max-width: 749px) {
    .article-audio-player {
      padding: 20px 16px;
    }

    .article-audio-player__stop {
      width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('article-audio-player')) {
    customElements.define(
      'article-audio-player',
      class ArticleAudioPlayer extends HTMLElement {
        connectedCallback() {
          if (this.isInitialized) return;

          this.isInitialized = true;
          this.audio = this.querySelector('[data-audio]');
          this.stopButton = this.querySelector('[data-stop]');
          this.error = this.querySelector('[data-error]');
          this.handleStop = () => this.stopPlayback();
          this.handleError = () => this.handleMediaError();
          this.handleRecovery = () => this.clearMediaError();

          this.stopButton.addEventListener('click', this.handleStop);
          this.audio.addEventListener('error', this.handleError);
          this.audio.addEventListener('canplay', this.handleRecovery);
          this.audio.addEventListener('loadstart', this.handleRecovery);
        }

        disconnectedCallback() {
          this.stopButton.removeEventListener('click', this.handleStop);
          this.audio.removeEventListener('error', this.handleError);
          this.audio.removeEventListener('canplay', this.handleRecovery);
          this.audio.removeEventListener('loadstart', this.handleRecovery);
          this.isInitialized = false;
        }

        handleMediaError() {
          const mediaError = this.audio.error;

          if (!mediaError || mediaError.code === 1) return;

          this.error.hidden = false;
          this.stopButton.disabled = true;

          if (this.dataset.designMode === 'true') {
            console.error('Article audio failed to load', {
              code: mediaError.code,
              message: mediaError.message,
              currentSrc: this.audio.currentSrc,
            });
          }
        }

        clearMediaError() {
          this.error.hidden = true;
          this.stopButton.disabled = false;
        }

        stopPlayback() {
          this.audio.pause();

          if (this.audio.readyState > 0) {
            this.audio.currentTime = 0;
          } else {
            this.audio.load();
          }
        }
      }
    );
  }
{% endjavascript %}
